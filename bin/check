#!/usr/bin/env bash
# Compile the example app (ClojureDart → Dart) and statically analyze the result.
#
# Why the example and not the library alone: `clojure -M:cljd compile` only emits
# Dart, it never runs the Dart front-end — so an internally-inconsistent build
# still reports success and blows up only when `flutter run` compiles it at launch.
# The example app is the artifact that launches; it pulls the library in as a
# `:local/root` dep, so library errors surface here too.
#
# `dart analyze` reproduces the exact errors the Flutter front-end raises for the
# common failure mode (stale incremental output: dangling `IFnMixin_*` mixin
# references → `mixin_of_non_class`), in ~3s instead of a full `flutter build`.
#
# Usage:
#   bin/check            incremental compile + analyze (fast, matches dev loop)
#   bin/check --clean     wipe the ClojureDart cache first (fixes stale builds)
#
# Warnings/infos are the generated-code baseline; only error-severity issues fail.
set -uo pipefail
cd "$(dirname "$0")/../example" || exit 1

if [ "${1:-}" = "--clean" ]; then
	echo "▶ Wiping ClojureDart cache…"
	rm -rf .clojuredart lib/cljd-out
fi

echo "▶ Compiling example (ClojureDart → Dart)…"
if ! clojure -M:cljd compile; then
	echo "✖ ClojureDart compilation failed."
	exit 1
fi

echo "▶ Analyzing generated Dart (example/lib/cljd-out)…"
report=$(dart analyze lib/cljd-out 2>&1)
errors=$(printf '%s\n' "$report" | grep -E '^[[:space:]]*error ' || true)
if [ -n "$errors" ]; then
	printf '%s\n' "$errors"
	count=$(printf '%s\n' "$errors" | grep -c .)
	echo "✖ ${count} Dart error(s) in generated code."
	# Dangling IFnMixin_* references are stale incremental output, not a real
	# source bug — a clean rebuild fixes them.
	if printf '%s\n' "$errors" | grep -q mixin_of_non_class; then
		echo "  ↳ 'mixin_of_non_class' usually means a stale incremental build."
		echo "    Retry with: bin/check --clean"
	fi
	exit 1
fi
echo "✓ No Dart errors (warnings/infos are the generated-code baseline)."
