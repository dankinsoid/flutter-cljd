;; @ai-generated(solo)
(ns flutter-cljd.internal.collection.render
  "Virtualization engine for sliver-collection.

   One RenderSliver drives any layout map (see collection.layout): it creates
   and disposes children lazily, garbage-collects outside the cache window,
   and computes sliver geometry and scroll corrections. Layouts only answer
   geometry questions.

   Flow layouts get a persistent per-index geometry cache:
   - entries are validated by re-measuring attached children, so any data
     change self-heals at the first index whose size differs — no explicit
     invalidation protocol is needed;
   - when the viewport's first visible child changes its offset after a
     re-place (content above it grew or shrank), the engine emits a
     scrollOffsetCorrection so the visible content stays put;
   - after a cache loss the engine dead-reckons from the first attached
     child (layout's :anchor) instead of measuring everything from index 0.

   Indexed layouts (:geometry present) need no cache — geometry is exact math."
  (:require
   ["dart:core" :as dc]
   ["dart:math" :as math]
   ["dart:ui" :as ui]
   ["package:flutter/animation.dart" :as a]
   ["package:flutter/foundation.dart" :as fd]
   ["package:flutter/rendering.dart" :as r]
   ["package:flutter/widgets.dart" :as w]
   [flutter-cljd.internal.collection.animation :as an]
   [flutter-cljd.internal.collection.layout :as lay]
   [flutter-cljd.internal.collection.paint :as cpaint]
   [flutter-cljd.internal.collection.tween :as tw]))

;; --- parent data helpers ---

(defn- set-layout-offset! [^r/RenderBox child ^double offset]
  (let [^r/SliverMultiBoxAdaptorParentData pd (.-parentData child)]
    (.-layoutOffset! pd offset)))

(defn- set-cross-axis-offset! [^r/RenderBox child ^double offset]
  (let [^r/SliverGridParentData pd (.-parentData child)]
    (.-crossAxisOffset! pd offset)))

(declare flow-layout! indexed-layout! flying-flow! commit-pass! commit-prune? env-agg
         segment-start! update-velocity! overscan-extent)

;; --- Render object ---

(deftype CollectionRenderSliver
  [^r/RenderSliverBoxChildManager childMgr
   ^:mutable layoutModel  ;; layout map (see collection.layout)
   ^:mutable itemCount    ;; int? — nil means infinite/unknown
   ^:mutable ^double crossCached  ;; cross extent the cache was built for
   ^:mutable cache        ;; vec of {:offset :cross :extent :end :max-end :state}
   ^:mutable ^int cacheFirst      ;; absolute index of cache[0]
   ^:mutable baseState    ;; flow state before cache[0]
   ^:mutable ^a/Animation? tweenAnim   ;; drives per-tick relayout during a layout morph
   ^:mutable tweenListener            ;; the listener registered on tweenAnim (for removal)
   ^:mutable keyOf         ;; (fn [^int i] -> key) | nil ⇒ animation key = the index
   ^:mutable committed     ;; {key -> rect} content-space; persists across child GC, scoped
                           ;; geometrically to the cache band (see commit-pass!/prune-committed)
   ;; --- segment state (v2 keyed rect animator, see docs/CollectionRectAnimator.md) ---
   ^:mutable ^int curGen    ;; host's current segment gen (set by update-render!)
   ^:mutable ^int segGen    ;; gen the engine last BUILT segTween for; -1 = none built
   ^:mutable fromRects      ;; {key -> rect} OLD committed rects frozen at segment start
   ^:mutable ^double fromExtent ;; scroll extent frozen at segment start
   ^:mutable entering       ;; set of keys wiping open this segment
   ^:mutable exiting        ;; set of keys wiping shut this segment
   ^:mutable leaving        ;; {key -> edge frame} leave-slide `to`s this segment (§7b);
                            ;; also the GC exemption set for kept out-of-window cells
   ^:mutable segTween      ;; the built keyed-tween-layout for the current segment, or nil
   ^:mutable segAnchor     ;; nil | {:from ^double :to ^double :screen ^double} — the viewport-top
                           ;; INDEX SLOT set-point that drives this segment's scroll correction (docs §9);
                           ;; frozen in segment-start!, self-nullifying when the slot doesn't move
   ^:mutable ^double segPrevDesired ;; last EMITTED desired value for the incremental set-point (docs §9);
                           ;; seeded desired(0) = scroll-off at segment start so the animation delta composes
                           ;; with user drag (scrollOffset = drag + Σcorrections); telescopes exactly to to−from
   ^:mutable restingTop    ;; nil | {:idx ^int :off ^double} — OLD viewport top captured at the end of
                           ;; each resting pass (indices consistent); seeds segAnchor at segment start
   ^:mutable clips        ;; {child-index -> [vis-main vis-cross opacity]} for cells laid at full but painted
                          ;; clipped to a lerped window (§8a enter/exit collapse); rebuilt each indexed pass.
                          ;; opacity = the collapse fraction for a faded enter/exit cell, else 1.0
   ^:mutable ^bool fadeEnter  ;; fade entering cells 0→1 with the collapse (off when a custom :insert builder owns it)
   ^:mutable ^bool fadeExit  ;; fade exiting cells 1→0 with the collapse (off when a custom :remove builder owns it)
   ^:mutable prevLayout   ;; the layout the cells were resting under just before a layout-change segment (nil
                          ;; otherwise); segment-start! builds an `old-src` frame-source over it so a cell
                          ;; arriving into the viewport gets its OLD frame (size + relative position) and morphs
                          ;; instead of popping in at target (docs §7c). Consumed and cleared per segment.
   ^:mutable approxSize   ;; approximate-item-size seed (double | ui/Size | nil) — the cold prior for
                          ;; :avg-main/:avg-cross before any cell is measured (WS2.2 §1.1)
   ^:mutable measuredAgg  ;; nil | {:avg-main d :avg-cross d} — EMA over the live window; overrides the
                          ;; seed once cells exist. Populated by the consuming phase (flying regime); nil here.
   ^:mutable checkpoints  ;; sparse {^int index -> {:offset ^double :state <flow-state>}} — the exact flow
                          ;; state BEFORE that index, retained past GC as a backward-re-flow seed (WS2.2 §2.1).
                          ;; Recorded at renewal points (or a periodic stride when the layout has no
                          ;; :renewal-point?, e.g. masonry); pruned to the visible+cache band + one seed above.
   ^:mutable ^bool anchoredTo0 ;; true once a pass placed index 0 at offset 0 with an unbroken cache down to
                          ;; the live window ⇒ reported offsets are truth. false on cold deep start / far jump /
                          ;; invalidation above the frontier ⇒ offsets are checkpoint-relative estimates (§2.4).
                          ;; Consumed by finish-flow-geometry! (indicator honesty) + the exact-landing branch.
   ^:mutable ^double refineLastOffset ;; scrollOffset observed by the previous layout pass, compensated by any
                          ;; correction that pass emitted (so a same-frame correction re-run reads as no motion).
                          ;; NaN before the first pass. Drives the refinement suppression gate: a negative
                          ;; pass-over-pass delta = active backward drag / ballistic-up (WS2.3 tier 3).
   ^:mutable ^bool landingEmitted ;; one-shot: the previous pass emitted an exact-landing correction, so the
                          ;; current geometry is a fresh from-:init re-flow. If index 0 is STILL off zero the
                          ;; layout broke the ":init places index 0 at 0" contract — assert in debug, accept a
                          ;; constant inset in release (see landing-decision) instead of re-emitting forever.
   ;; --- WS2 phase E: velocity sensor + directional overscan + regime gate ---
   ^:mutable overscanConfig  ;; normalized :overscan spec (resolve-overscan); never nil (zero-config ⇒ {:mode :dynamic})
   ^:mutable ^double velocityEMA ;; smoothed signed scroll velocity px/s (correction-compensated). 0 at rest.
   ^:mutable ^int scrollSign  ;; hysteresis-smoothed scroll direction: +1 forward/down, -1 back/up, 0 idle
   ^:mutable ^double lastVelStamp ;; frame timestamp (micros) of the last velocity update; NaN before the first.
                          ;; Gates the EMA to once per frame — a same-frame correction re-run must not decay it.
   ^:mutable curRegime    ;; :resting | :flying | :landing — the fidelity regime the last velocity update classified.
                          ;; Drives the flow dispatch (flying ⇒ approximate placement) and overscan gating.
   ^:mutable ^double overscanBehind ;; this frame's resolved leading/trailing overscan margins (px), computed once
   ^:mutable ^double overscanAhead ;; in performLayout and read by the drivers + commit-pass!. 0 when flying/disabled.
   ^:mutable ^int flyingRun ;; consecutive frames the EMA has held ≥ v-fast (0 = not fast) — the flying
                          ;; entry gate; a lone fast frame (desktop scroll notch/jump/glitch) never trips it.
   ^:mutable ^bool crossLayoutReanchor ;; a layout :id change dropped the cache; the surviving top child's
                          ;; last offset lives in the OLD layout's coordinate space. The next seed-cache!
                          ;; must re-anchor it at the NEW layout's :approx-offset (not the stale, differently
                          ;; scaled offset) so the leading extent above the window matches the new layout and
                          ;; backfill can still walk to index 0. Set by update-render!, consumed by seed-cache!.
   ^:mutable ^double reanchorShift ;; NaN | the (approx − stale) offset delta a cross-layout re-anchor
                          ;; introduced this pass; flow-layout! emits it as a scrollOffsetCorrection so the
                          ;; visible child holds still while the indicator jumps to the new-layout estimate.
   ^:mutable ^int passMaterialized ;; children laid out by the CURRENT flow pass (walk / backfill / leading
                          ;; inserts); reset per pass. Feeds the kDebugMode O(window+overscan) materialization
                          ;; tripwire (assert-materialization-bounded!) — a pass that lays O(gap) children
                          ;; means some path walked a gap instead of seeding geometrically.
   ^:mutable ^double pendingLandingWs ;; NaN | the window start (scrollOffset+cacheOrigin) the exact-landing
                          ;; emission expects its corrected re-run at. seed-cache! consumes it
                          ;; (landing-reseed-decision): near the expectation it FORCES the from-:init seed —
                          ;; the landing contract — because the usual empty-cache dead-reckon at a surviving
                          ;; child (whose stale offset the correction deliberately did not move) rebuilds the
                          ;; STALE frame and re-derives the same residual every pass (the non-convergent
                          ;; correction loop / per-frame :violated assert). Far from it the frame aborted
                          ;; mid-correction (viewport cycle cap) — abandon: disarm landingEmitted, seed normally.
   ^:mutable dyingSlots] ;; WS3.2: host-supplied SPARSE dying representation — ascending-by-shadow-index
                          ;; [{:index i :key k} ...], #dying entries. segment-start! reads it to build the
                          ;; window-scoped shadow frame source without an O(n) live/dying mask. [] when nothing dies.
  :extends (r/RenderSliverMultiBoxAdaptor .childManager childMgr)

  ;; SliverGridParentData for every layout: flow layouts use crossAxisOffset too
  (setupParentData [_this ^r/RenderObject child]
    (when-not (instance? r/SliverGridParentData (.-parentData child))
      (.-parentData! child (r/SliverGridParentData)))
    nil)

  (childCrossAxisPosition [_this ^r/RenderBox child]
    (let [^r/SliverGridParentData pd (.-parentData child)]
      (or (.-crossAxisOffset pd) 0.0)))

  ;; §8a: replicates RenderSliverMultiBoxAdaptor.paint's child-paint offset math
  ;; verbatim, then — for any child whose index is in `clips` — pushClipRect to the
  ;; cell's lerped VISIBLE window [vis-main vis-cross] (anchored at the child's
  ;; main-start + cross-start corner) so a cell laid out at its full stable size is
  ;; REVEALED along the axis its layout collapses (main for a list, cross for a
  ;; grid/wrap). The anchor corner is the pre-addExtent childOffset (== top-left for
  ;; down/right; the far edge for up/left), so the reveal always grows from the
  ;; scroll-start (gap-side) edge of the cell.
  (paint [^CollectionRenderSliver this ^r/PaintingContext context ^ui/Offset offset]
    (when (.-firstChild this)
      (let [^r/SliverConstraints c (.-constraints this)
            ad (r/applyGrowthDirectionToAxisDirection (.-axisDirection c) (.-growthDirection c))
            up (= ad r/AxisDirection.up)
            down (= ad r/AxisDirection.down)
            left (= ad r/AxisDirection.left)
            ^double mux (cond left -1.0 (= ad r/AxisDirection.right) 1.0 :else 0.0)
            ^double muy (cond up -1.0 down 1.0 :else 0.0)
            ^double cux (if (or up down) 1.0 0.0)
            ^double cuy (if (or up down) 0.0 1.0)
            add-extent (or up left)
            ^double paint-extent (let [^r/SliverGeometry g (.-geometry this)] (.-paintExtent g))
            ^double ox (+ (.-dx offset) (if left paint-extent 0.0))
            ^double oy (+ (.-dy offset) (if up paint-extent 0.0))
            clips (.-clips this)
            ^double rpe (.-remainingPaintExtent c)]
        (loop [child (.-firstChild this)]
          (when child
            (let [^r/RenderBox ch child
                  ^double md (.childMainAxisPosition this ch)
                  ^double cd (.childCrossAxisPosition this ch)
                  ^double pe (.paintExtentOf this ch)
                  ;; base = main-start corner (framework childOffset before addExtent)
                  ^double bx (+ ox (* mux md) (* cux cd))
                  ^double by (+ oy (* muy md) (* cuy cd))
                  ^ui/Offset child-off (if add-extent
                                         (ui/Offset (+ bx (* mux pe)) (+ by (* muy pe)))
                                         (ui/Offset bx by))]
              (when (and (< md rpe) (> (+ md pe) 0.0))
                (if-let [visible (get clips (.indexOf this ch))]
                  ;; visible = [vis-main vis-cross opacity]; clip anchored at the cell's
                  ;; main-start + cross-start corner (bx,by) so the reveal grows
                  ;; from the gap side (start) along WHICHEVER axis its layout
                  ;; collapses — main for a list, cross for a grid/wrap. opacity < 1
                  ;; fades the cell with the SAME collapse fraction (enter/exit default).
                  (let [^double vm (double (nth visible 0))
                        ^double vc (double (nth visible 1))
                        ^double op (double (nth visible 2 1.0))
                        clip-rect (ui/Rect.fromPoints
                                   (ui/Offset bx by)
                                   (ui/Offset (+ bx (* mux vm) (* cux vc))
                                              (+ by (* muy vm) (* cuy vc))))]
                    (cpaint/paint-clipped-cell! context (.-needsCompositing this)
                                                clip-rect op ch child-off))
                  (.paintChild context ch child-off)))
              (recur (.childAfter this ch)))))))
    nil)

  (performLayout [this]
    (let [^r/SliverConstraints c (.-constraints this)]
      (when (not= (.-crossAxisExtent c) (.-crossCached this))
        (.-crossCached! this (.-crossAxisExtent c))
        (.-cache! this [])
        (.-baseState! this nil)
        ;; cross-extent change re-packs every wrap/masonry run — all checkpoints
        ;; are stale (list's are cross-independent, but dropping all is cheap).
        (.-checkpoints! this {})
        (.-anchoredTo0! this false)
        (.-landingEmitted! this false)
        (.-pendingLandingWs! this dc/double.nan))
      ;; WS2 phase E: update the velocity sensor (once per frame) and resolve this
      ;; frame's directional overscan window BEFORE dispatching. A playing segment
      ;; never flies and never overscans — the WS1.3 set-point + widen-window! own
      ;; the window there, so the regime gate must not fight it (scenario 6).
      (let [prev-regime (.-curRegime this)]
        (update-velocity! this c)
        (let [seg? (some? (.-tweenAnim this))
              [^double behind ^double ahead] (if seg? [0.0 0.0]
                                               (overscan-extent this c (.-curRegime this)))]
          (.-overscanBehind! this behind)
          (.-overscanAhead! this ahead))
        (cond
          ;; RESTING: no animation — run the plain target through its natural driver.
          ;; The approximate-placement (flying) path engages ONLY when the caller
          ;; opted in via :overscan {:flying true} (:fly? on the spec) AND the regime
          ;; sustained a fast run. Zero-config keeps real placement always
          ;; (pixel-perfect; desktop pointer-scroll would otherwise misread as a
          ;; fling). `entry?` = first pass of a flying run, so flying-flow! drops the
          ;; real cache once instead of every pass.
          (nil? (.-tweenAnim this))
          (let [layout (.-layoutModel this)
                regime (.-curRegime this)
                fly? (and (= :flying regime) (:fly? (.-overscanConfig this)) (:approx-offset layout))]
            (cond
              (:geometry layout) (indexed-layout! this layout c)
              fly? (flying-flow! this layout c (not= :flying prev-regime))
              :else (flow-layout! this layout c)))

          ;; SEGMENT START: host bumped gen — capture the target from the new tree.
          (not= (.-curGen this) (.-segGen this))
          (segment-start! this c)

          ;; SEGMENT CONTINUE: advance the built tween (progress reads the Animation).
          :else
          (indexed-layout! this (.-segTween this) c)))
      ;; Refinement motion sensor: remember this pass's offset compensated by any
      ;; correction it emitted, so the correction's same-frame re-run (and the
      ;; corrected next frame) read as no user motion — only real drag/ballistic
      ;; deltas reach the velocity sensor + suppression gate.
      (let [^r/SliverGeometry g (.-geometry this)]
        (.-refineLastOffset! this (+ (.-scrollOffset c)
                                     (double (or (.-scrollOffsetCorrection g) 0.0)))))
      ;; Phase D geometric committed scoping, phase-E-widened to the overscan band:
      ;; prune to [ws − behind, we + ahead], but only between segments and never on
      ;; a correction pass (commit-prune?).
      (let [^double ws (+ (.-scrollOffset c) (.-cacheOrigin c))
            ^double we (+ ws (.-remainingCacheExtent c))
            ^r/SliverGeometry g (.-geometry this)
            corrected? (some? (.-scrollOffsetCorrection g))]
        (commit-pass! this (lay/make-env c (.-itemCount this) (env-agg this))
                      (- ws (.-overscanBehind this)) (+ we (.-overscanAhead this))
                      (commit-prune? (some? (.-tweenAnim this)) corrected?)))))

  (dispose [^CollectionRenderSliver this]
    (when-let [l (.-tweenListener this)]
      (when-let [^a/Animation anim (.-tweenAnim this)]
        (.removeListener anim l)))
    (.dispose ^super this)))

(defn- env-agg
  "The approximate-layout aggregates make-env carries: the approximate-item-size
   seed plus the engine's measured EMA (nil until a consuming phase populates it)."
  [^CollectionRenderSliver rs]
  {:approx-size (.-approxSize rs) :measured (.-measuredAgg rs)})

;; --- checkpoint store (WS2.2 §2.1) — pure kernels over a {idx -> {:offset :state}} map ---

(def ^:private checkpoint-stride
  "Index stride at which a layout WITHOUT :renewal-point? (e.g. masonry) gets a
   periodic full-:state checkpoint. Coarser than a natural run boundary but still
   an exact backward-re-flow seed."
  32)

(defn cp-record
  "Adds/refreshes the checkpoint at `index`: `offset` is that index's main-axis
   offset, `state` the flow state BEFORE it (the walk's state-before-i). Pure."
  [checkpoints ^int index ^double offset state]
  (assoc checkpoints index {:offset offset :state state}))

(defn cp-nearest-at-or-below
  "The checkpoint with the greatest index <= `target`, as {:index :offset :state},
   or nil. This is the seed for a backward re-flow of the run(s) above `target`. Pure."
  [checkpoints ^int target]
  (reduce-kv (fn [best k v]
               (if (and (<= ^int k target)
                        (or (nil? best) (> ^int k ^int (:index best))))
                 (assoc v :index k)
                 best))
             nil checkpoints))

(defn cp-drop-from
  "Drops checkpoints with index >= `j` — a resize / mutation at `j` shifts every
   offset prefix-sum below it, so those seeds are stale. Pure."
  [checkpoints ^int j]
  (reduce-kv (fn [m k v] (if (>= ^int k j) m (assoc m k v))) {} checkpoints))

(defn cp-prune-offset
  "Checkpoint memory bound (WS2 §2.1), the same geometric rule as the committed
   cache since Phase D: keep checkpoints whose stored :offset is within the
   [ws, we] band (the visible+cache region's run starts), PLUS the single
   greatest-index checkpoint strictly above the band (offset < ws) as the seed a
   backward re-flow walks forward from. Everything further above is dropped and
   re-recorded on the next downward walk. Never pruned by count or age. Bounded
   O((we-ws)/min-run-height). Sound because the anchoredTo0 frontier does not
   rest on checkpoints (see frontier-after-prune): exact near-0 landing walks
   from :init, and a deep window only ever re-flows from the retained band+seed.
   Phase E re-scopes [ws, we] to the velocity-widened overscan window. Pure."
  [checkpoints ^double ws ^double we]
  (let [seed (reduce-kv (fn [best k v]
                          (if (< ^double (:offset v) ws)
                            (if (or (nil? best) (> ^int k ^int best)) k best)
                            best))
                        nil checkpoints)]
    (reduce-kv (fn [m k v]
                 (let [^double o (double (:offset v))]
                   (if (or (and (>= o ws) (<= o we))
                           (and seed (= ^int k ^int seed)))
                     (assoc m k v)
                     m)))
               {} checkpoints)))

(defn frontier-after-prune
  "anchoredTo0 after a geometric prune / front-trim pass — the NEW frontier
   invariant (Row 3). anchoredTo0 no longer claims \"index 0 is still in the
   cache\" (front-trim drops the from-0 prefix while deep); it claims the retained
   entries' OFFSETS ARE EXACT — chained from a from-0-exact walk. trim-front drops
   the exact prefix but keeps the retained offsets and re-seeds baseState from the
   exact stored state, and the checkpoint / committed prunes touch no offsets at
   all — so NO geometric prune can degrade the claim. Degradation is owned entirely
   by the offset-PRODUCING ops that introduce estimates (cold / far inverse seed
   and dead-reckon re-anchor in seed-cache!, walk!'s mismatch truncation, the
   underflow branch) plus mutation invalidation in update-render! (a count change
   shifts the retained offsets, drops all checkpoints, and clears the flag). Each
   sets the flag directly, so this reconciliation is the identity — it exists to
   state, at the one prune site, that pruning/trimming preserves the frontier. Pure."
  [^bool anchored]
  anchored)

(defn stitch-prefix
  "Prepends the `prefix` cache entries (index-ascending, each carrying a running
   :max-end seeded fresh from the prefix) onto `cache`, restoring the GLOBAL
   running-max :max-end invariant across the seam so bsearch-max-end stays sound.
   `prefix` covers indices strictly above cache[0]; a tall mid-run item above the
   seam can push :max-end past the old head, so carry the prefix's final max-end
   forward into the old entries until it is absorbed (usually one step). Pure."
  [prefix cache]
  (if (empty? prefix)
    cache
    (let [^double carry (double (:max-end (peek prefix)))]
      (into (vec prefix)
            (loop [^int i 0 out (transient [])]
              (if (< i (count cache))
                (let [e (nth cache i)
                      ^double me (double (:max-end e))]
                  (if (>= me carry)
                    ;; carry absorbed — the rest of the cache is already a correct
                    ;; running max (it is non-decreasing from here).
                    (persistent! (reduce conj! out (subvec cache i)))
                    (recur (inc i) (conj! out (assoc e :max-end carry)))))
                (persistent! out)))))))

;; --- cold-start / far-jump index seeding: invert the monotone :approx-offset ---

(defn invert-approx-offset
  "Binary-searches the MONOTONE non-decreasing `approx-fn` (int index -> double
   main offset) for the greatest index whose approx offset is <= `target`, i.e.
   the index to attach a cold deep window at. Lands within one item of the true
   index on a well-formed monotone estimate. `n` bounds the search (item count);
   nil ⇒ gallop up to `unbounded-cap`. On a DEGENERATE estimate (constant density,
   e.g. no seeded/measured avg) the result saturates at the last index — the
   caller (seed-cache!) guards on approx(start) actually reaching `target`. Pure."
  [approx-fn ^double target n]
  (let [unbounded-cap 16777216
        ^int hi (if n
                  (int n)
                  ;; gallop to bracket the target when the count is unknown/infinite
                  (loop [^int h 1]
                    (cond
                      (> (double (approx-fn h)) target) h
                      (>= h unbounded-cap) unbounded-cap
                      :else (recur (* 2 h)))))]
    (loop [^int lo 0 ^int hi hi]
      (if (< lo hi)
        (let [^int mid (bit-shift-right (+ lo hi) 1)]
          (if (<= (double (approx-fn mid)) target)
            (recur (inc mid) hi)
            (recur lo mid)))
        (math/max 0 (dec lo))))))

;; --- progressive offset refinement (WS2 phase C) — pure kernels ---
;; Note: Phase C's per-pass `refine-suppress-eps` / `refine-suppressed?` signal was
;; retired in Phase E — refinement suppression now reads the velocity sensor
;; (see refine-suppressed? in the phase-E section above).

(defn refine-emit?
  "The WS1.3 exclusivity + suppression gate in one place: refinement corrections
   are emitted only on a RESTING flow pass — a playing segment freezes the offset
   model at capture and emits only the segment set-point correction, so the two
   are mutually exclusive per pass — and only while not suppressed by active
   backward motion. This gates the ABOVE-ANCHOR seam refinement (reflow-from-
   checkpoint!), which is mid-content churn a fast motion would race. Pure."
  [^bool segment? ^bool suppressed?]
  (and (not segment?) (not suppressed?)))

(defn origin-refine-emit?
  "Emission gate for the ORIGIN corrections — exact-landing (index 0 at offset 0)
   and top-underflow (indices stranded at/above the coordinate origin). Unlike the
   above-anchor seam refinement (refine-emit?), these reconcile the SCROLL BOUNDARY
   the motion is heading toward: one-shot, convergent and pixel-stable (shift-
   attached-from! / from-:init re-flow hold the visible children put), and Flutter
   resolves the scrollOffsetCorrection within the same frame. So firing them during
   a fast fling closes the boundary WITHIN the frame instead of leaving a gap above
   item 0 until deceleration re-enables refinement (#B) — they are NOT gated by
   ballistic/drag velocity. Only the WS1.3 segment exclusivity applies (a playing
   segment freezes the offset model at capture). Pure."
  [^bool segment?]
  (not segment?))

(defn refine-seam-delta
  "How far a checkpoint-seeded re-flow says the cache head REALLY sits from
   where the estimated cache placed it: places head index `cf` (its measured
   `head-size`) through the layout's :place seeded with the re-flowed prefix's
   end state, and returns `true-offset − old-head` — this seam's refinement
   correction. 0.0 when below the pixel threshold (converged / emit-once). Pure."
  [layout env ^int cf ^ui/Size head-size end-state ^double old-head]
  (let [[gm _] ((:place layout) env cf head-size end-state)
        ^double d (- (double (:offset gm)) old-head)]
    (if (> (.abs d) 1e-3) d 0.0)))

(defn landing-decision
  "Decision kernel for the exact-landing check when the cache reaches index 0:
   `z` is index 0's current offset, `emit?` the refinement gate, and
   `emitted-before?` whether the previous pass already emitted a landing
   correction (⇒ the current geometry is a fresh from-:init re-flow). Returns:
     :converged — index 0 sits at 0: flip anchoredTo0, clear the one-shot.
     :defer     — gated (suppressed / mid-segment): leave the offset model frozen.
     :emit      — drop the cache, emit −z, arm the one-shot; the corrected
                  re-run re-flows from :init and must land 0 at 0 (seed-cache!
                  enforces the from-:init walk via landing-reseed-decision —
                  a dead-reckoned re-seed would re-derive the same residual).
     :violated  — the fresh :init re-flow STILL left index 0 off zero: the
                  layout broke the \":init walk places index 0 at offset 0\"
                  contract. Assert in debug; in release accept z as a constant-
                  inset origin instead of re-emitting the same residual forever.
   Pure."
  [^double z ^bool emit? ^bool emitted-before?]
  (cond
    (<= (.abs z) 1e-3) :converged
    (not emit?) :defer
    emitted-before? :violated
    :else :emit))

(def ^:private ^double underflow-eps
  "Sub-pixel slack below which a leading deficit isn't worth manufacturing."
  0.5)

(defn underflow-decision
  "Decision kernel for the top-underflow branch of backfill. The leading backfill
   stalled at frontier index `cf` whose current offset is `head` (cache[0].offset),
   while the layout's honest estimate places index cf at `honest` (= approx-offset(cf),
   the extent of indices [0,cf)). Top-underflow = an index > 0 stranded at or above
   the coordinate origin: `cf`>0 AND `head` sits at ~0 or below while `honest` says it
   belongs a positive `deficit = honest − head` further down. The re-anchor estimate
   undershot the true leading extent, so backfill exhausted its offset budget before
   reaching index 0 and the deep frontier pins at offset 0 (items above unreachable).
   The origin test — not the deficit magnitude — is the gate: a normal mid-scroll
   stall leaves `head` ≈ the large window start (never ≤ 0), so it can't false-fire.
   `emit?` is the refinement gate (resting, unsuppressed). Returns:
     :ok    — not underflow (cf==0, frontier above origin, or honest deficit within
              eps): the caller falls through to the landing check.
     :defer — underflow but gated (suppressed / mid-segment): the offset model stays
              frozen; a later resting pass picks the deficit up.
     :emit  — manufacture `deficit`: shift the window up by it and emit it as a
              pixel-stable scrollOffsetCorrection, restoring the honest scroll range
              so backfill reaches index 0 on the corrected re-runs.
   Pure."
  [^int cf ^double head ^double honest ^bool emit?]
  (cond
    (not (pos? cf)) :ok
    (> head underflow-eps) :ok
    (<= (- honest head) underflow-eps) :ok
    (not emit?) :defer
    :else :emit))

(defn landing-reseed-decision
  "Seed decision for the pass right after an exact-landing emission. `pending-ws`
   is the window start (scrollOffset+cacheOrigin) the emission recorded for its
   corrected re-run (NaN = no landing pending); `ws` the current pass's window
   start; `slack` the tolerated drift (one viewport). The landing contract —
   \"the corrected re-run re-flows from :init, placing index 0 at 0\" — is what
   makes the correction ABSORBING: seed-cache!'s usual empty-cache dead-reckon at
   a surviving attached child (whose stale offset the correction deliberately did
   not move) would rebuild the stale coordinate frame, re-derive the SAME residual
   from the SAME estimation error, and misclassify the honest layout as :violated
   (the device per-frame assert under a DrivenScrollActivity). Returns:
     :init-seed — the window is where the corrected re-run expects it: force the
                  from-:init walk (cacheFirst 0, baseState :init).
     :abandon   — the frame aborted between emission and re-run (viewport cycle
                  cap) and the window has moved elsewhere: the from-:init premise
                  is gone — disarm the one-shot state and seed normally.
     :none      — no landing pending.
   Pure."
  [^double pending-ws ^double ws ^double slack]
  (cond
    (.-isNaN pending-ws) :none
    (<= (.abs (- ws pending-ws)) slack) :init-seed
    :else :abandon))

(def ^:private ^double agg-ema-alpha
  "EMA weight of the current pass's live-window mean in :avg-main/:avg-cross."
  0.25)

(defn ema-agg
  "Folds one pass's live-window mean extents into the measured aggregates
   (design §1.1). nil prev seeds directly from the sample — measured reality
   overrides the approximate-item-size prior as soon as cells exist. Pure."
  [prev ^double mean-main ^double mean-cross]
  (if (nil? prev)
    {:avg-main mean-main :avg-cross mean-cross}
    {:avg-main (+ (* (- 1.0 agg-ema-alpha) (double (:avg-main prev)))
                  (* agg-ema-alpha mean-main))
     :avg-cross (+ (* (- 1.0 agg-ema-alpha) (double (:avg-cross prev)))
                   (* agg-ema-alpha mean-cross))}))

;; --- velocity sensor + directional overscan + regime gate (WS2 phase E) — pure kernels ---

(def ^:private overscan-tunables
  "Every Phase E threshold in ONE place. All values are reasoned starting points
   and AWAIT ON-DEVICE CALIBRATION (WS2.1 §9 open Q3) — see the phase-E device-
   calibration checklist. Units: :v-* px/s, :lookahead-ms ms, fractions of the
   viewport main extent, alpha dimensionless."
  {:v-slow          220.0    ;; |v| below ⇒ resting band: refinement on, small symmetric base overscan
   :v-fast         3200.0    ;; |v| above ⇒ flying: approximate placement, overscan + refinement OFF
   :min-fast-run      3      ;; consecutive frames the EMA must hold ≥ v-fast before flying engages —
                             ;; a single big-delta frame (desktop wheel/trackpad notch, a jumpTo, a
                             ;; correction mis-compensation, the first post-idle sample) must NOT fly.
   :ema-alpha         0.35   ;; velocity EMA weight of the current frame's instantaneous sample
   :teleport-v      50000.0  ;; |inst| above ⇒ programmatic jumpTo teleport, not motion: reset the sensor.
                             ;; Safely above any input device (fling caps ~8k px/s, a wheel notch reads
                             ;; ~12k, a 3-notch frame ~36k) and below any far jump (50k ≈ >1vp per frame).
                             ;; A far animateTo faster than ~60vp/s also reads as teleporting — it then
                             ;; rides the geometric inverse-seed (O(window)/frame) instead of flying.
   :dir-flip-eps     90.0    ;; px/s the reversed velocity must clear before scrollSign flips (anti-thrash hysteresis)
   :suppress-v      120.0    ;; upward |v| above which above-anchor refinement corrections defer (WS2.3 tier 3)
   :lookahead-ms    120.0    ;; read-ahead horizon: velocity-scaled lead = |v|·lookahead
   :ahead-max-frac    1.0    ;; the velocity-scaled ahead margin is capped at this × viewport
   :base-frac         0.25}) ;; zero-config symmetric base as a fraction of viewport when no :avg-main is known yet

(defn frame-velocity
  "Instantaneous signed scroll velocity px/s from a correction-compensated offset
   delta over a frame gap. `dt-micros` is the frame timestamp delta in MICROseconds
   (WidgetsBinding.currentFrameTimeStamp is a Duration); ÷1e6 → seconds, so px÷s.
   Returns 0.0 when dt is non-positive (guards a same-frame re-run). Pure.
   NOTE: on desktop, pointer-scroll (wheel/trackpad) is delivered as a discrete
   per-frame offset JUMP, not a physics drag — a single 200px notch over a 16.7ms
   frame reads as ~12000px/s. That is why flying must require a SUSTAINED fast run
   (fidelity-regime `min-fast-run`), not a single fast sample."
  [^double prev-off ^double so ^double dt-micros]
  (let [^double dt (/ dt-micros 1000000.0)]
    (if (pos? dt) (/ (- so prev-off) dt) 0.0)))

(defn vel-ema
  "Folds one frame's instantaneous velocity `sample` into the EMA. NaN prev (no
   prior sample) seeds directly. Pure."
  [^double prev ^double sample ^double alpha]
  (if (.-isNaN prev) sample (+ (* (- 1.0 alpha) prev) (* alpha sample))))

(defn vel-sign
  "Hysteresis direction: keeps `prev` sign until the signed velocity clears
   ±`flip-eps`, so a brief zero-crossing at a fling's tail or a jittery drag
   doesn't swap the asymmetric overscan every frame (WS2.1 §5). Pure."
  [^int prev ^double v ^double flip-eps]
  (cond (> v flip-eps) 1 (< v (- flip-eps)) -1 :else prev))

(defn fold-velocity-sample
  "One frame's velocity-sensor fold → {:ema :run} from the instantaneous sample
   `inst-v`. Two jump defenses (a far jumpTo delivers its whole delta as ONE
   frame's delta — `min-fast-run` alone does not cover it):
   - TELEPORT: |inst-v| >= `teleport-v` cannot come from any input device — it is
     a programmatic jump. Reset the sensor instead of folding; naively folded,
     the EMA's decay tail holds >= v-fast for ~13 still frames and leaks into
     flying entry and refinement suppression while the user is at rest.
   - SUSTAINED gate: the fast-run counter increments only while the INSTANTANEOUS
     sample is also fast — a decaying EMA alone (the still frames after a wheel
     notch / sub-teleport jump) must not accumulate a \"sustained\" run.
   Pure."
  [^double prev-ema ^int prev-run ^double inst-v ^double alpha ^double v-fast ^double teleport-v]
  (if (>= (.abs inst-v) teleport-v)
    {:ema 0.0 :run 0}
    (let [^double ema (vel-ema prev-ema inst-v alpha)
          ^int run (if (and (>= (.abs ema) v-fast) (>= (.abs inst-v) v-fast))
                     (inc prev-run) 0)]
      {:ema ema :run run})))

(defn fidelity-regime
  "Classifies the pass into :resting / :flying / :landing from the smoothed speed
   `absv`, the deceleration flag `decel?`, the count of consecutive fast frames
   `fast-run` (this frame included), and the previous regime (WS2.1 §2.3).
   Hysteresis band [v-slow, v-fast]: enter flying only once the EMA has held
   ≥ v-fast for `min-fast-run` consecutive frames (a single fast frame — a desktop
   scroll notch, a jumpTo, a correction glitch, the first post-idle sample — must
   NOT fly), then stay flying down to v-slow; drop out of flying while still
   decelerating ⇒ landing (re-enables real materialisation + refinement + overscan
   so the stop lands exactly), which relaxes to resting once motion dies. A medium
   drag that never sustains v-fast stays resting (Phase D behavior). Pure."
  [prev ^double absv ^bool decel? ^int fast-run ^double v-slow ^double v-fast ^int min-fast-run]
  (cond
    (and (>= absv v-fast) (>= fast-run min-fast-run)) :flying
    (and (= prev :flying) (> absv v-slow)) :flying
    (and (or (= prev :flying) (= prev :landing)) decel? (> absv 1.0)) :landing
    :else :resting))

(defn refine-suppressed?
  "WS2.3 tier-3 gate on the VELOCITY signal (Phase E supersedes Phase C's per-pass
   eps): defer above-anchor refinement corrections when emitting a same-frame
   scrollOffsetCorrection would race live motion. Two cases:
   - active UP drag/fling (scrollSign < 0) above `suppress-v` — the original rule;
   - ANY fling at/above `v-fast` (either direction) — a scrollOffsetCorrection
     during a fast ballistic tick fights the simulation (correctBy shifts pixels
     under it, the next tick snaps back) and can terminate it early (the abrupt
     stop). Corrections resume once the fling decelerates, so landing still refines
     to the exact stop. `absv` px/s. Pure."
  [^int scroll-sign ^double absv ^double suppress-v ^double v-fast]
  (or (>= absv v-fast)
      (and (neg? scroll-sign) (> absv suppress-v))))

(defn resolve-overscan
  "Normalizes the :overscan config form once at build (mirrors parse-anim-config).
   Forms:
     number px          → fixed symmetric px, no velocity scaling
     {:viewport f}      → fixed symmetric fraction of the viewport main extent
     {:ahead :behind :max :lookahead-ms}  → velocity-scaled dynamic (any subset; rest default)
     false | 0 | :none  → disabled (Flutter :cache-extent still applies)
     (fn [ctx] …)       → escape hatch, re-normalized per frame (ctx per WS2.1 §6)
     nil (not given)    → zero-config dynamic default (small symmetric base + ~120ms lookahead, ~1vp cap)
   Returns a normalized spec map (never nil). Pure.

   FLYING OPT-IN (`:flying true` in the dynamic map): the approximate-placement
   regime (flying-flow!) is engaged ONLY when the spec carries `:fly? true`, which
   only an explicit `{... :flying true}` sets. Zero-config and every other form
   keep REAL placement always — overscan still widens the materialisation window
   (real, measured cells kept alive past the viewport), but a fast fling never
   drops to estimated offsets. This makes zero-config scrolling pixel-perfect on
   every input device (desktop pointer-scroll delivers discrete per-frame jumps
   that a velocity gate alone can misread as a fling); flying is available for
   callers who opt in and can tolerate transient estimated frames mid-fling."
  [overscan]
  (cond
    (nil? overscan) {:mode :dynamic}
    (false? overscan) {:disabled true}
    (= :none overscan) {:disabled true}
    (and (number? overscan) (zero? overscan)) {:disabled true}
    (number? overscan) {:mode :fixed :px (double overscan)}
    (fn? overscan) {:mode :fn :fn overscan}
    (map? overscan)
    (if (contains? overscan :viewport)
      {:mode :viewport :frac (double (:viewport overscan))}
      (cond-> {:mode :dynamic}
        (:ahead overscan) (assoc :base-ahead (double (:ahead overscan)))
        (:behind overscan) (assoc :base-behind (double (:behind overscan)))
        (:max overscan) (assoc :max (double (:max overscan)))
        (:lookahead-ms overscan) (assoc :lookahead-ms (double (:lookahead-ms overscan)))
        (true? (:flying overscan)) (assoc :fly? true)))
    :else {:mode :dynamic}))

(defn overscan-window
  "Pure directional overscan resolver → [behind ahead] px. `spec` is a normalized
   resolve-overscan result (NOT the :fn form — the caller pre-resolves that).
   nil / :disabled ⇒ [0 0]. Velocity law (WS2.1 §2.2):
     lead   = clamp(base_ahead, |v|·lookahead/1000, ahead-max)
     ahead  = forward? lead : base_behind ;  behind = forward? base_behind : lead
   so the wide margin follows the motion sign; at rest (absv 0, any sign) it
   collapses to the small symmetric base. Fixed / viewport specs ignore velocity.
   `avg-main` seeds the zero-config base (one item); falls back to base-frac·vp. Pure."
  [spec ^double absv ^int sign ^double viewport ^double avg-main
   ^double lookahead-ms ^double ahead-max-frac ^double base-frac]
  (if (or (nil? spec) (:disabled spec))
    [0.0 0.0]
    (case (:mode spec)
      :fixed (let [^double p (double (:px spec))] [p p])
      :viewport (let [^double p (* (double (:frac spec)) viewport)] [p p])
      ;; :dynamic (and the zero-config default)
      (let [^double default-base (if (and (pos? avg-main) (.-isFinite avg-main))
                                   avg-main (* base-frac viewport))
            ^double base-ahead (double (:base-ahead spec default-base))
            ^double base-behind (double (:base-behind spec default-base))
            ^double ahead-max (double (:max spec (* ahead-max-frac viewport)))
            ^double lm (double (:lookahead-ms spec lookahead-ms))
            ^double lead (math/min ahead-max (math/max base-ahead (* absv (/ lm 1000.0))))
            fwd (>= sign 0)]
        [(if fwd base-behind lead)
         (if fwd lead base-behind)]))))

(defn- update-velocity!
  "Once-per-frame velocity sensor (WS2.1 §2.1), render-object-local. The delta is
   correction-compensated: `refineLastOffset` already carries the last pass's
   scrollOffset PLUS the correction that pass emitted, so a same-frame correction
   re-run and a WS1.3/WS2.3 reconciliation read as no user motion — only real
   drag/ballistic deltas survive. Folds the instantaneous velocity into the EMA,
   updates the hysteresis direction sign and the fidelity regime. Gated on the
   frame timestamp so the several layout passes a frame can hold don't decay it."
  [^CollectionRenderSliver rs ^r/SliverConstraints c]
  (let [^double stamp (double (.-inMicroseconds
                               ^dc/Duration (.-currentFrameTimeStamp w/WidgetsBinding.instance)))
        ^double last (.-lastVelStamp rs)
        ^double prev-off (.-refineLastOffset rs)
        ^double so (.-scrollOffset c)]
    (when (and (not (.-isNaN last)) (not (.-isNaN prev-off)) (> stamp last))
      (let [^double dt-micros (- stamp last)]
        (when (pos? dt-micros)
          (let [^double inst-v (frame-velocity prev-off so dt-micros)
                ^double prev-ema (.-velocityEMA rs)
                ^double old-abs (if (.-isNaN prev-ema) 0.0 (.abs prev-ema))
                ^double v-fast (double (:v-fast overscan-tunables))
                ;; teleport clamp + sustained fast-run gate: a far jumpTo (whole
                ;; delta in one frame) resets the sensor instead of folding, and
                ;; only frames whose INSTANTANEOUS sample is fast extend the run —
                ;; so neither a jump nor its EMA decay tail ever reads as a fling.
                folded (fold-velocity-sample prev-ema (.-flyingRun rs) inst-v
                                             (double (:ema-alpha overscan-tunables))
                                             v-fast
                                             (double (:teleport-v overscan-tunables)))
                ^double ema (double (:ema folded))
                ^double new-abs (.abs ema)
                decel? (< new-abs old-abs)
                ^int run (int (:run folded))]
            (.-flyingRun! rs run)
            (.-velocityEMA! rs ema)
            (.-scrollSign! rs (vel-sign (.-scrollSign rs) ema
                                        (double (:dir-flip-eps overscan-tunables))))
            (.-curRegime! rs (fidelity-regime (.-curRegime rs) new-abs decel? run
                                              (double (:v-slow overscan-tunables))
                                              v-fast
                                              (int (:min-fast-run overscan-tunables))))))))
    (.-lastVelStamp! rs stamp)))

(defn- overscan-extent
  "This frame's [behind ahead] overscan margins (px): [0 0] when the config is
   disabled, or on a pass that ACTUALLY flies (opted-in flying regime — the
   approximate path owns the window there). A fast fling that is NOT opted into
   flying keeps widening: real, measured cells stay materialised ahead of the
   viewport. Resolves the :fn form against the live sensor ctx, then applies the
   pure velocity law (overscan-window)."
  [^CollectionRenderSliver rs ^r/SliverConstraints c regime]
  (let [spec (.-overscanConfig rs)
        ^double viewport (.-viewportMainAxisExtent c)
        ^int sign (.-scrollSign rs)
        spec (if (and (map? spec) (= :fn (:mode spec)))
               (resolve-overscan ((:fn spec) {:velocity (.-velocityEMA rs) :direction sign
                                              :viewport viewport :item-count (.-itemCount rs)
                                              :cache-extent (.-remainingCacheExtent c)}))
               spec)]
    (if (or (nil? spec) (:disabled spec) (and (:fly? spec) (= :flying regime)))
      [0.0 0.0]
      (let [^double absv (.abs (.-velocityEMA rs))
            ^double avg-main (double (or (:avg-main (lay/make-env c (.-itemCount rs) (env-agg rs))) 0.0))]
        (overscan-window spec absv sign viewport avg-main
                         (double (:lookahead-ms overscan-tunables))
                         (double (:ahead-max-frac overscan-tunables))
                         (double (:base-frac overscan-tunables)))))))

;; --- keyed rect commit (v2 persistent {key -> content-space rect}) ---

(defn- key-for
  "Animation key of index `i`: the host's key-of closure, or the index itself
   when no key-of was supplied."
  [^CollectionRenderSliver rs ^int i]
  (if-let [kf (.-keyOf rs)] (kf i) i))

(defn- child-rect
  "Content-space rect {:offset :cross :main-extent :cross-extent} of an attached,
   sized child from its parentData offsets and measured size."
  [env ^r/RenderBox child]
  (let [^r/SliverGridParentData pd (.-parentData child)
        ^ui/Size size (.-size child)]
    {:offset (double (or (.-layoutOffset pd) 0.0))
     :cross (double (or (.-crossAxisOffset pd) 0.0))
     :main-extent (lay/size-main env size)
     :cross-extent (lay/size-cross env size)}))

(defn committed-rect
  "The content-space rect stored in `committed` for a laid child: its full laid
   `rect` (main/cross-extent = the laid size) with the collapse-axis VISIBLE
   window applied — from `clip` = [vis-main vis-cross], or nil when the child isn't
   clipped (resting / not collapsing, visible == full) — and the full laid extent
   kept as :full-main/:full-cross. Pure."
  [rect clip]
  (let [^double fm (double (:main-extent rect))
        ^double fc (double (:cross-extent rect))
        ^double vm (if clip (double (nth clip 0)) fm)
        ^double vc (if clip (double (nth clip 1)) fc)]
    (assoc rect :main-extent vm :cross-extent vc
                :full-main fm :full-cross fc)))

(defn prune-committed
  "Geometric committed-cache scoping (WS2 phase D): keeps entries whose content-
   space span [offset, offset + full-main) still overlaps the cache band
   [ws, we); an entry whose rect left the band is dropped. Replaces the 600-pass
   age prune — a key outside the band has NO committed entry, so a re-insert of
   a long-gone key structurally cannot animate from a stale offset: it takes the
   enter-wipe / edge-slide path (followups §2.1). The span uses :full-main (a
   mid-wipe cell still occupies its full extent — mirrors widen-window!),
   falling back to the visible :main-extent. An infinite band (the box host's
   whole-box universe) degrades to keep-all. Pure."
  [committed ^double ws ^double we]
  (reduce-kv (fn [m k v]
               (let [^double o (double (:offset v))
                     ^double fm (double (:full-main v (:main-extent v)))]
                 (if (and (< o we) (> (+ o fm) ws))
                   (assoc m k v)
                   m)))
             {} committed))

(defn commit-prune?
  "Phase D prune gate: the committed map is pruned geometrically only BETWEEN
   segments — never mid-segment, so active participants (entering/exiting/
   leaving keys and everything the segment's `from` capture references) survive
   until the segment ends — and only on a pass that emitted no
   scrollOffsetCorrection (offsets are mid-reconciliation then; the corrected
   re-run prunes with coherent coordinates). Pure."
  [^bool segment? ^bool corrected?]
  (and (not segment?) (not corrected?)))

(defn- commit-pass!
  "Upserts committed[key] = this pass's content-space rect for every attached,
   sized child — scrolled-off keys are kept while their rect stays inside the
   cache band [ws, we) — then, when `prune?` (see commit-prune?), prunes
   geometrically to that band. Runs once per performLayout, after the driver
   returns.

   A cell mid-wipe is laid at its FULL extent but painted clipped to a smaller
   VISIBLE window (recorded in `clips`, keyed by child index). The committed rect
   stores that VISIBLE extent on each axis (mirrors box.cljd's animate-pass!), so
   a retrigger continues the wipe from the current window instead of snapping to
   0/full, plus the FULL laid extent as :full-main/:full-cross so the exit wipe
   lays out at the stable size rather than the partial one. A child absent from
   `clips` (resting, or not collapsing) has visible == full on both axes."
  [^CollectionRenderSliver rs env ^double ws ^double we ^bool prune?]
  (let [clips (.-clips rs)
        m (loop [child (.-firstChild rs) m (.-committed rs)]
            (if child
              (let [^r/RenderBox ch child]
                (recur (.childAfter rs ch)
                       (if (.-hasSize ch)
                         (let [^int idx (.indexOf rs ch)]
                           (assoc m (key-for rs idx)
                                  (committed-rect (child-rect env ch)
                                                  (get clips idx))))
                         m)))
              m))]
    (.-committed! rs (if prune? (prune-committed m ws we) m))))

(defn committed-rects
  "Snapshot of committed — {key -> rect} content space, for the host to freeze
   as a segment's `from` side at (re)start. Each rect's :main-extent/
   :cross-extent are the VISIBLE window (partial mid-wipe); :full-main/
   :full-cross carry the stable full laid extent (see commit-pass!)."
  [^CollectionRenderSliver rs]
  (.-committed rs))

(defn widen-window-indices
  "Union windowing (pure): extend the target [first-index, target-last] window to
   keep any attached cell still overlapping [ws, we] under its last committed
   rect, so a cell leaving/entering under a new layout glides through instead of
   popping. `cells` are {:index :offset :main-extent}; `target-last` may be nil
   (unbounded trailing). Returns [first-index target-last]."
  [^int first-index target-last cells ^double ws ^double we]
  (reduce (fn [[^int fi tl] c]
            (let [^int ci (int (:index c))
                  ^double o (double (:offset c))
                  ^double m (double (:main-extent c))
                  overlaps (and (< o we) (> (+ o m) ws))]
              [(if (and overlaps (< ci fi)) ci fi)
               (if (and overlaps tl (> ci ^int tl)) ci tl)]))
          [first-index target-last] cells))

(defn- widen-window!
  "widen-window-indices over this sliver's attached children, keyed via key-of
   into the committed map for each child's last content-space rect. Exiting
   (data-removed) keys are skipped: they collapse in place at their in-window
   shadow slot (§7a) and must not pin the kept range when reindexing pushed
   their slot out of it."
  [^CollectionRenderSliver rs ^int first-index target-last ^double ws ^double we]
  (let [committed (.-committed rs)
        exiting (.-exiting rs)
        cells (loop [child (.-firstChild rs) out []]
                (if child
                  (let [^r/RenderBox ch child
                        k (key-for rs (.indexOf rs ch))
                        rect (when-not (contains? exiting k) (get committed k))]
                    (recur (.childAfter rs ch)
                           (if rect
                             ;; :full-main, not the (possibly partial) visible
                             ;; extent — a mid-wipe cell still occupies its full
                             ;; span for windowing, so it isn't dropped mid-glide.
                             (conj out {:index (.indexOf rs ch)
                                        :offset (:offset rect)
                                        :main-extent (:full-main rect (:main-extent rect))})
                             out)))
                  out))]
    (widen-window-indices first-index target-last cells ws we)))

(defn- set-tween-anim!
  "Moves the per-tick relayout listener onto `anim` (see an/swap-tick-listener!)."
  [^CollectionRenderSliver rs ^a/Animation? anim]
  (when-not (identical? anim (.-tweenAnim rs))
    (.-tweenListener! rs (an/swap-tick-listener! rs (.-tweenAnim rs)
                                                 (.-tweenListener rs) anim))
    (.-tweenAnim! rs anim)))

(defn next-prev-layout
  "prevLayout lifecycle (docs §7c) — the resting layout frozen across a layout
   change so segment-start! can give a viewport-arriving cell its OLD frame
   (`old-src`). Valid ONLY while a segment is pending: with no tween-anim no
   segment-start! will consume it, so drop it — left around it would feed a
   LATER data-only segment an old-src over a layout the cells stopped resting
   under N changes ago. While pending, a same-id rebuild before layout must NOT
   wipe it (a second rebuild racing performLayout was a real bug), hence `prev`
   is kept unless the :id changed."
  [prev old ^bool layout-changed ^bool tween-anim?]
  (cond
    (not tween-anim?) nil
    layout-changed old
    :else prev))

(defn update-render!
  "Applies a segment from updateRenderObject. The host passes the PLAIN target
   layout (never a pre-built tween), the segment `tween-anim`, an int `gen` bumped
   once per segment, the `entering`/`exiting` key sets and `key-of`. The engine
   builds the segment tween itself on the first pass whose `gen` differs from the
   one it last built for (see `segment-start!`); when `tween-anim` is nil the
   sliver rests on `target-layout` and all segment state is cleared. A changed
   layout :id invalidates the flow geometry cache."
  [^CollectionRenderSliver rs target-layout item-count ^a/Animation? tween-anim
   ^int gen entering exiting key-of ^bool fade-enter ^bool fade-exit dying-slots]
  (let [old (.-layoutModel rs)
        layout-changed (or (nil? (:id target-layout))
                           (not= (:id old) (:id target-layout)))
        count-changed (not= item-count (.-itemCount rs))
        seg-start (and tween-anim (not= gen (.-segGen rs)))]
    (when layout-changed
      (.-cache! rs [])
      (.-baseState! rs nil))
    ;; checkpoints invalidate in lockstep with the cache: a layout :id change
    ;; re-packs everything; a count change shifts offset prefix-sums (no diff index
    ;; available here → drop all, per docs §2.1). Both un-anchor the frontier.
    (when (or layout-changed count-changed)
      (.-checkpoints! rs {})
      (.-anchoredTo0! rs false)
      (.-landingEmitted! rs false)
      (.-pendingLandingWs! rs dc/double.nan))
    ;; a layout :id change invalidates the survivor's stale offset (it is in the OLD
    ;; layout's space) — flag the next seed-cache! to re-anchor at the NEW layout's
    ;; :approx-offset instead. A count change keeps the same layout space, so its
    ;; offsets stay valid — no cross-layout re-anchor there.
    (when layout-changed
      (.-crossLayoutReanchor! rs true))
    (.-prevLayout! rs (next-prev-layout (.-prevLayout rs) old
                                        (boolean layout-changed) (some? tween-anim)))
    ;; always swap the fns — same :id means same behavior, fresher closures
    (.-layoutModel! rs target-layout)
    (.-itemCount! rs item-count)
    (.-keyOf! rs key-of)
    (.-curGen! rs gen)
    (.-entering! rs (or entering #{}))
    (.-exiting! rs (or exiting #{}))
    (.-fadeEnter! rs (boolean fade-enter))
    (.-fadeExit! rs (boolean fade-exit))
    (.-dyingSlots! rs (or dying-slots []))
    (set-tween-anim! rs tween-anim)
    (when-not tween-anim  ;; back to resting — forget the segment
      (.-segGen! rs -1)
      (.-segTween! rs nil)
      (.-leaving! rs {}))
    (when (or layout-changed count-changed seg-start)
      (.markNeedsLayout rs))))

;; --- layout-morph snapshots (read by the host at tween start / retarget) ---

(defn snapshot-window
  "Frozen `from` endpoint: the exact on-screen frames of every attached child
   this frame, plus the current reported scroll extent. At tween start this is
   the outgoing layout; at retarget the children sit at interpolated positions,
   so the same read captures them mid-morph and the re-aim is jump-free.
   Returns {:frames :base :extent :env} — nil when nothing is attached."
  [^CollectionRenderSliver rs]
  (when-let [fc (.-firstChild rs)]
    (let [^r/SliverConstraints c (.-constraints rs)
          env (lay/make-env c (.-itemCount rs) (env-agg rs))]
      (loop [child fc frames [] base (.indexOf rs ^r/RenderBox fc)]
        (if child
          (let [^r/RenderBox ch child
                ^r/SliverGridParentData pd (.-parentData ch)]
            (if (.-hasSize ch)
              (let [^ui/Size size (.-size ch)
                    fr {:offset (double (or (.-layoutOffset pd) 0.0))
                        :cross (double (or (.-crossAxisOffset pd) 0.0))
                        :main-extent (lay/size-main env size)
                        :cross-extent (lay/size-cross env size)}]
                (recur (.childAfter rs ch) (conj frames fr) base))
              (recur (.childAfter rs ch) frames base)))
          (when (seq frames)
            {:frames frames :base (int base)
             :extent (let [^r/SliverGeometry g (.-geometry rs)]
                       (if g (.-scrollExtent g) (tw/frames-main-extent frames)))
             :env env}))))))

(defn project-flow-window
  "Frozen `to` endpoint for a FLOW target that can't be queried directly (e.g.
   grid→list): dry-measures each attached child under the target's :measure
   constraints — so sizes reflow for real — and runs its placement anchored at
   the window's top. Approximate in absolute offset, exact in the reflowed sizes.
   Returns {:frames :base :extent} — nil when nothing is attached."
  [^CollectionRenderSliver rs to-layout]
  (when-let [fc (.-firstChild rs)]
    (let [^r/SliverConstraints c (.-constraints rs)
          env (lay/make-env c (.-itemCount rs) (env-agg rs))
          env (if-let [prep (:prepare to-layout)] (assoc env :ctx (prep env)) env)
          measure-fn (:measure to-layout)
          ^int base (.indexOf rs ^r/RenderBox fc)
          ^double base-off (double (or (.childScrollOffset rs ^r/RenderBox fc) 0.0))
          sized (loop [child fc out []]
                  (if child
                    (let [^r/RenderBox ch child
                          i (.indexOf rs ch)
                          ^r/BoxConstraints bc (measure-fn env i)
                          ^ui/Size size (.getDryLayout ch bc)]
                      (recur (.childAfter rs ch) (conj out [i size])))
                    out))
          seed (tw/flow-seed-state to-layout env base base-off)
          frames (tw/flow-frames to-layout env sized seed)]
      {:frames frames :base base :extent (tw/frames-main-extent frames)})))

;; @ai-generated(solo)
(defn vacated-trailing-extent
  "Main-axis space the dying cells will vacate inside the band [ws, we) — the
   extra walk-ahead a remove-segment's flow capture needs. The capture walks the
   SHADOW band, in which dying cells still hold their full extent, so without
   this the pure-live `to` snapshot falls short of `we` by exactly this much and
   the replacements rising in from below are only materialized after the segment.

   `rects` are the dying slots' committed rects. Rects sharing one :offset are a
   wrap run dying together — the run vacates its height ONCE (the group's max
   :full-main), which for a list (distinct offsets) degrades to the plain sum.
   Ascending cascade: a rect beyond `we` but inside the band EXTENDED by the
   space vacated above it also counts. Rects wholly above `ws` contribute
   nothing — removals above the anchor are absorbed by the segment scroll
   correction, not the trailing backfill. Partially-dying runs over-count (upper
   bound): a few extra materialized cells, never a shortfall. Pure."
  [rects ^double ws ^double we]
  (let [groups (->> rects
                    (reduce (fn [m r]
                              (let [^double off (double (:offset r))
                                    ^double fm (double (or (:full-main r) (:main-extent r) 0.0))
                                    ^double cur (double (or (get m off) 0.0))]
                                (assoc m off (math/max cur fm))))
                            {})
                    (sort-by key))]
    (loop [gs (seq groups) ^double acc 0.0]
      (if gs
        (let [e (first gs)
              ^double off (key e)
              ^double fm (val e)]
          (recur (next gs)
                 (if (and (< off (+ we acc)) (> (+ off fm) ws))
                   (+ acc fm)
                   acc)))
        acc))))

(defn- live-only-flow-window
  "Frozen PURE-LIVE `to` endpoint for a FLOW remove segment — the flow analogue of
   an indexed source over pure-live indices. After `flow-layout!` has materialized
   and measured the shadow window (survivors at natural size, inserts at target),
   walk the attached children, DROP the ones whose key is `exiting`, REINDEX the
   survivors to contiguous pure-live indices (base = count of live entries before
   the window top), and RE-PLACE them via `flow-frames` seeded at the live base —
   a real re-flow so the gap each dying cell leaves closes and survivors below it
   glide up (offset-subtraction would be wrong for wrap/masonry). Returns the
   {:frames :base :extent} shape `frozen-frame-source` consumes, addressed by
   pure-live index (what `shadow-frame-source` remaps shadow indices into).

   Extent excludes the dying cells' main-extents (subtracted from the shadow scroll
   extent) so `keyed-tween-layout`'s max-extent lerp lands on the true pure-live
   total — no end-of-segment snap. Guards all-attached-dying (empty survivors →
   empty frames, gap frames fall back to extent)."
  [^CollectionRenderSliver rs to-layout ^r/SliverConstraints c]
  (let [env (lay/make-env c (.-itemCount rs) (env-agg rs))
        env (if-let [prep (:prepare to-layout)] (assoc env :ctx (prep env)) env)
        exiting (.-exiting rs)
        exiting-key? (fn [^int i] (contains? exiting (key-for rs i)))
        ;; Only the cache-backed (just-walked) window feeds the re-flow: kept
        ;; out-of-window leave-slides (§7b) still sit attached beyond it with
        ;; STALE sizes and would corrupt the contiguous reindex.
        ^int cf (.-cacheFirst rs)
        ^int clen (count (.-cache rs))
        walked? (fn [^int i] (and (>= i cf) (< (- i cf) clen)))
        [survivors first-off ^double dying-ext]
        (loop [child (.-firstChild rs) surv [] first-off nil ^double dext 0.0]
          (if child
            (let [^r/RenderBox ch child ^int i (.indexOf rs ch)]
              (if (and (.-hasSize ch) (walked? i))
                (if (exiting-key? i)
                  (recur (.childAfter rs ch) surv first-off
                         (+ dext (lay/size-main env (.-size ch))))
                  (recur (.childAfter rs ch) (conj surv [i (.-size ch)])
                         (or first-off (.childScrollOffset rs ch)) dext))
                (recur (.childAfter rs ch) surv first-off dext)))
            [surv first-off dext]))
        ^double shadow-ext (if-let [^r/SliverGeometry g (.-geometry rs)]
                             (.-scrollExtent g) 0.0)
        ^double live-ext (math/max 0.0 (- shadow-ext dying-ext))]
    (if (empty? survivors)
      {:frames [] :base 0 :extent live-ext}
      (let [^int first-shadow (first (first survivors))
            ^int base (loop [^int j 0 ^int cnt 0]
                        (if (< j first-shadow)
                          (recur (inc j) (if (exiting-key? j) cnt (inc cnt)))
                          cnt))
            ^double base-off (double (or first-off 0.0))
            sized (map-indexed (fn [^int k [_ ^ui/Size size]] [(+ base k) size]) survivors)
            seed (tw/flow-seed-state to-layout env base base-off)
            frames (tw/flow-frames to-layout env sized seed)]
        {:frames frames :base base
         :extent (math/max (tw/frames-main-extent frames) live-ext)}))))

;; --- shared helpers ---

(defn- ^int count-attached [^CollectionRenderSliver rs]
  (loop [c (.-firstChild rs) n 0]
    (if c (recur (.childAfter rs ^r/RenderBox c) (inc n)) n)))

(defn- bsearch-max-end
  "Index of the first cache entry whose :max-end exceeds `off` (count when none)."
  ^int [cache ^double off]
  (loop [^int lo 0 ^int hi (count cache)]
    (if (< lo hi)
      (let [^int mid (bit-shift-right (+ lo hi) 1)]
        (if (> ^double (:max-end (nth cache mid)) off)
          (recur lo mid)
          (recur (inc mid) hi)))
      lo)))

;; @ai-generated(guided)
(defn trim-front
  "Front-trims the flow geometry cache to the leading band edge `ws` (Row 3 memory
   bound). Returns [trimmed-cache new-cache-first new-base-state], or nil when
   nothing is trimmable.

   `bsearch-max-end` gives `t` = the first entry whose running :max-end reaches
   into the band (> ws); entries [0, t) are therefore FULLY above the band (their
   furthest edge <= ws) and are dropped. The new baseState is the exact flow state
   stored on the last dropped entry (cache[t-1].:state = state AFTER the new head's
   predecessor = state BEFORE the new head), so the retained head resumes an exact
   chain with no re-walk.

   The retained head's :max-end already equals its own :end — it dominates every
   dropped entry (all ending <= ws < its own end) — so the running-max invariant
   survives the cut with NO rebaseline; downstream bsearch-max-end stays sound.

   A FRESH vector is realized (into [], not a subvec view) so the O(N) dropped
   prefix is actually released to GC — the whole point of the bound. The copy is
   O((count cache) − t) = O(band entries), which also bounds walk!'s mismatch
   truncation `(subvec cache 0 rel)` (rel <= count) at O(band) — Row 4. No-op (nil)
   when t==0 (nothing above the band) or t==count (keep the last entry). Pure."
  [cache ^int cache-first ^double ws]
  (let [^int t (bsearch-max-end cache ws)]
    (when (and (pos? t) (< t (count cache)))
      [(into [] (subvec cache t))
       (+ cache-first t)
       (:state (nth cache (dec t)))])))

;; ============================================================
;; Flow driver
;; ============================================================

(defn- pre-gc!
  "Collects attached children clearly outside [ws, we) using last-frame
   offsets and cached extents (child sizes may not be read before this
   frame's layout). Children never laid out (no offset) count as leading."
  [^CollectionRenderSliver rs ^double ws ^double we]
  (when (.-firstChild rs)
    (let [^int total (count-attached rs)
          cache (.-cache rs)
          ^int cf (.-cacheFirst rs)
          ^int leading
          (loop [c (.-firstChild rs) ^int n 0]
            (if (and c
                     (let [off (.childScrollOffset rs ^r/RenderBox c)
                           rel (- (.indexOf rs ^r/RenderBox c) cf)
                           e (when (and (>= rel 0) (< rel (count cache)))
                               (nth cache rel))]
                       (or (nil? off)
                           (and e (<= ^double (:end e) ws)))))
              (recur (.childAfter rs ^r/RenderBox c) (inc n))
              n))
          ^int trailing
          (loop [c (.-lastChild rs) ^int n 0]
            (if (and c
                     (let [off (.childScrollOffset rs ^r/RenderBox c)]
                       (and (some? off) (>= ^double off we))))
              (recur (.childBefore rs ^r/RenderBox c) (inc n))
              n))
          ^int trailing (math/max 0 (math/min trailing (- total leading)))]
      (.collectGarbage rs leading trailing))))

(defn reanchor-offset
  "Offset to re-anchor a lost-cache survivor at index `idx`. `stale-off` is its
   last layoutOffset — coordinate-valid only WITHIN the layout it was placed
   under. After a layout :id change (`cross-layout?`) that offset lives in the OLD
   layout's space; the NEW layout's leading geometry above `idx` can be much
   taller (list vs. a packed wrap) or shorter, so keeping the stale offset strands
   the leading region — there aren't enough px between 0 and stale-off to fit
   `idx` new-layout runs, so backfill can never walk up to index 0 and the deep
   survivor pins at offset 0 (the \"no elements above #1700, clamps at 0\" defect).
   Re-anchor instead at the new layout's O(1) estimate `approx-off` so the leading
   extent matches the new layout and index 0 stays reachable; the caller emits the
   (approx-off − stale-off) shift as a scrollOffsetCorrection to hold the visible
   child still while the indicator jumps to the honest-approximate estimate.
   Same-layout losses (keyed reconcile) keep the stale offset — no visible jump.
   Falls back to stale-off at the top (idx 0) or when no positive estimate exists.
   Pure."
  [^bool cross-layout? ^int idx ^double stale-off approx-off]
  (if (and cross-layout? (pos? idx) approx-off (pos? (double approx-off)))
    (double approx-off)
    stale-off))

(defn reanchor-band
  "The band a flow pass materializes/GCs/prunes against, [ws we] shifted by a
   recorded cross-layout re-anchor. seed-cache!'s re-anchor rebased the walked
   frame by `rsh` = approx − stale (NaN = none this pass), and the emitted
   scrollOffsetCorrection (or the segment set-point) lands the NEXT window
   exactly there — so this pass must fill the SHIFTED band. Filling the OLD one
   made backfill-leading! walk the whole [old-ws, new-head) gap one leading
   child at a time, O(gap) materialisations in one frame (the first wrap→list
   morph freeze); the shift keeps per-pass work O(window+overscan) regardless
   of the rebase distance — the corrected re-run absorbs the coordinate jump.
   Pure."
  [^double ws ^double we ^double rsh]
  (if (.-isNaN rsh) [ws we] [(+ ws rsh) (+ we rsh)]))

(defn window-far-from-band?
  "Geometric seeding decision — the cache is an accelerator, never the algorithm:
   per-pass work must stay O(window+overscan) regardless of cache contents. True
   when the known band [cache[0].offset, last :max-end) lies MORE THAN ONE window
   extent away from the window [ws, we): re-attaching at the band and walking the
   gap would materialize O(gap) children in one frame (the first-far-jump freeze),
   so the caller must drop the stale band and inverse-seed near the window — the
   same O(window) path as a cold deep start. An intersecting or nearby band
   (gap <= one window extent) keeps the walk: that is normal scrolling, bounded
   by O(window), and preserves the exact frontier. Pure."
  [cache ^double ws ^double we]
  (boolean
   (when (seq cache)
     (let [^double head (double (:offset (nth cache 0)))
           ^double tail (double (:max-end (peek cache)))
           ^double w (- we ws)]
       (or (> (- ws tail) w)        ;; band far above the window (jumped down)
           (> (- head we) w))))))   ;; band far below the window (jumped up)

(defn- inverse-seed!
  "O(1) deep-window seed: inverts the monotone :approx-offset at `ws` to pick the
   start index and re-anchors the (emptied) cache there; align-start! attaches and
   walk! places forward from baseState, so the pass costs O(window), not O(gap).
   Checkpoints drop in lockstep — a stale checkpoint far below the new frontier
   would make the next reflow-from-checkpoint! insert O(gap) leading children in
   ONE step; with none stored, upward backfill re-seeds via the renewal-point path
   (synth-renewal-checkpoint), whole runs, band-bounded. anchoredTo0 := false —
   offsets are estimates until refined. Returns false WITHOUT touching state when
   the estimate cannot place the window. Returns:
     :seeded     — re-anchored near the window (estimates until refined).
     :at-top     — the inversion put the window inside index 0's span: the exact
                   from-0 seed is the right (and O(window)) move; caller seeds it.
     :degenerate — the estimate's density never reaches the window (an unseeded
                   density saturates at the last index at offset ≪ ws); state
                   untouched, the caller keeps its previous frontier."
  [^CollectionRenderSliver rs layout env ^double ws]
  (let [approx-fn (:approx-offset layout)
        anchor-fn (:anchor layout)
        ^int raw (invert-approx-offset (fn [^int i] (approx-fn env i))
                                       ws (.-itemCount rs))
        ^int n (int (or (.-itemCount rs) 0))
        ^int start (if (pos? n) (math/max 0 (math/min raw (dec n))) (math/max 0 raw))
        ^double off-start (double (approx-fn env start))]
    (cond
      (and (pos? start) (>= off-start (* 0.5 ws)))
      (do (.-cache! rs [])
          (.-checkpoints! rs {})
          (.-cacheFirst! rs start)
          (.-baseState! rs (if anchor-fn
                             (anchor-fn env start off-start)
                             ((:init layout) env)))
          (.-anchoredTo0! rs false)
          (.-crossLayoutReanchor! rs false)
          :seeded)
      (zero? start) :at-top
      :else :degenerate)))

(defn- seed-at-0!
  "Exact from-0 seed: drops the band + checkpoints and re-flows from :init.
   O(window) when the window is at the scroll top."
  [^CollectionRenderSliver rs layout env]
  (.-cache! rs [])
  (.-checkpoints! rs {})
  (.-cacheFirst! rs 0)
  (.-baseState! rs ((:init layout) env))
  (.-anchoredTo0! rs true)
  (.-crossLayoutReanchor! rs false))

(defn- seed-cache!
  "Re-anchors the geometry cache when it cannot serve this pass's window. Two
   triggers:
   - FAR WINDOW (geometry, not emptiness): nothing attached (pre-gc! detached
     the whole stale band) and the window sits more than one window extent from
     the known band (window-far-from-band?). trim-front! always keeps >= 1 cache
     entry, so gating the inverse seed on emptiness left it unreachable after any
     initial layout — a far jump then walked the gap from the stale band, O(gap)
     in one frame. Geometry now selects the seed regardless of cache contents:
     the inverse seed for a deep window, the exact from-0 seed for a jump to the
     scroll top (backfill would otherwise walk the whole gap down to 0).
   - EMPTY cache (cold start / invalidation): on a cold deep start take the same
     inverse seed; otherwise anchor at the first attached child's last-frame
     offset (dead reckoning via :anchor) or at index 0."
  [^CollectionRenderSliver rs layout env]
  (let [init-fn (:init layout)
        anchor-fn (:anchor layout)
        approx-fn (:approx-offset layout)
        ^r/SliverConstraints c (:constraints env)
        ^double ws (+ (.-scrollOffset c) (.-cacheOrigin c))
        ^double we (+ ws (.-remainingCacheExtent c))
        fc (.-firstChild rs)
        ;; deep window with nothing attached and an invertible estimate — the
        ;; cold-start precondition for the O(1) inverse seed
        deep? (boolean (and (nil? fc) approx-fn (> ws 0.5)))]
    (cond
      ;; FAR JUMP over a live band: seed by geometry.
      (and (nil? fc) (seq (.-cache rs)) (window-far-from-band? (.-cache rs) ws we))
      (cond
        ;; jumped to the scroll top: the exact from-0 seed IS O(window) there;
        ;; keeping the deep band would make backfill walk the whole gap to 0.
        (<= ws 0.5) (seed-at-0! rs layout env)
        approx-fn (case (inverse-seed! rs layout env ws)
                    :at-top (seed-at-0! rs layout env)
                    ;; :degenerate keeps the band (walking the gap is the best
                    ;; available move — and a live band implies a measured
                    ;; density, so this practically cannot occur); :seeded done.
                    nil)
        ;; no :approx-offset — the window can't be placed O(1); keep the band
        :else nil)

      (seq (.-cache rs)) nil   ;; band serves the window — nothing to re-seed

      :else
      (let [idx (if fc (.indexOf rs ^r/RenderBox fc) 0)
            ;; consumed once: the survivor's stale offset is cross-layout (see
            ;; reanchor-offset) only on the first seed after a layout :id change.
            cross-layout? (.-crossLayoutReanchor rs)
            ;; consumed once: an exact-landing emission last pass requires THIS
            ;; pass to re-flow from :init (landing-reseed-decision) — the
            ;; dead-reckon below would rebuild the stale frame and re-derive
            ;; the same landing residual forever.
            reseed (landing-reseed-decision (.-pendingLandingWs rs) ws
                                            (.-remainingPaintExtent c))]
        (.-crossLayoutReanchor! rs false)
        (when-not (= :none reseed)
          (.-pendingLandingWs! rs dc/double.nan))
        (when (= :abandon reseed)
          ;; frame aborted between emission and re-run, window moved: the
          ;; "fresh from-:init re-flow" premise behind the :violated one-shot
          ;; is gone — disarm it so an honest later landing can emit again.
          (.-landingEmitted! rs false))
        (cond
          ;; PENDING LANDING: the previous pass emitted the exact-landing
          ;; correction and dropped cache+checkpoints; the corrected re-run
          ;; re-flows from :init so index 0 lands at 0 and the residual is
          ;; absorbed (landing-decision :converged) instead of re-derived.
          (= :init-seed reseed)
          (do (.-cacheFirst! rs 0)
              (.-baseState! rs (init-fn env))
              (.-anchoredTo0! rs false))

          ;; COLD DEEP START: nothing attached and the window sits far down.
          ;; Inverse-seed instead of walking O(n) from 0; a degenerate estimate
          ;; falls back to the from-0 walk (nothing better exists yet).
          deep?
          (when-not (= :seeded (inverse-seed! rs layout env ws))
            (.-cacheFirst! rs 0)
            (.-baseState! rs (init-fn env))
            (.-anchoredTo0! rs true))

          (or (nil? fc) (zero? ^int idx))
          (do (.-cacheFirst! rs 0)
              (.-baseState! rs (init-fn env))
              (.-anchoredTo0! rs true))

          (some? anchor-fn)
          (let [^double stale (double (or (.childScrollOffset rs ^r/RenderBox fc) 0.0))
                approx-off (when (and cross-layout? approx-fn (pos? ^int idx))
                             (double (approx-fn env idx)))
                ^double off (reanchor-offset (boolean cross-layout?) (int idx) stale approx-off)]
            ;; a cross-layout re-anchor moved the survivor to the new-layout estimate;
            ;; record the shift so flow-layout! emits it as a scrollOffsetCorrection
            ;; and the visible child holds still (no jump) as the indicator updates.
            (when (not= off stale)
              (.-reanchorShift! rs (- off stale)))
            (.-cacheFirst! rs idx)
            (.-baseState! rs (anchor-fn env idx off))
            ;; dead-reckoned re-anchor above 0 — offsets are estimates again; a
            ;; surviving anchoredTo0 here would be a stale truth claim (Phase D).
            (.-anchoredTo0! rs false))

          ;; no :anchor — can't dead-reckon; drop children and re-flow from 0
          :else
          (do (.collectGarbage rs (count-attached rs) 0)
              (.-cacheFirst! rs 0)
              (.-baseState! rs (init-fn env))
              (.-anchoredTo0! rs true)))))))

(defn- normalize-cache!
  "Keyed reconciliation may remap attached child indices arbitrarily between
   frames; when firstChild no longer falls inside the cached prefix, drop the
   cache and re-anchor at its stale offset. Keeps the walk invariant
   0 <= firstChild-rel <= (count cache)."
  [^CollectionRenderSliver rs layout env]
  (when-let [fc (.-firstChild rs)]
    (let [rel (- (.indexOf rs ^r/RenderBox fc) (.-cacheFirst rs))]
      (when (or (neg? rel) (> rel (count (.-cache rs))))
        (.-cache! rs [])
        (seed-cache! rs layout env)))))

(defn- state-before
  "Flow state after children 0..i-1."
  [^CollectionRenderSliver rs layout env ^int i]
  (let [rel (- i (.-cacheFirst rs))
        cache (.-cache rs)]
    (cond
      (<= rel 0) (.-baseState rs)
      (<= rel (count cache)) (:state (nth cache (dec rel)))
      ;; unforeseen gap — dead-reckon rather than crash; the dead-reckoned state
      ;; breaks the "unbroken cache from 0" claim, so degrade the frontier.
      :else
      (let [off (or (some->> (.-firstChild rs) (.childScrollOffset rs)) 0.0)]
        (.-anchoredTo0! rs false)
        (if-let [anchor-fn (:anchor layout)]
          (anchor-fn env i (double off))
          ((:init layout) env))))))

(defn- align-start!
  "Ensures firstChild exists and starts at (or before) the first index whose
   cached max-end reaches into the window. Returns false when the collection
   is empty."
  [^CollectionRenderSliver rs layout env ^double ws]
  (let [cache (.-cache rs)
        ^int cf (.-cacheFirst rs)
        ^int start-rel (bsearch-max-end cache ws)
        ^int attach-idx (+ cf (math/min start-rel (count cache)))
        measure-fn (:measure layout)]
    (if (nil? (.-firstChild rs))
      (let [^double attach-off (cond
                                 (< start-rel (count cache)) (double (:offset (nth cache start-rel)))
                                 (pos? (count cache)) (double (:end (peek cache)))
                                 :else 0.0)]
        (if (.addInitialChild rs .index attach-idx .layoutOffset attach-off)
          true
          ;; nothing at attach-idx — the collection shrank; restart at 0
          (if (pos? attach-idx)
            (do (.-cache! rs [])
                (.-cacheFirst! rs 0)
                (.-baseState! rs ((:init layout) env))
                (.addInitialChild rs .index 0 .layoutOffset 0.0))
            false)))
      (loop []
        (let [^int fidx (.indexOf rs (.-firstChild rs))]
          (if (> fidx attach-idx)
            (if-let [c (.insertAndLayoutLeadingChild rs
                        ^r/BoxConstraints (measure-fn env (dec fidx))
                        .parentUsesSize true)]
              ;; placeholder offsets; the walk overwrites them from the cache
              (do (.-passMaterialized! rs (inc (.-passMaterialized rs)))
                  (set-layout-offset! c 0.0)
                  (set-cross-axis-offset! c 0.0)
                  (recur))
              true)
            true))))))

(defn- record-checkpoint!
  "Retains index `i` in the checkpoint store as a backward-re-flow seed when it
   begins a fresh run (:renewal-point?), or — for a layout without the hook
   (masonry) — at a periodic stride. `state` is the flow state BEFORE `i` (the
   seed for a forward re-walk from it); `off`/`cross` are i's just-placed frame."
  [^CollectionRenderSliver rs layout env ^int i ^double off ^double cross state]
  (let [rp (:renewal-point? layout)]
    (when (if rp
            (boolean (rp env i {:offset off :cross cross}))
            (zero? (mod i checkpoint-stride)))
      (.-checkpoints! rs (cp-record (.-checkpoints rs) i off state)))))

(defn- walk!
  "Lays out children forward from firstChild until the window is filled or
   children run out. Cache entries whose measured extent matches are reused;
   the first mismatch truncates the cache (and checkpoints at/below it) and
   re-places from there. Records renewal-point/stride checkpoints as it walks.
   Returns {:last-i int :end double :reached bool}."
  [^CollectionRenderSliver rs layout env ^double we]
  (let [measure-fn (:measure layout)
        place-fn (:place layout)
        flow-end-fn (:flow-end layout)]
    (loop [^r/RenderBox child (.-firstChild rs)
           ^int i (.indexOf rs (.-firstChild rs))
           state (state-before rs layout env i)]
      (let [^r/BoxConstraints cs (measure-fn env i)]
        (.layout child cs .parentUsesSize true)
        (.-passMaterialized! rs (inc (.-passMaterialized rs)))
        (let [^double ext (.paintExtentOf rs child)
              ^int rel (- i (.-cacheFirst rs))
              cache (.-cache rs)
              entry (when (and (>= rel 0) (< rel (count cache))) (nth cache rel))
              reuse (boolean (and entry
                                  (< (.abs (- ^double (:extent entry) ext)) 0.01)))
              [^double off ^double cross next-state ^double max-end]
              (if reuse
                [(double (:offset entry)) (double (:cross entry))
                 (:state entry) (double (:max-end entry))]
                (do
                  (when entry
                    ;; measured-size mismatch at i: truncate the cache AND drop
                    ;; checkpoints with index >= i — their offset prefix-sums shifted.
                    (.-cache! rs (into [] (subvec cache 0 rel)))
                    (.-checkpoints! rs (cp-drop-from (.-checkpoints rs) i))
                    (.-anchoredTo0! rs false))
                  (let [[gm st] (place-fn env i (.-size child) state)
                        ^double off (double (:offset gm))
                        ^double cross (double (or (:cross gm) 0.0))
                        ^double end (+ off ext)
                        cache' (.-cache rs)
                        ^double mx (if (pos? rel)
                                     (math/max ^double (:max-end (nth cache' (dec rel))) end)
                                     end)]
                    (.-cache! rs (conj cache'
                                       {:offset off :cross cross :extent ext
                                        :end end :max-end mx :state st :canon true}))
                    [off cross st mx])))]
          (set-layout-offset! child off)
          (set-cross-axis-offset! child cross)
          ;; `state` is the flow state BEFORE i — the exact seed to store.
          (record-checkpoint! rs layout env i off cross state)
          (let [^double fe (if flow-end-fn
                             (double (flow-end-fn env next-state))
                             max-end)]
            (if (>= fe we)
              {:last-i i :end max-end :reached false}
              (let [after (.childAfter rs child)
                    nxt (if (and after (= (.indexOf rs ^r/RenderBox after) (inc i)))
                          after
                          (.insertAndLayoutChild rs
                           ^r/BoxConstraints (measure-fn env (inc i))
                           .after child .parentUsesSize true))]
                (if (nil? nxt)
                  {:last-i i :end max-end :reached true}
                  (recur ^r/RenderBox nxt (inc i) next-state))))))))))

(defn- post-gc!
  "Collects walked children that ended before the window and any attached
   children beyond the last walked index, keeping at least one child."
  [^CollectionRenderSliver rs ^int last-i ^double ws]
  (let [^int total (count-attached rs)
        ^int trailing
        (loop [c (.-lastChild rs) ^int n 0]
          (if (and c (> (.indexOf rs ^r/RenderBox c) last-i))
            (recur (.childBefore rs ^r/RenderBox c) (inc n))
            n))
        cache (.-cache rs)
        ^int cf (.-cacheFirst rs)
        ^int leading
        (loop [c (.-firstChild rs) ^int n 0]
          (if (and c (<= (.indexOf rs ^r/RenderBox c) last-i))
            (let [rel (- (.indexOf rs ^r/RenderBox c) cf)
                  e (when (and (>= rel 0) (< rel (count cache))) (nth cache rel))]
              (if (and e (<= ^double (:end e) ws))
                (recur (.childAfter rs ^r/RenderBox c) (inc n))
                n))
            n))
        ^int leading (math/max 0 (math/min leading (- total trailing 1)))]
    (.collectGarbage rs leading trailing)))

(defn- update-measured-agg!
  "Refreshes the :avg-main/:avg-cross measured aggregates from the attached
   window (design §1.1) so :approx-offset / extent extrapolation track measured
   reality instead of the cold approximate-item-size prior. Returns this pass's
   RAW sample means {:avg-main :avg-cross} (nil when nothing is sized) — the
   materialization tripwire reads them instead of the EMA (see tripwire-env)."
  [^CollectionRenderSliver rs env]
  (loop [child (.-firstChild rs) ^double sm 0.0 ^double sc 0.0 ^int n 0]
    (if child
      (let [^r/RenderBox ch child]
        (if (.-hasSize ch)
          (recur (.childAfter rs ch)
                 (+ sm (lay/size-main env (.-size ch)))
                 (+ sc (lay/size-cross env (.-size ch)))
                 (inc n))
          (recur (.childAfter rs ch) sm sc n)))
      (when (pos? n)
        (let [^double mm (/ sm n) ^double mc (/ sc n)]
          (.-measuredAgg! rs (ema-agg (.-measuredAgg rs) mm mc))
          {:avg-main mm :avg-cross mc})))))

(defn- shift-attached-from!
  "Adds `d` to the layoutOffset of every attached child with index >= `from-idx`
   — the estimated content below a reconciled seam rides the same shift as the
   scrollOffset correction, keeping the intermediate state coherent until the
   corrected re-run re-walks it from the exact prefix state."
  [^CollectionRenderSliver rs ^int from-idx ^double d]
  (loop [child (.-firstChild rs)]
    (when child
      (let [^r/RenderBox ch child]
        (when (>= (.indexOf rs ch) from-idx)
          (when-let [off (.childScrollOffset rs ch)]
            (set-layout-offset! ch (+ (double off) d))))
        (recur (.childAfter rs ch))))))

(defn- reflow-from-checkpoint!
  "One backward re-flow step (WS2.2 §2.2). Seeds at checkpoint `cp` (index k <=
   cf-1), materialises [k .. cf-1] as leading children and places them FORWARD via
   the checkpoint's exact flow state — real :cross and real per-run :offset, not
   the one-child-per-slot estimate — then stitches the produced entries onto the
   cache and lowers cacheFirst to the reached top. Re-records renewal-point
   checkpoints for the re-flowed runs.

   Phase C seam reconciliation: when the re-flow says the cache head really sits
   `d` away from where the estimated cache placed it (refine-seam-delta):
   - `emit?` (resting, unsuppressed): trust the re-flowed truth — drop the
     stale-coordinate entries below the seam, shift their attached children by
     `d`, and return `d` as this step's refinement correction; backfill-leading!
     folds it into the pass's summed correction and keeps walking in the shifted
     frame, and the single corrected re-run re-walks the window forward from the
     exact prefix state, pixel-stable.
   - otherwise (suppressed / mid-segment — the offset model is frozen): re-anchor
     the prefix AT THE SEAM via :anchor(lo, first-offset − d). Structure stays
     exact (lo is a renewal point); the absolute displacement stays latent above,
     reconciled by a later resting pass or the exact landing at 0.

   Returns nil (no leading child available — caller stops), true (stepped,
   caller continues), or a double (correction emitted — caller returns it)."
  [^CollectionRenderSliver rs layout env cp ^bool emit?]
  (let [measure-fn (:measure layout)
        ^int cf (.-cacheFirst rs)
        ^int k (int (:index cp))
        seed-state (:state cp)
        ;; insert cf-1, cf-2, …, k as leading children (each prepends before firstChild)
        inserted (loop [^int i (dec cf) acc (transient {})]
                   (if (>= i k)
                     (if-let [c (.insertAndLayoutLeadingChild rs
                                 ^r/BoxConstraints (measure-fn env i)
                                 .parentUsesSize true)]
                       (recur (dec i) (assoc! acc i c))
                       (persistent! acc))
                     (persistent! acc)))]
    (.-passMaterialized! rs (+ (.-passMaterialized rs) (count inserted)))
    (if (empty? inserted)
      nil
      ;; lowest contiguous index we actually materialised (usually k)
      (let [^int lo (loop [^int i (dec cf)]
                      (if (and (>= i k) (contains? inserted i)) (recur (dec i)) (inc i)))
            use-seed (if (= lo k)
                       seed-state
                       ;; ran out before the checkpoint — dead-reckon the seed at lo
                       ;; (approximate; the child manager normally reaches k)
                       (if-let [anchor-fn (:anchor layout)]
                         (anchor-fn env lo (double (or (.childScrollOffset rs ^r/RenderBox (get inserted lo)) 0.0)))
                         ((:init layout) env)))
            sized (mapv (fn [^int i]
                          (let [^r/RenderBox c (get inserted i)]
                            [i (.-size c) (.paintExtentOf rs c)]))
                        (range lo cf))
            entries (tw/flow-run-entries layout env sized use-seed)
            ;; seam: where does the re-flow say the head (index cf) really sits?
            head-child (some->> ^r/RenderBox (get inserted (dec cf)) (.childAfter rs))
            ^double old-head (double (:offset (nth (.-cache rs) 0)))
            ^double d (if (and head-child
                               (= cf (.indexOf rs ^r/RenderBox head-child))
                               (.-hasSize ^r/RenderBox head-child))
                        (refine-seam-delta layout env cf (.-size ^r/RenderBox head-child)
                                           (:state (peek entries)) old-head)
                        0.0)
            [entries use-seed ^double d]
            (cond
              (or (zero? d) emit?) [entries use-seed d]
              (:anchor layout)
              (let [seed' ((:anchor layout) env lo (- (double (:offset (nth entries 0))) d))]
                [(tw/flow-run-entries layout env sized seed') seed' 0.0])
              ;; no :anchor to re-anchor with while frozen — keep the stale seam
              ;; (Phase B behavior) rather than emit outside the gate.
              :else [entries use-seed 0.0])]
        (dotimes [j (count entries)]
          (let [^int i (+ lo j)
                e (nth entries j)
                ^r/RenderBox c (get inserted i)
                ^double off (double (:offset e))
                ^double cross (double (:cross e))
                state-before (if (zero? j) use-seed (:state (nth entries (dec j))))]
            (set-layout-offset! c off)
            (set-cross-axis-offset! c cross)
            (record-checkpoint! rs layout env i off cross state-before)))
        (if (zero? d)
          (do (.-cache! rs (stitch-prefix entries (.-cache rs)))
              (.-cacheFirst! rs lo)
              (.-baseState! rs use-seed)
              true)
          (do (shift-attached-from! rs cf d)
              (.-cache! rs (vec entries))
              (.-cacheFirst! rs lo)
              (.-baseState! rs use-seed)
              d))))))

(defn leading-step-entry
  "Canonical single-child leading dead-reckon used by estimate-leading-step! when
   NO checkpoint covers the region above the cache. Places index `i` (= cf-1) as an
   independent run through the layout's :anchor + :place, so its :cross and the
   inter-run MAIN gap are the layout's own — list's :spacing, wrap's :run-spacing —
   NOT the old size-only `head - ext` pack that dropped the gap and let walk!'s
   extent-only reuse leak a no-spacing offset into the visible window (the
   wrap→jump→list no-spacing bug). `head` is cache[0]'s offset (index cf), `size`/
   `ext` the measured Size and main paint extent of i, `head-max-end` cache[0]'s
   :max-end. The absolute base stays approximate (a lone off-screen child can't know
   its run) but the geometry SHAPE is canonical — spacing/cross via :place. Returns
   the cache entry plus :base-state (the flow state BEFORE i, for the new baseState).
   Pure.

   Invariant (user directive): estimates may decide WHERE the window starts and shape
   the extents OUTSIDE it, but the cells INSIDE the materialized window are ALWAYS
   placed by the one canonical flow walk (:anchor-seeded state + :place per child)."
  [layout env ^int i ^double head size ^double ext ^double head-max-end]
  (let [place-fn (:place layout)
        anchor-fn (:anchor layout)
        init-fn (:init layout)
        flow-end-fn (:flow-end layout)
        ;; seed i as a fresh run whose children 0..i-1 ended at `head`, place it,
        ;; and read how far MAIN advances to the next index — list: ext + :spacing;
        ;; wrap/masonry: same-run advance is 0 on main, so fall back to run height.
        seed (if anchor-fn (anchor-fn env i head) (init-fn env))
        [gm st'] (place-fn env i size seed)
        ^double adv (if flow-end-fn
                      (math/max ext (- (double (flow-end-fn env st')) head))
                      ext)
        ^double noff (- head adv)
        ^double cross (double (or (:cross gm) 0.0))
        ^double end (+ noff ext)]
    {:offset noff :cross cross :extent ext :end end
     :max-end (math/min end head-max-end)
     ;; :state = flow state AFTER i (before cf): reconstructs placing cf back at head
     :state (if anchor-fn (anchor-fn env (inc i) head) (init-fn env))
     :base-state (if anchor-fn (anchor-fn env i noff) (init-fn env))
     :canon true}))

(defn- estimate-leading-step!
  "Fallback backward step when NO checkpoint covers the region above the cache
   (cold / never-visited off-screen margin): one leading child placed as its own
   run via the layout's :anchor + :place (leading-step-entry) — the layout's real
   spacing/cross, not the old one-child-per-slot `head - ext` estimate. Absolute
   offset stays approximate (docs §2/§4 accept a transiently approximate off-screen
   leading margin); geometry shape is canonical. Returns true iff it stepped."
  [^CollectionRenderSliver rs layout env]
  (let [measure-fn (:measure layout)
        cache (.-cache rs)
        ^int cf (.-cacheFirst rs)
        ^int i (dec cf)]
    (if-let [c (.insertAndLayoutLeadingChild rs
                ^r/BoxConstraints (measure-fn env i)
                .parentUsesSize true)]
      (let [_ (.-passMaterialized! rs (inc (.-passMaterialized rs)))
            ^double ext (.paintExtentOf rs ^r/RenderBox c)
            ^double head (double (:offset (nth cache 0)))
            ^double head-max-end (double (:max-end (nth cache 0)))
            e (leading-step-entry layout env i head (.-size ^r/RenderBox c) ext head-max-end)
            ^double noff (double (:offset e))
            ^double cross (double (:cross e))]
        (set-layout-offset! c noff)
        (set-cross-axis-offset! c cross)
        (.-cache! rs (into [(dissoc e :base-state)] cache))
        (.-cacheFirst! rs i)
        (.-baseState! rs (:base-state e))
        true)
      false)))

;; @ai-generated(guided)
(defn- trim-front!
  "Applies trim-front to the live cache (Row 3): drops the fully-above-band prefix
   and re-seeds cacheFirst/baseState so the retained band IS the whole cache.
   Without it a from-0-anchored deep scroll keeps every entry [0..head] on the heap
   (O(N) memory) — cacheFirst never leaves 0. The dropped prefix's children were
   already collected by pre-/post-gc! over the same [ws-o, we-o] band, so no child
   is orphaned. anchoredTo0 is untouched: trimming preserves the exact-offsets claim
   (frontier-after-prune). Runs every flow pass, after backfill has lowered
   cacheFirst to the band top."
  [^CollectionRenderSliver rs ^double ws]
  (when-let [[cache' ^int cf' base'] (trim-front (.-cache rs) (.-cacheFirst rs) ws)]
    (.-cache! rs cache')
    (.-cacheFirst! rs cf')
    (.-baseState! rs base')))

(defn synth-renewal-checkpoint
  "A backward-re-flow seed at the nearest renewal-point index `k` (<= `target`) for
   a flow layout that exposes run structure (`:renewal-index` + `:approx-offset` +
   `:anchor`) but has NO STORED checkpoint above the cache — the cold-deep-start /
   far-jump / post-layout-switch state where the checkpoint store above the window
   is empty or pruned to the band. Its :offset is the layout's O(1) :approx-offset
   estimate and its :state the renewal-point :anchor state (exact at a run start by
   the two-mode contract). Reflowing from it lands on a run boundary and produces
   WHOLE RUNS with real :cross — this is what stops wrap's above-window backfill
   from degenerating to a single left column (#A), the single-child leading
   estimate's failure mode for a packed layout.

   Returns nil when `target` is ITSELF a run start (k == target — list, or a wrap
   run boundary), where the single-child leading estimate is already exact and
   cheaper (no seam reconciliation), or when the layout lacks the hooks (masonry).
   The synthesized run start is only an ESTIMATE (the real pack uses measured
   sizes), so `k` may not be a true boundary — but the forward :place re-flow from
   it packs subsequent cells by real size, so the structure is correct multi-column
   forward of `k` with at most one approximate break at `k` itself, reconciled as
   the walk reaches a true checkpoint or index 0. Pure."
  [layout env ^int target]
  (let [ri (:renewal-index layout)
        approx (:approx-offset layout)
        anchor (:anchor layout)]
    (when (and ri approx anchor (not (neg? target)))
      (let [^int k (int (ri env target))]
        (when (< k target)
          (let [^double off (double (approx env k))]
            {:index k :offset off :state (anchor env k off)}))))))

(defn- backfill-leading!
  "Materialises the leading margin [ws, cache[0].offset) above the cached region as
   REAL runs (WS2.2 §2.2): each step seeds at the nearest checkpoint at-or-above the
   target — stored, else a run-boundary checkpoint synthesized from the layout's run
   structure (synth-renewal-checkpoint) — and re-flows forward (real :cross /
   per-run :offset — kills #5/#A's single left column), falling back to the
   one-child estimator only where no checkpoint AND no run structure exist (list /
   masonry). Returns this pass's refinement correction (double) or nil.

   Phase C refinement, telescoped per pass: every step that discovers a seam
   mismatch reconciles it in place (reflow-from-checkpoint! shifts the content
   at/below the seam), and the walk CONTINUES in the shifted frame accumulating
   the deltas into ONE summed pixel-stable scrollOffsetCorrection — one viewport
   re-run per frame regardless of how many stale seams the band holds (the
   per-seam pass-ending emission hit the viewport's 10-cycle cap on a deep stale
   band). Exact landing: whenever the cache reaches index 0
   away from offset 0, the residual is the final correction — the cache is
   dropped and the corrected re-run re-flows from :init, placing index 0 exactly
   at offset 0 with pixels unmoved; scroll stops exactly on the first element and
   anchoredTo0 flips true. The landing check runs every pass (not only after a
   step) so a residual deferred by suppression / a segment is picked up by the
   next resting pass; while `emit?` is false the offset model stays frozen.

   `emit?` gates the above-anchor SEAM refinement (reflow-from-checkpoint!) — off
   during a fast fling so a mid-content correction doesn't race the simulation.
   `origin-emit?` gates the ORIGIN corrections (exact landing at index 0, top-
   underflow); it is off only mid-segment, NOT for velocity, so a fast up-fling
   still lands index 0 exactly instead of leaving a gap above it (#B)."
  [^CollectionRenderSliver rs layout env ^double ws ^bool emit? ^bool origin-emit?]
  (let [init-fn (:init layout)
        approx-fn (:approx-offset layout)
        land (fn [^double wsx]
               (when (and (zero? (.-cacheFirst rs)) (seq (.-cache rs)))
                 (let [^double z (double (:offset (nth (.-cache rs) 0)))]
                   (case (landing-decision z origin-emit? (.-landingEmitted rs))
                     :converged (do (.-anchoredTo0! rs true)
                                    (.-landingEmitted! rs false)
                                    nil)
                     :defer nil
                     :emit (do (.-cache! rs [])
                               ;; stale-frame checkpoints would re-seed the OLD
                               ;; coordinates on the corrected re-run — the
                               ;; residual would be re-derived, not absorbed
                               (.-checkpoints! rs {})
                               (.-baseState! rs (init-fn env))
                               (.-anchoredTo0! rs false)
                               (.-landingEmitted! rs true)
                               ;; where the corrected re-run's window will sit
                               ;; (wsx = ws + this pass's accumulated seam
                               ;; corrections); seed-cache! consumes it and
                               ;; forces the from-:init walk
                               (.-pendingLandingWs! rs
                                 (+ wsx (.-overscanBehind rs) (- z)))
                               (- z))
                     :violated
                     (do (when fd/kDebugMode
                           (assert false
                                   (str "collection: flow layout " (:id layout)
                                        " walked from :init left index 0 at offset " z
                                        " — :init/:place must put index 0 at offset 0")))
                         ;; release: degrade to a constant inset — accept z as the
                         ;; origin so the offset stops creeping by z every pass.
                         (.-anchoredTo0! rs true)
                         (.-landingEmitted! rs false)
                         nil)))))
        ;; Top-underflow: the leading backfill stalled at a positive frontier `cf`
        ;; sitting at/above the coordinate origin because the re-anchor estimate
        ;; undershot the true leading extent — indices 0..cf-1 fell below offset 0
        ;; and became unreachable ("clamps with #cf as the top, nothing above").
        ;; Manufacture the missing extent = honest(cf) − head as a pixel-stable
        ;; scrollOffsetCorrection (like the reanchor shift): hold the visible
        ;; children put while the coordinate space grows and the indicator jumps to
        ;; the honest estimate, restoring the scroll range so index 0 is reachable.
        ;; Drop the cache + stale checkpoints so the corrected re-run re-seeds the
        ;; frontier at its honest offset (seed-cache!'s dead-reckon) and re-flows.
        underflow
        (fn []
          (let [cache (.-cache rs)
                ^int cf (.-cacheFirst rs)]
            (when (and (pos? cf) (seq cache))
              (let [^double head (double (:offset (nth cache 0)))
                    ^double avg (double (or (:avg-main env) 0.0))
                    ^double honest (cond
                                     approx-fn (double (approx-fn env cf))
                                     (pos? avg) (* cf avg)
                                     :else head)]
                (when (= :emit (underflow-decision cf head honest origin-emit?))
                  (let [^double deficit (- honest head)]
                    (shift-attached-from! rs cf deficit)
                    (.-cache! rs [])
                    (.-checkpoints! rs {})
                    (.-anchoredTo0! rs false)
                    deficit))))))]
    ;; The walk ACCUMULATES seam corrections instead of ending the pass per
    ;; emission: each reconciled seam already shifted the content at/below it
    ;; (shift-attached-from!), so the deltas compose additively into ONE summed
    ;; scrollOffsetCorrection and the loop continues in the shifted frame
    ;; (wsx = ws + acc tracks where the corrected window will sit). One
    ;; emission per pass ⇒ one viewport re-run per frame, however many stale
    ;; seams the band holds — a chain of N seams used to cost N layout cycles
    ;; and hit the RenderViewport 10-cycle cap in a single frame.
    (loop [^double acc 0.0 ^double wsx ws]
      (let [cache (.-cache rs)
            ^int cf (.-cacheFirst rs)
            total (fn [tail]
                    (let [^double t (+ acc (double (or tail 0.0)))]
                      (when (> (.abs t) 1e-3) t)))]
        (if (and (pos? cf) (seq cache) (> ^double (:offset (nth cache 0)) wsx))
          (let [cp (or (cp-nearest-at-or-below (.-checkpoints rs) (dec cf))
                       (synth-renewal-checkpoint layout env (dec cf)))
                stepped (if cp
                          (reflow-from-checkpoint! rs layout env cp emit?)
                          (estimate-leading-step! rs layout env))]
            (cond
              (identical? true stepped) (recur acc wsx)
              (or (nil? stepped) (false? stepped)) (total (land wsx))
              ;; seam correction reconciled — fold it in and keep walking in
              ;; the shifted frame; the single corrected re-run re-walks the
              ;; window from the exact prefix state.
              :else (let [^double d (double stepped)]
                      (recur (+ acc d) (+ wsx d)))))
          ;; leading budget exhausted (head <= wsx) or cf==0: manufacture the
          ;; missing leading extent when the frontier undershoots the origin,
          ;; else land.
          (total (or (underflow) (land wsx))))))))

(defn- anchor-before
  "Snapshot of the first cached entry overlapping the paint window —
   the child the user is visually anchored to."
  [^CollectionRenderSliver rs ^double so]
  (let [cache (.-cache rs)
        ^int rel (bsearch-max-end cache so)]
    (when (< rel (count cache))
      {:idx (+ (.-cacheFirst rs) rel)
       :off (double (:offset (nth cache rel)))})))

(defn- anchor-delta
  "How far the anchored child moved during this pass; non-nil requests a
   scroll correction so the viewport follows it."
  [^CollectionRenderSliver rs anchor]
  (when anchor
    (let [^int rel (- ^int (:idx anchor) (.-cacheFirst rs))
          cache (.-cache rs)]
      (when (and (>= rel 0) (< rel (count cache)))
        (let [^double delta (- ^double (:offset (nth cache rel)) ^double (:off anchor))]
          (when (> (.abs delta) 1e-3)
            delta))))))

(defn window-canonical-violations
  "Structural-invariant guard (debug only). Cache entries whose laid span
   [offset, end) overlaps the true VISIBLE window [vs, ve) but whose geometry did
   NOT come from the layout's :place walk (`:canon` unset).

   The invariant (user directive): estimates may decide WHERE the window starts
   (base offset) and shape the extents OUTSIDE it, but the cells INSIDE the
   materialized window are ALWAYS placed by the one canonical flow walk
   (:anchor-seeded state + :place per child). No path may write estimate-shaped
   entries (uniform avg extents, missing spacing, cross 0) into the visible window.

   Non-empty ⇒ a leak — the root class behind the single-left-column, the Phase-E
   resting approx frames, and the wrap→jump→list no-spacing bugs. Pure; the caller
   runs it only under kDebugMode so release overhead is zero. Returns the offending
   [abs-index entry] pairs."
  [cache ^int cache-first ^double vs ^double ve]
  (loop [^int rel 0 out []]
    (if (< rel (count cache))
      (let [e (nth cache rel)]
        (recur (inc rel)
               (if (and (< (double (:offset e)) ve)
                        (> (double (:end e)) vs)
                        (not (:canon e)))
                 (conj out [(+ cache-first rel) e])
                 out)))
      out)))

(defn- assert-window-canonical!
  "kDebugMode: fail loudly if any cache entry overlapping the visible paint window
   lacks canonical-walk provenance (window-canonical-violations). Zero release
   overhead — the whole body is dead-code-eliminated when kDebugMode is false."
  [^CollectionRenderSliver rs layout ^r/SliverConstraints c]
  (when fd/kDebugMode
    (let [^double vs (.-scrollOffset c)
          ^double ve (+ vs (.-remainingPaintExtent c))
          v (window-canonical-violations (.-cache rs) (.-cacheFirst rs) vs ve)]
      (when (seq v)
        (assert false
                (str "collection: flow layout " (:id layout) " left "
                     (count v) " estimate-shaped cell(s) in the visible window ["
                     vs " " ve ") — in-window geometry must come from the canonical "
                     ":place walk (WS2 invariant). First offender: " (first v)))))))

(def ^:private ^double materialize-budget-factor
  "Headroom multiplier of the materialization tripwire over a perfectly dense
   band. Generous (a dense pass uses ~1x) so estimate error — avg-main measured
   over items much larger than the ones actually entering the band — never trips
   it on legit scroll/jump/morph flows; an O(gap) walk overshoots it by orders."
  4.0)

(def ^:private ^int materialize-budget-floor
  "Constant slack of the materialization tripwire — tiny windows / double-laid
   leading placeholders must not flake it."
  32)

(defn materialization-budget
  "Ceiling on how many children ONE flow pass may lay out under the
   O(window+overscan) design bound (the cache is an accelerator; per-pass work
   never depends on cache contents or jump distance):
     floor + factor * (band-extent / avg-main) * items-per-run
   where items-per-run = max(1, cross-extent / avg-cross) (a wrap packs several
   items per main-axis run; a list's MEASURED full-width children → 1). Infinite
   while EITHER density is unknown (nothing measured yet — a cold first pass may
   legitimately walk an unknown band): an unknown cross density must WIDEN the
   budget, never collapse it to 1-per-run — a bare-double approximate-item-size
   seeds only the main aggregate, and modeling a wrap band as one item per run
   was the on-device false positive. Pure."
  [^double band-extent ^double avg-main ^double avg-cross ^double cross-extent]
  (if-not (and (pos? avg-main) (.-isFinite avg-main)
               (pos? avg-cross) (.-isFinite avg-cross) (pos? cross-extent))
    dc/double.infinity
    (let [^double per-run (math/max 1.0 (/ cross-extent avg-cross))]
      (+ materialize-budget-floor
         (* materialize-budget-factor per-run (/ band-extent avg-main))))))

(defn tripwire-env
  "env for the materialization tripwire: THIS pass's attached-window sample
   means override the persistent EMA. The EMA goes stale across a layout :id
   change (update-render! keeps it — a stale estimate beats none for
   :approx-offset), but for the tripwire a list-era :avg-cross == cross-extent
   models the new wrap band as ONE item per run and collapses the budget under a
   legitimate dense relayout. nil sample (nothing sized) keeps the EMA env. Pure."
  [env sample]
  (if sample (merge env sample) env))

(defn- assert-materialization-bounded!
  "kDebugMode tripwire for the O(window+overscan) per-pass bound: a resting flow
   pass that laid out more than materialization-budget children walked a gap
   instead of seeding geometrically (the far-jump freeze class). Zero release
   overhead — dead-code-eliminated when kDebugMode is false."
  [^CollectionRenderSliver rs layout env ^double band-extent]
  (when fd/kDebugMode
    (let [^double budget (materialization-budget band-extent
                                                 (double (or (:avg-main env) 0.0))
                                                 (double (or (:avg-cross env) 0.0))
                                                 (double (:cross-extent env)))
          ^int n (.-passMaterialized rs)]
      (assert (<= n budget)
              (str "collection: flow layout " (:id layout) " laid out " n
                   " children in ONE pass — budget " budget " for the "
                   band-extent "px band. Per-pass work must be O(window+overscan);"
                   " some path walked a gap instead of seeding geometrically.")))))

(defn- finish-flow-geometry!
  [^CollectionRenderSliver rs layout env ^r/SliverConstraints c walked]
  (let [^r/RenderSliverBoxChildManager mgr (.-childManager rs)
        ^double end (double (:end walked))
        ^int last-i (int (:last-i walked))
        reached (boolean (:reached walked))
        item-count (:item-count env)
        ^double total
        (cond
          reached end
          (nil? item-count) dc/double.infinity
          :else (math/max end
                          (if-let [est (:estimate layout)]
                            (double (est env last-i end (int item-count)))
                            (* end (/ (double item-count) (double (inc last-i)))))))
        ;; §2.4 indicator honesty: while anchoredTo0 the reported extent is truth
        ;; (walked/estimated from exact offsets). While un-anchored it is honest-
        ;; but-approximate — let the measured-density :approx-offset raise it
        ;; toward truth, never below the walked end (content is laid there).
        ^double total
        (if (and (not reached)
                 (not (.-anchoredTo0 rs))
                 item-count)
          (if-let [approx-fn (:approx-offset layout)]
            (math/max total (double (approx-fn env (int item-count))))
            total)
          total)
        ^double first-off (if-let [fc (.-firstChild rs)]
                            (or (.childScrollOffset rs ^r/RenderBox fc) 0.0)
                            (let [cache (.-cache rs)]
                              (if (seq cache) (double (:offset (nth cache 0))) 0.0)))
        ^double paint-extent (.calculatePaintOffset rs c .from first-off .to end)
        ^double cache-extent (.calculateCacheOffset rs c .from first-off .to end)]
    (.-geometry! rs
      (r/SliverGeometry
       .scrollExtent total
       .paintExtent paint-extent
       .cacheExtent cache-extent
       .maxPaintExtent total
       .hasVisualOverflow (or (> end (+ (.-scrollOffset c) (.-remainingPaintExtent c)))
                              (pos? (.-scrollOffset c)))))
    (when reached
      (.setDidUnderflow mgr true))
    ;; WS2 invariant tripwire (debug only, resting frames): no estimate-shaped cell
    ;; may sit in the visible window. Segment-capture passes place a transient tween
    ;; window, so the check is scoped to resting; flying-flow! is the sanctioned
    ;; approximate path and keeps the cache empty, so it never reaches here.
    (when (nil? (.-tweenAnim rs))
      (assert-window-canonical! rs layout c))
    (.didFinishLayout mgr)))

;; @ai-generated(solo)
(defn- flying-flow!
  "Flying-regime approximate placement (WS2.1 §4). Lays ONLY the visible window
   [ws, we] at monotone :approx-offset positions — no overscan, no backfill, no
   refinement, no checkpoint reflow — so a fast fling / far animateTo doesn't pay
   O(gap) real layout for frames that fly past unseen. Children still self-size
   (they must, to paint) but stack at the estimate with cross 0 (fly-by frames
   aren't scrutinised — a wrap window shows a transient single column mid-fling).
   On regime ENTRY (`entry?`) it drops the persistent real cache once and un-anchors
   the frontier, so the next resting/landing pass dead-reckons from the attached top
   and refines to land exactly; subsequent flying passes REUSE the attached children
   and leave the (already-empty) cache untouched — clearing it every pass would force
   a cold re-materialisation each frame (the fast-scroll stutter). Falls back to the
   real driver when the estimate is degenerate (no measured :avg-main yet)."
  [^CollectionRenderSliver rs layout ^r/SliverConstraints c ^bool entry?]
  (let [env (lay/make-env c (.-itemCount rs) (env-agg rs))
        env (if-let [prep (:prepare layout)] (assoc env :ctx (prep env)) env)
        approx-fn (:approx-offset layout)]
    (if (or (nil? approx-fn) (not (pos? (double (or (:avg-main env) 0.0)))))
      (flow-layout! rs layout c)   ; can't estimate yet — stay on real geometry
      (let [^r/RenderSliverBoxChildManager mgr (.-childManager rs)]
        (.didStartLayout mgr)
        (.setDidUnderflow mgr false)
        (.-clips! rs {})
        (let [measure-fn (:measure layout)
              anchor-fn (:anchor layout)
              init-fn (:init layout)
              item-count (:item-count env)
              approx (fn ^double [^int i] (double (approx-fn env i)))
              ^double ws (+ (.-scrollOffset c) (.-cacheOrigin c))
              ^double we (+ ws (.-remainingCacheExtent c))
              ^int n (int (or item-count 0))
              ^int raw (invert-approx-offset approx ws item-count)
              ^int start (if (pos? n) (math/max 0 (math/min raw (dec n))) (math/max 0 raw))]
          ;; ONCE on entry: drop the stale real cache — flying owns approximate
          ;; offsets; landing rebuilds real geometry (seed-cache! dead-reckons from
          ;; the attached top). Later flying passes keep the cache empty and reuse
          ;; attached children, so no per-frame cold rebuild.
          (when entry?
            (.-cache! rs [])
            (.-cacheFirst! rs start)
            (.-baseState! rs (if anchor-fn (anchor-fn env start (approx start)) (init-fn env)))
            (.-anchoredTo0! rs false))
          (if (.-firstChild rs)
            (.collectGarbage rs (.calculateLeadingGarbage rs .firstIndex start) 0)
            (.collectGarbage rs 0 0))
          (if (and (nil? (.-firstChild rs))
                   (not (.addInitialChild rs .index start .layoutOffset (approx start))))
            (do (.-geometry! rs r/SliverGeometry.zero) (.didFinishLayout mgr))
            (do
              ;; ensure firstChild sits at/above `start`
              (loop []
                (let [^int fidx (.indexOf rs (.-firstChild rs))]
                  (when (> fidx start)
                    (when-let [ch (.insertAndLayoutLeadingChild rs
                                   ^r/BoxConstraints (measure-fn env (dec fidx))
                                   .parentUsesSize true)]
                      (set-layout-offset! ch (approx (dec fidx)))
                      (set-cross-axis-offset! ch 0.0)
                      (recur)))))
              ;; forward-fill the visible window at approximate offsets
              (let [[^int last-i ^double end reached]
                    (loop [^r/RenderBox child (.-firstChild rs)
                           ^int i (.indexOf rs (.-firstChild rs))]
                      (.layout child ^r/BoxConstraints (measure-fn env i) .parentUsesSize true)
                      (let [^double off (approx i)
                            ^double ext (.paintExtentOf rs child)]
                        (set-layout-offset! child off)
                        (set-cross-axis-offset! child 0.0)
                        (if (>= off we)
                          [i (+ off ext) false]
                          (let [after (.childAfter rs child)
                                nxt (if (and after (= (.indexOf rs ^r/RenderBox after) (inc i)))
                                      after
                                      (.insertAndLayoutChild rs
                                       ^r/BoxConstraints (measure-fn env (inc i))
                                       .after child .parentUsesSize true))]
                            (if (nil? nxt)
                              [i (+ off ext) true]
                              (recur ^r/RenderBox nxt (inc i)))))))]
                ;; collect anything beyond the last placed index
                (let [^int trailing (loop [cc (.-lastChild rs) ^int ntr 0]
                                      (if (and cc (> (.indexOf rs ^r/RenderBox cc) last-i))
                                        (recur (.childBefore rs ^r/RenderBox cc) (inc ntr))
                                        ntr))]
                  (.collectGarbage rs 0 trailing))
                (let [^double first-off (approx start)
                      ^double total (cond
                                      reached end
                                      (nil? item-count) dc/double.infinity
                                      :else (math/max end (approx (int item-count))))
                      ^double paint-extent (.calculatePaintOffset rs c
                                            .from (math/min (.-scrollOffset c) first-off) .to end)
                      ^double cache-extent (.calculateCacheOffset rs c .from first-off .to end)]
                  (.-geometry! rs
                    (r/SliverGeometry
                     .scrollExtent total .paintExtent paint-extent .cacheExtent cache-extent
                     .maxPaintExtent total
                     .hasVisualOverflow (or (> end (+ (.-scrollOffset c) (.-remainingPaintExtent c)))
                                            (pos? (.-scrollOffset c)))))
                  (when reached (.setDidUnderflow mgr true))
                  (.didFinishLayout mgr))))))))))

(defn- flow-layout! [^CollectionRenderSliver rs layout ^r/SliverConstraints c]
  (let [^r/RenderSliverBoxChildManager mgr (.-childManager rs)]
    (.didStartLayout mgr)
    (.setDidUnderflow mgr false)
    ;; §8a: flow children are never engine-clipped — clear any stale clip map
    ;; left by a prior indexed segment so it doesn't paint-clip this flow pass.
    (.-clips! rs {})
    ;; fresh each pass: seed-cache! sets it only when it re-anchors cross-layout.
    (.-reanchorShift! rs dc/double.nan)
    ;; per-pass laid-child counter for the O(window+overscan) tripwire
    (.-passMaterialized! rs 0)
    (let [env (lay/make-env c (.-itemCount rs) (env-agg rs))
          env (if-let [prep (:prepare layout)] (assoc env :ctx (prep env)) env)
          ^double so (.-scrollOffset c)
          ^double ws (+ so (.-cacheOrigin c))
          ^double we (+ ws (.-remainingCacheExtent c))
          ;; WS2 phase E: widen the materialisation/GC window by this frame's
          ;; directional overscan (0 while segment/flying/disabled). Geometry
          ;; advertised to the viewport stays on the TRUE [ws, we] — the overscan
          ;; children are held privately (finish-flow-geometry! clamps paint/cache
          ;; extent to the constraints' true remaining, so they aren't advertised).
          ^double ws-o (- ws (.-overscanBehind rs))
          ^double we-o (+ we (.-overscanAhead rs))]
      (pre-gc! rs ws-o we-o)
      (seed-cache! rs layout env)
      (normalize-cache! rs layout env)
      (let [;; a cross-layout re-anchor (seed-cache!) rebased the walked frame by
            ;; reanchorShift and the emitted correction / segment set-point lands
            ;; the window there — materialize THIS pass against the shifted band,
            ;; or backfill walks the whole (approx − stale) gap in one frame.
            [^double ws-eff ^double we-eff] (reanchor-band ws-o we-o (.-reanchorShift rs))
            ^double align-ws (+ ws (- ws-eff ws-o))
            anchor (anchor-before rs so)
            ;; Phase C emission gate, phase-E suppression signal: refinement
            ;; corrections are emitted only on a resting (no-segment) pass with no
            ;; active upward drag/fling (velocity sensor) — mutually exclusive with
            ;; the WS1.3 segment correction per pass.
            seg? (some? (.-tweenAnim rs))
            emit? (refine-emit? seg?
                                (refine-suppressed? (.-scrollSign rs) (.abs (.-velocityEMA rs))
                                                    (double (:suppress-v overscan-tunables))
                                                    (double (:v-fast overscan-tunables))))
            ;; Origin corrections (exact landing at 0, top-underflow) are boundary
            ;; reconciliations — pixel-stable and same-frame-convergent — so they
            ;; fire even under ballistic suppression, only deferring mid-segment.
            ;; Without this a fast up-fling leaves a gap above item 0 until it
            ;; decelerates (#B).
            origin-emit? (origin-refine-emit? seg?)]
        ;; RESTING only: the anchored top {:idx :off} seeds the next segment's
        ;; set-point. During a segment flow-layout! runs to capture the target.
        (when (nil? (.-tweenAnim rs))
          (.-restingTop! rs anchor))
        (if-not (align-start! rs layout env align-ws)
          (do (.-geometry! rs r/SliverGeometry.zero)
              (.didFinishLayout mgr))
          (let [walked (walk! rs layout env we-eff)
                ^int last-i (int (:last-i walked))
                ;; §7b: this branch runs mid-segment only as the CAPTURE pass
                ;; (segment-start!). Attached cells whose committed rect still
                ;; overlaps the window are leave-slides — keep them past the
                ;; walked window so they stay materialized and glide out.
                ^int keep-last (if (.-tweenAnim rs)
                                 (let [[_ kl] (widen-window! rs last-i last-i ws we)]
                                   (int kl))
                                 last-i)]
            (post-gc! rs keep-last ws-eff)
            (let [corr (backfill-leading! rs layout env ws-eff emit? origin-emit?)]
              ;; Row 3 memory bound: front-trim the cache to the overscan band so a
              ;; from-0-anchored deep scroll doesn't keep [0..head] on the heap. The
              ;; retained offsets stay exact (baseState re-seeds from the last
              ;; dropped entry), so this never degrades the frontier.
              (trim-front! rs ws-eff)
              ;; Geometric checkpoint scoping (phase-E-widened): keep the overscan
              ;; band [ws-eff, we-eff] plus one seed above (the D prune re-scoped).
              (.-checkpoints! rs (cp-prune-offset (.-checkpoints rs) ws-eff we-eff))
              ;; Frontier reconciliation: geometric prune/trim never clears
              ;; anchoredTo0 under the Row 3 invariant — its claim is "offsets exact",
              ;; which trimming preserves; degradation is owned by the offset ops.
              (.-anchoredTo0! rs (frontier-after-prune (.-anchoredTo0 rs)))
              ;; measured aggregates track the live window on resting passes so
              ;; :approx-offset / extent extrapolation follow reality (§1.1).
              (when (nil? (.-tweenAnim rs))
                (let [sample (update-measured-agg! rs env)]
                  ;; O(window+overscan) tripwire (debug, resting passes — a segment
                  ;; capture legitimately widens the window via widen-window!). The
                  ;; budget's density comes from THIS pass's sample, not the EMA:
                  ;; env was built pre-pass and the EMA is stale across a layout
                  ;; :id change (tripwire-env).
                  (assert-materialization-bounded! rs layout (tripwire-env env sample)
                                                   (- we-o ws-o))))
              ;; A cross-layout re-anchor (seed-cache!) takes precedence: this pass's
              ;; anchor was captured AFTER the re-anchor so anchor-delta reads ~0; the
              ;; recorded shift is the real correction that keeps the visible child put
              ;; while the offset jumps to the new-layout estimate. During a segment
              ;; capture pass segment-start! overwrites this geometry, so the segment's
              ;; own set-point (not this) moves the viewport — no double count.
              (let [^double rsh (.-reanchorShift rs)]
                (cond
                  (not (.-isNaN rsh))
                  (do (.-geometry! rs (r/SliverGeometry .scrollOffsetCorrection rsh))
                      (.didFinishLayout mgr))
                  corr
                  (do (.-geometry! rs (r/SliverGeometry .scrollOffsetCorrection (double corr)))
                      (.didFinishLayout mgr))
                  :else
                  (if-let [delta (anchor-delta rs anchor)]
                    (do (.-geometry! rs (r/SliverGeometry .scrollOffsetCorrection (double delta)))
                        (.didFinishLayout mgr))
                    (finish-flow-geometry! rs layout env c walked)))))))))))

;; ============================================================
;; Indexed driver
;; ============================================================

;; @ai-generated(solo)
(defn- capture-resting-top!
  "Records the OLD viewport top for the next segment's set-point: the first laid
   child whose content-space span reaches past `scroll-off`, as {:idx :off} in
   content space. Called only on a RESTING indexed pass, while indices are
   consistent. Stores nil when no attached child overlaps."
  [^CollectionRenderSliver rs env ^double scroll-off]
  (.-restingTop! rs
    (loop [child (.-firstChild rs)]
      (when child
        (let [^r/RenderBox ch child
              ^r/SliverGridParentData pd (.-parentData ch)
              ^double off (double (or (.-layoutOffset pd) 0.0))
              ^double me (if (.-hasSize ch) (lay/size-main env (.-size ch)) 0.0)]
          (if (> (+ off me) scroll-off)
            {:idx (.indexOf rs ^r/RenderBox ch) :off off}
            (recur (.childAfter rs ^r/RenderBox ch))))))))

;; @ai-generated(solo)
(defn- seg-scroll-correction
  "Incremental set-point scroll correction for the animating/indexed path (docs §9):
   drives scrollOffset so the captured viewport-top slot tracks its lerped OLD→NEW
   position. Emits only the per-pass ANIMATION delta (desired(t) − segPrevDesired),
   so a concurrent user drag composes with the animation instead of being reverted;
   updates segPrevDesired to the emitted target (telescopes exactly to to−from, and
   a same-t re-run — the viewport re-layout after a correction — emits 0, letting the
   pass converge). `c` is unused now that the correction ignores the live offset.
   Returns the correction delta or nil.
   Note: if ScrollPosition clamps the applied correction (overscroll near an edge),
   segPrevDesired drifts from real pixels; accepted — the drift is bounded (≤ to−from)
   and reconciled by the resting-pass anchor-delta once the segment ends."
  [^CollectionRenderSliver rs ^r/SliverConstraints _c]
  (when (and (.-tweenAnim rs) (.-segAnchor rs))
    (let [[corr ^double new-prev]
          (tw/point-correction-delta (.-segAnchor rs)
                                     (.-value ^a/Animation (.-tweenAnim rs))
                                     (.-segPrevDesired rs))]
      (.-segPrevDesired! rs new-prev)
      corr)))

;; @ai-generated(solo)
(defn- compute-clips!
  "§8a: (re)build the `clips` map — {child-index -> [vis-main vis-cross opacity]} — for
   every attached cell whose lerped VISIBLE extent is smaller than its full laid extent
   on the collapse axis. Such a cell is laid at full but painted clipped to that
   window; a faded enter/exit cell also carries opacity = its collapse fraction so the
   fade rides the same jump-free window. Shared by the indexed driver and the
   first-pass `from-relay!` so both display an enter/exit collapse without a flash."
  [^CollectionRenderSliver rs env geo-fn]
  (let [entering (.-entering rs)
        exiting (.-exiting rs)
        fade-enter (.-fadeEnter rs)
        fade-exit (.-fadeExit rs)]
    (.-clips! rs
      (loop [child (.-firstChild rs) m (transient {})]
        (if child
          (let [^r/RenderBox ch child
                ^int idx (.indexOf rs ch)
                gm (geo-fn env idx)
                k (key-for rs idx)
                fade? (or (and fade-enter (contains? entering k))
                          (and fade-exit (contains? exiting k)))]
            (recur (.childAfter rs ch)
                   (if-let [entry (tw/clip-window gm fade?)]
                     (assoc! m idx entry)
                     m)))
          (persistent! m))))))

(defn- indexed-layout! [^CollectionRenderSliver rs layout ^r/SliverConstraints c]
  (let [^r/RenderSliverBoxChildManager mgr (.-childManager rs)]
    (.didStartLayout mgr)
    (.setDidUnderflow mgr false)
    ;; §8a: fresh clip map each pass; a resting/non-collapsing frame leaves it {}.
    (.-clips! rs {})
    (let [env (lay/make-env c (.-itemCount rs) (env-agg rs))
          env (if-let [prep (:prepare layout)] (assoc env :ctx (prep env)) env)
          geo-fn (:geometry layout)
          ^double ws (+ (.-scrollOffset c) (.-cacheOrigin c))
          ^double we (+ ws (.-remainingCacheExtent c))
          ;; WS2 phase E: widen the index materialisation window by this frame's
          ;; overscan (0 while segment/flying/disabled). Geometry (1050) stays on
          ;; the true window — calculate*Offset clamps the overscan children out.
          ^double ws-o (- ws (.-overscanBehind rs))
          ^double we-o (+ we (.-overscanAhead rs))
          item-count (:item-count env)
          ^int first-index0 (let [^int fi (int ((:first-index layout) env ws-o))]
                              (if (and item-count (pos? ^int item-count))
                                (math/max 0 (math/min fi (dec ^int item-count)))
                                (math/max 0 fi)))
          target-last0 (when (.-isFinite we-o)
                         (int ((:last-index layout) env we-o)))
          ;; Union windowing (animating only): keep attached cells still
          ;; overlapping [ws, we] so a cell leaving/entering the new layout glides.
          [^int first-index target-last]
          (if (.-tweenAnim rs)
            (widen-window! rs first-index0 target-last0 ws we)
            [first-index0 target-last0])]
      ;; GC by index range
      (if (.-firstChild rs)
        (let [^int leading (.calculateLeadingGarbage rs .firstIndex first-index)
              ^int trailing (if target-last
                              (.calculateTrailingGarbage rs .lastIndex ^int target-last)
                              0)]
          (.collectGarbage rs leading trailing))
        (.collectGarbage rs 0 0))

      (let [gm-first (geo-fn env first-index)]
        (if (and (nil? (.-firstChild rs))
                 (not (.addInitialChild rs .index first-index
                                        .layoutOffset (double (:offset gm-first)))))
          ;; empty collection (or nothing at first-index)
          (let [^double max-ext (if item-count
                                  (double ((:max-extent layout) env (int item-count)))
                                  0.0)]
            (.-geometry! rs (r/SliverGeometry .scrollExtent max-ext .maxPaintExtent max-ext))
            (when (nil? (.-tweenAnim rs))
              (capture-resting-top! rs env (.-scrollOffset c)))
            (.didFinishLayout mgr))

          (let [^double leading-off (double (:offset gm-first))
                ;; children before the current firstChild, down to first-index
                last-leading
                (loop [^int idx (dec (.indexOf rs (.-firstChild rs)))
                       created nil]
                  (if (>= idx first-index)
                    (let [gm (geo-fn env idx)
                          ch (.insertAndLayoutLeadingChild rs (lay/cell-constraints env gm)
                                                            .parentUsesSize true)]
                      (if (nil? ch)
                        created
                        (do (set-layout-offset! ch (double (:offset gm)))
                            (set-cross-axis-offset! ch (double (:cross gm)))
                            (recur (dec idx) (or created ch)))))
                    created))
                ;; if no leading children were created, lay out the first child
                ^r/RenderBox start-child
                (or last-leading
                    (let [^r/RenderBox fc (.-firstChild rs)
                          ^int fidx (.indexOf rs fc)
                          gm (geo-fn env fidx)]
                      (.layout fc (lay/cell-constraints env gm) .parentUsesSize true)
                      (set-layout-offset! fc (double (:offset gm)))
                      (set-cross-axis-offset! fc (double (:cross gm)))
                      fc))
                ^double start-end (let [^int sidx (.indexOf rs start-child)
                                        gm (geo-fn env sidx)]
                                    (+ ^double (:offset gm) ^double (:main-extent gm)))
                ;; forward: create children only inside the TRUE target window
                ;; [first-index0, target-last0]; attached cells outside it (§7b
                ;; leave-slides kept by the widened GC bounds) are (re)laid at
                ;; their lerped frames but never bridged with created cells —
                ;; a shuffle must not materialize the span to a scattered index.
                [^double trail-end ^bool reached]
                (loop [^int idx (inc (.indexOf rs start-child))
                       ^r/RenderBox prev start-child
                       ^double trail-end start-end]
                  (let [existing (.childAfter rs prev)
                        at-idx (boolean (and existing
                                             (= (.indexOf rs ^r/RenderBox existing) idx)))
                        in-window (and (>= idx first-index0)
                                       (or (nil? target-last0) (<= idx ^int target-last0)))]
                    (cond
                      (or at-idx in-window)
                      (let [gm (geo-fn env idx)
                            ^r/BoxConstraints bc (lay/cell-constraints env gm)
                            child (if at-idx
                                    (do (.layout ^r/RenderBox existing bc .parentUsesSize true)
                                        existing)
                                    (.insertAndLayoutChild rs bc .after prev .parentUsesSize true))]
                        (if (nil? child)
                          [trail-end true]
                          (do (set-layout-offset! ^r/RenderBox child (double (:offset gm)))
                              (set-cross-axis-offset! ^r/RenderBox child (double (:cross gm)))
                              (recur (inc idx) ^r/RenderBox child
                                     (double (math/max trail-end
                                                       (+ ^double (:offset gm)
                                                          ^double (:main-extent gm))))))))
                      ;; out-of-window gap: jump to the next attached child (a
                      ;; kept leave-slide) or into the window start — no bridges.
                      :else
                      (let [nxt (cond
                                  (and existing (< idx first-index0))
                                  (math/min (.indexOf rs ^r/RenderBox existing) first-index0)
                                  existing (.indexOf rs ^r/RenderBox existing)
                                  (< idx first-index0) first-index0
                                  :else nil)]
                        (if nxt
                          (recur (int nxt) prev trail-end)
                          [trail-end false])))))
                ^double total (cond
                                item-count (double ((:max-extent layout) env (int item-count)))
                                reached trail-end
                                :else dc/double.infinity)
                ^double paint-extent
                (.calculatePaintOffset rs c
                  .from (math/min (.-scrollOffset c) leading-off)
                  .to trail-end)
                ^double cache-extent
                (.calculateCacheOffset rs c .from leading-off .to trail-end)
                ;; §8a: record each animating cell's paint-clip window (shared helper).
                _clips (compute-clips! rs env geo-fn)
                ;; Scroll correction (animating only): the indexed path writes
                ;; geometry directly, so when content above collapses/rescales
                ;; mid-segment the viewport-top slot jumps unless we follow it.
                ;; Incremental set-point model (docs §9) — per-pass animation delta,
                ;; composes with user drag; same-t re-layout converges to 0.
                corr (seg-scroll-correction rs c)]
            (if corr
              (do (.-geometry! rs (r/SliverGeometry .scrollOffsetCorrection (double corr)))
                  (.didFinishLayout mgr))
              (do
                (.-geometry! rs
                  (r/SliverGeometry
                   .scrollExtent total
                   .paintExtent paint-extent
                   ;; mid-collapse the laid trail exceeds the final resting total;
                   ;; maxPaintExtent must cover what we actually paint this pass.
                   .maxPaintExtent (math/max total paint-extent)
                   .cacheExtent cache-extent
                   .hasVisualOverflow (or (> total paint-extent)
                                          (pos? (.-scrollOffset c))
                                          (not (zero? (.-overlap c))))))
                (when (or reached (= total trail-end))
                  (.setDidUnderflow mgr true))
                ;; RESTING only: record the OLD viewport top for the next segment.
                (when (nil? (.-tweenAnim rs))
                  (capture-resting-top! rs env (.-scrollOffset c)))
                (.didFinishLayout mgr)))))))))

;; ============================================================
;; Segment start (v2 keyed rect animator)
;; ============================================================

;; @ai-generated(solo)
(defn- layout-frame-source
  "The ONE way to evaluate a `layout` into per-cell frames, behind the frame-source
   interface — used symmetrically for BOTH endpoints of a morph: the OLD layout gives
   an arriving cell its `from` (§7c), the NEW layout gives a leaving cell its `to`
   size (§7b). Uniform across layout kinds:
     - INDEXED layout → exact O(1) math (`indexed-frame-source`).
     - FLOW layout → dry-measure the currently attached cells at this layout's
       constraint and place them under its flow (`project-flow-window`, wrapped as a
       `frozen-frame-source`).
   Returns nil when a flow layout has nothing attached to measure (e.g. an arriving
   cell not yet materialised because an indexed target hasn't laid its window) — the
   caller then falls back to an edge slide at the other endpoint's size."
  [^CollectionRenderSliver rs layout]
  (if (some? (:geometry layout))
    (tw/indexed-frame-source layout)
    (when-let [snap (project-flow-window rs layout)]
      (tw/frozen-frame-source snap))))

;; @ai-generated(solo)
(defn- from-relay!
  "Re-lays every currently attached child at `layout`'s indexed geometry and
   writes sliver geometry — WITHOUT a childManager create/GC cycle, so it triggers
   no didStartLayout/didFinishLayout. Used to display a FLOW segment's first pass
   at its `from` rects (t≈0) after the flow capture walk already ran one lifecycle
   cycle; a second full driver would double it. Relaid: the target window flow
   just materialized plus the kept leave-slides (§7b) — at t≈0 exactly the
   visible set (a leaving cell's lerp starts at its committed rect)."
  [^CollectionRenderSliver rs layout ^r/SliverConstraints c]
  (let [env (lay/make-env c (.-itemCount rs) (env-agg rs))
        env (if-let [prep (:prepare layout)] (assoc env :ctx (prep env)) env)
        geo-fn (:geometry layout)
        item-count (:item-count env)
        ^r/RenderBox fc (.-firstChild rs)
        ^double lead-off (if fc (double (:offset (geo-fn env (.indexOf rs fc)))) 0.0)
        ^double trail-end
        (loop [child fc ^double trail lead-off]
          (if child
            (let [^r/RenderBox ch child
                  ^int i (.indexOf rs ch)
                  gm (geo-fn env i)]
              (.layout ch (lay/cell-constraints env gm) .parentUsesSize true)
              (set-layout-offset! ch (double (:offset gm)))
              (set-cross-axis-offset! ch (double (:cross gm)))
              (recur (.childAfter rs ch)
                     (double (math/max trail (+ (double (:offset gm))
                                                (double (:main-extent gm)))))))
            trail))
        ^double total (if item-count
                        (double ((:max-extent layout) env (int item-count)))
                        trail-end)
        ^double paint-extent (.calculatePaintOffset rs c
                              .from (math/min (.-scrollOffset c) lead-off) .to trail-end)
        ^double cache-extent (.calculateCacheOffset rs c .from lead-off .to trail-end)]
    ;; §8a: enter/exit collapse clips for THIS first pass, same as the indexed driver
    ;; — so a collapsing cell isn't painted full-size for one frame before it wipes.
    (compute-clips! rs env geo-fn)
    (.-geometry! rs
      (r/SliverGeometry
       .scrollExtent total
       .paintExtent paint-extent
       ;; t≈0 the laid trail can exceed the final resting total; maxPaintExtent
       ;; must cover what we actually paint this pass.
       .maxPaintExtent (math/max total paint-extent)
       .cacheExtent cache-extent
       .hasVisualOverflow (or (> total paint-extent) (pos? (.-scrollOffset c)))))))

;; @ai-generated(solo)
(defn- attached-keys
  "Keys of the children ATTACHED right now — the genuinely on-screen set. Captured
   at segment start (before the driver materializes the new window) it is the
   `from`-visible set: the ground truth for which cells were on-screen before the
   change, unlike the persistent (stale-prone) committed map (docs §7c)."
  [^CollectionRenderSliver rs]
  (loop [child (.-firstChild rs) ks (transient #{})]
    (if child
      (let [^r/RenderBox ch child]
        (recur (.childAfter rs ch) (conj! ks (key-for rs (.indexOf rs ch)))))
      (persistent! ks))))

;; @ai-generated(solo)
(defn- segment-start!
  "First pass of a new segment (docs §4.1/§6). Freezes the OLD committed rects as
   the `from` side, captures the target from the NEW tree, builds the keyed
   segment tween and displays THIS pass at `from` (t≈0) so nothing jumps to target:
     a. fromRects := the OLD committed rects (this pass has not committed yet).
     b. fromExtent := the scroll extent reported last pass (read before overwrite).
     c. to-src := exact indexed math for an indexed target; for a flow target,
        run the flow driver so the inserted cells are created/measured at their
        natural target, then freeze that window as an index-addressed source.
     d. build the keyed tween; record segGen := curGen.
     e. display at `from`: the indexed driver over the tween (which also creates
        the new target window) for an indexed target; a manager-free relay for a
        flow target (its capture walk already drove the lifecycle once)."
  [^CollectionRenderSliver rs ^r/SliverConstraints c]
  (let [layout (.-layoutModel rs)
        indexed (some? (:geometry layout))
        ;; the layout's own enter/exit collapse axis (docs §8a/3c) — read
        ;; generically, no layout-name switch; drives both the gap frame and the
        ;; keyed tween's wipe.
        collapse-axis (or (:collapse-axis layout) :main)
        committed-from (committed-rects rs)                              ; (a)
        ;; the genuinely on-screen set BEFORE the driver rematerializes (old tree
        ;; still attached) — the ground-truth `from`-visible set (docs §7c)
        on-screen (attached-keys rs)
        ^double from-extent (if-let [^r/SliverGeometry g (.-geometry rs)] ; (b)
                              (.-scrollExtent g) 0.0)
        ;; §7a: each branch emits a PURE-NEW-DATA (live-only) frame source and the
        ;; universal collapse remap below wraps BOTH. Indexed = exact math over live
        ;; indices; flow = a live-only re-flow (`live-only-flow-window`) that drops
        ;; the dying cells and closes their gap so survivors glide up. Indexed is the
        ;; O(1) special case of flow.
        ;; Materialise the target window FIRST (both kinds), so every cell that will
        ;; be on-screen — arrivals included — is attached and can be measured for its
        ;; OLD size (§7c). Flow lays it via flow-layout!; indexed via indexed-layout!
        ;; on the plain target (widen-window! keeps leave-slides attached too). The
        ;; segAnchor reset makes this pass' scroll-correction a no-op (segAnchor is
        ;; rebuilt below); the first frame is then displayed by from-relay!.
        pure-live-src (if indexed
                        (do (.-segAnchor! rs nil)
                            (indexed-layout! rs layout c)
                            (tw/indexed-frame-source layout))
                        ;; The capture walk fills the SHADOW band, where dying cells
                        ;; still hold their full extent — extend it by the extent they
                        ;; will vacate (vacated-trailing-extent) so the pure-live `to`
                        ;; snapshot covers the FULL band and every replacement rising
                        ;; in from below is materialized in THIS frame, before the
                        ;; removal collapse plays, not after it.
                        (let [^double cap-ws (+ (.-scrollOffset c) (.-cacheOrigin c))
                              ^double cap-we (+ cap-ws (.-remainingCacheExtent c))
                              ^double extra (if (.-isFinite cap-we)
                                              (vacated-trailing-extent
                                               (into [] (keep #(get committed-from (:key %)))
                                                     (.-dyingSlots rs))
                                               cap-ws cap-we)
                                              0.0)
                              ^double ahead0 (.-overscanAhead rs)]
                          (.-overscanAhead! rs (+ ahead0 extra))
                          (flow-layout! rs layout c)
                          (.-overscanAhead! rs ahead0)
                          (tw/frozen-frame-source (live-only-flow-window rs layout c))))
        ;; WS3.2: the dying slots come from the host as a SPARSE, ascending-by-shadow-
        ;; index vector (built in the already-O(n) rebuild-shadow!), so the segment
        ;; never rebuilds an O(n) live/dying mask. Off-window dying slots are only an
        ;; index shift; the windowed source binary-searches them. Attach each slot's
        ;; committed rect (nil ⇒ gap-frame falls back) for the gap frames.
        ^int n (int (or (.-itemCount rs) 0))
        dying (mapv (fn [ds] {:index (int (:index ds))
                              :committed (get committed-from (:key ds))})
                    (.-dyingSlots rs))
        ;; survivors map to pure-new indices (glide up); dying slots present
        ;; zero-extent gaps (shrink in place).
        to-src (tw/windowed-shadow-frame-source pure-live-src n dying collapse-axis) ; (c)
        ;; §7b leave-slide frame lookup is over PURE-LIVE indices, but the attached
        ;; `cells` carry SHADOW indices (dying cells stay in-tree). Translate
        ;; shadow→pure-live = shadow − (dying slots before it); identity when nothing
        ;; is dying (the spaces coincide). Sparse binary search — no O(n) prefix scan.
        shadow->live (if (empty? dying)
                       identity
                       (fn [^int i] (- i (tw/dying-before dying i))))
        env (lay/make-env c (.-itemCount rs) (env-agg rs))
        ctx ((:prepare to-src) env)
        ;; §7c: `from` = committed ∪ edge slide for cells entering the viewport.
        ;; UNIVERSAL (flow + indexed): an entering cell has no committed rect, so
        ;; its `from` = its own frame slid to the near window edge (an arrive-slide),
        ;; the side chosen by index vs the on-screen committed span.
        ^double ws (+ (.-scrollOffset c) (.-cacheOrigin c))
        ^double we (+ ws (.-remainingCacheExtent c))
        fi ((:first-index to-src) env ctx ws)
        li (when (.-isFinite we) ((:last-index to-src) env ctx we))
        ;; §7c size morph: on a pure layout change (no concurrent data churn, so the
        ;; shadow index == old-data index) build ONE frame-source over the resting
        ;; layout; an off-screen cell arriving into the viewport is then given its OLD
        ;; frame (size + relative position) uniformly — indexed by math, flow by
        ;; dry-measure — and morphs instead of popping in at target.
        old-layout (.-prevLayout rs)
        old-src (when (and old-layout
                           (not= (:id old-layout) (:id layout))
                           (empty? (.-entering rs)) (empty? (.-exiting rs)))
                  (layout-frame-source rs old-layout))
        old-frame (when old-src
                    (let [octx ((:prepare old-src) env)
                          ofr (:frame old-src)]
                      (fn [^int i] (ofr env octx i))))
        from-rects (if (and fi li)
                     (tw/augment-from-edges
                      committed-from on-screen (.-entering rs) to-src env ctx #(key-for rs %)
                      (int fi) (int li) ws we old-frame)
                     committed-from)                                     ; (a')
        ;; Set-point anchor from the viewport-top INDEX SLOT captured at the last
        ;; resting pass (docs §9): fromSlot = its OLD content-space offset, toSlot =
        ;; its offset in the NEW target layout. Index-based ⇒ immune to which keys
        ;; shuffled where; nil when nothing was resting or the slot's target frame
        ;; is off the (flow) snapshot window ⇒ no correction this segment.
        resting (.-restingTop rs)
        seg-anchor (when resting
                     (let [^int raw (int (:idx resting))
                           ^int n (int (or (.-itemCount rs) 0))
                           ^int idx (if (pos? n)
                                      (math/max 0 (math/min raw (dec n)))
                                      (math/max 0 raw))
                           tgt ((:frame to-src) env ctx idx)]
                       (when tgt
                         (let [^double from-slot (double (:off resting))
                               ^double to-slot (double (:offset tgt))]
                           {:from from-slot :to to-slot
                            :screen (- from-slot (.-scrollOffset c))}))))
        ;; §7b: leave-slide `to`s. The segment's scroll set-point moves the
        ;; window by (to − from) at t=1; a cell whose target index falls outside
        ;; the UNION of the current and end-of-segment window spans is leaving —
        ;; its `to` = committed slid past the near END-window edge. Cells inside
        ;; the union are normal stay/arrive machinery (a cell the viewport
        ;; naturally scrolls away from must NOT be edge-dragged).
        ^double shift (if seg-anchor
                        (- (double (:to seg-anchor)) (double (:from seg-anchor)))
                        0.0)
        ^double end-ws (+ ws shift)
        ^double end-we (+ we shift)
        end-fi (or ((:first-index to-src) env ctx end-ws) fi)
        end-li (or (when (.-isFinite end-we) ((:last-index to-src) env ctx end-we)) li)
        ;; §7b leave morph: a leaving cell needs its TARGET size to morph as it
        ;; slides out — the SAME layout evaluation as the arrival side, just on the
        ;; NEW layout. The frozen `to-src` snapshot omits off-window cells, so use the
        ;; full layout-frame-source (indexed math / flow dry-measure of attached).
        leave-src (or (layout-frame-source rs layout) to-src)
        leaving (if (and fi li end-fi end-li)
                  (let [cells (loop [child (.-firstChild rs) out []]
                                (if child
                                  (let [^r/RenderBox ch child
                                        ^int i (.indexOf rs ch)]
                                    (recur (.childAfter rs ch)
                                           (conj out {:index i :key (key-for rs i)})))
                                  out))]
                    (tw/augment-to-edges committed-from cells (.-exiting rs)
                                         leave-src env ((:prepare leave-src) env)
                                         (math/min (int fi) (int end-fi))
                                         (math/max (int li) (int end-li))
                                         ws we end-ws end-we shadow->live))
                  {})
        seg-tween (tw/keyed-tween-layout                                 ; (d)
                   [:seg (.-curGen rs)] to-src from-rects from-extent (.-keyOf rs)
                   (fn [] (.-value ^a/Animation (.-tweenAnim rs)))
                   {:entering (.-entering rs) :exiting (.-exiting rs)
                    :leaving leaving :collapse-axis collapse-axis})]
    ;; consume the frozen resting layout — this segment has read the old sizes; a
    ;; later data-only segment must not re-read it (docs §7c).
    (.-prevLayout! rs nil)
    (.-fromRects! rs from-rects)
    (.-fromExtent! rs from-extent)
    (.-segTween! rs seg-tween)
    (.-segAnchor! rs seg-anchor)
    ;; seed the incremental set-point at desired(0) = from − screen (== the current
    ;; scrollOffset), so the first animating pass emits desired(t)−desired(0) with no
    ;; jump, and a retrigger mid-segment re-seeds against the live offset (§9).
    (.-segPrevDesired! rs (if seg-anchor
                            (- (double (:from seg-anchor)) (double (:screen seg-anchor)))
                            0.0))
    (.-leaving! rs leaving)
    (.-segGen! rs (.-curGen rs))
    ;; (e) display THIS pass at `from` (t≈0). The target window is already
    ;; materialised (above), so re-lay the attached children at the tween — uniform
    ;; for both target kinds; continue passes go through indexed-layout!(seg-tween).
    (from-relay! rs seg-tween c)))

;; ============================================================
;; Widget
;; ============================================================

(deftype CollectionSliverWidget
  [^w/SliverChildDelegate del
   ^w/Key? k
   layoutImpl   ;; PLAIN target layout map (never a pre-built tween)
   itemCount    ;; int? — nil = infinite
   ^a/Animation? tweenAnim  ;; non-nil while a segment plays
   ^int segGen  ;; host's segment generation, bumped once per segment
   entering     ;; set of keys wiping open this segment
   exiting      ;; set of keys wiping shut this segment
   keyOf        ;; (fn [^int i] -> key) | nil ⇒ animation key = the index
   ^bool fadeEnter  ;; fade entering cells with the collapse (default enter/exit fade)
   ^bool fadeExit   ;; fade exiting cells with the collapse
   approxSize   ;; approximate-item-size seed (double | ui/Size | nil) — cold prior for :avg-main/:avg-cross
   overscanConfig ;; normalized :overscan spec (render/resolve-overscan) — WS2 phase E
   dyingSlots]  ;; WS3.2: sparse [{:index :key} ...] dying slots for the window-scoped segment diff
  :extends (w/SliverMultiBoxAdaptorWidget .delegate del .key k)

  (createRenderObject [_this ^w/BuildContext context]
    (let [^w/SliverMultiBoxAdaptorElement element context
          rs (CollectionRenderSliver element layoutImpl itemCount -1.0 [] 0 nil nil nil keyOf {}
                                     segGen -1 {} 0.0 (or entering #{}) (or exiting #{}) {} nil nil 0.0 nil {}
                                     fadeEnter fadeExit nil approxSize nil {} false dc/double.nan false
                                     overscanConfig 0.0 0 dc/double.nan :resting 0.0 0.0 0
                                     false dc/double.nan 0 dc/double.nan (or dyingSlots []))]
      (set-tween-anim! rs tweenAnim)
      rs))

  (updateRenderObject [_this ^w/BuildContext _context render-object]
    (.-approxSize! ^CollectionRenderSliver render-object approxSize)
    (.-overscanConfig! ^CollectionRenderSliver render-object overscanConfig)
    (update-render! render-object layoutImpl itemCount tweenAnim segGen entering exiting keyOf
                    fadeEnter fadeExit dyingSlots)))

(defn ^w/Widget collection-sliver-widget
  "Creates the collection sliver from a builder, item count (nil = infinite),
   the PLAIN target layout map and options {:key :find-child-index :auto-keep-alive
   :repaint-boundaries :semantic-indexes :tween-anim :seg-gen :entering :exiting
   :key-of :fade-entering :fade-exiting :approximate-item-size :overscan
   :dying-slots}. :dying-slots is the host's sparse [{:index :key} ...] dying
   representation (an/shadow-dying-slots) the engine window-scopes the segment
   diff over (WS3.2).
   :overscan is the pre-normalized overscan spec (render/resolve-overscan) driving
   the velocity-scaled directional materialisation band (WS2 phase E).
   :approximate-item-size is the cold prior (double | ui/Size) seeding the engine's
   :avg-main/:avg-cross aggregates before any cell is measured (WS2.2 §1.1). :fade-entering/:fade-exiting fade the
   collapsing cells with the same window (the default enter/exit opacity), off when
   a custom builder owns that direction. The engine builds the segment tween itself:
   :tween-anim is the segment Animation, :seg-gen an int bumped once per segment
   (default 0), :entering/:exiting the enter/exit key sets (default empty)."
  [item-builder item-count layout-impl opts]
  (CollectionSliverWidget
   (w/SliverChildBuilderDelegate
    item-builder
    .childCount item-count
    .findChildIndexCallback (:find-child-index opts)
    .addAutomaticKeepAlives (boolean (:auto-keep-alive opts true))
    .addRepaintBoundaries (boolean (:repaint-boundaries opts true))
    .addSemanticIndexes (boolean (:semantic-indexes opts true)))
   (:key opts)
   layout-impl
   item-count
   (:tween-anim opts)
   (int (:seg-gen opts 0))
   (:entering opts #{})
   (:exiting opts #{})
   (:key-of opts)
   (boolean (:fade-entering opts))
   (boolean (:fade-exiting opts))
   (:approximate-item-size opts)
   (or (:overscan opts) (resolve-overscan nil))
   (or (:dying-slots opts) [])))
