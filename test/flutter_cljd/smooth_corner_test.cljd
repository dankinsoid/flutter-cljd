;; @ai-generated(guided)
(ns flutter-cljd.smooth-corner-test
  (:require [clojure.test :refer [deftest is testing]]
            [flutter-cljd.smooth-corner :as sc]
            [flutter-cljd.internal.clip-corners :as cc]
            [flutter-cljd.types :as t]
            ["package:flutter/material.dart" :as m]
            ["dart:ui" :as ui]))

(defn- approx? [^double a ^double b]
  (< (abs (- a b)) 0.001))

(deftest test-corners-parsing
  (testing "Number applies default smoothing to all corners"
    (let [corners (sc/corners 8)]
      (is (= 4 (count corners)))
      (doseq [[_ {:keys [radius smoothing]}] corners]
        (is (approx? 8.0 radius))
        (is (approx? @sc/default-smoothing smoothing)))))

  (testing "Top-level :smoothing overrides the default"
    (let [corners (sc/corners {:all 8 :smoothing 0.9})]
      (doseq [[_ {:keys [smoothing]}] corners]
        (is (approx? 0.9 smoothing)))))

  (testing "Per-corner map value"
    (let [corners (sc/corners {:top-left {:radius 4 :smoothing 0.2} :all 8})]
      (is (approx? 4.0 (get-in corners [:top-left :radius])))
      (is (approx? 0.2 (get-in corners [:top-left :smoothing])))
      (is (approx? 8.0 (get-in corners [:bottom-right :radius])))))

  (testing "{:radius :smoothing} as the whole spec"
    (let [corners (sc/corners {:radius 16 :smoothing 1})]
      (doseq [[_ {:keys [radius smoothing]}] corners]
        (is (approx? 16.0 radius))
        (is (approx? 1.0 smoothing)))))

  (testing "Negative radius keeps sign and drops smoothing"
    (let [{:keys [radius smoothing]} (:top-left (sc/corners -12))]
      (is (approx? -12.0 radius))
      (is (approx? 0.0 smoothing))))

  (testing "{:rel f} marks the corner as relative"
    (let [{:keys [radius relative?]} (:top-left (sc/corners {:rel 0.5}))]
      (is (approx? 0.5 radius))
      (is (true? relative?)))
    (let [corners (sc/corners {:top-left {:rel 0.3} :all 8})]
      (is (true? (get-in corners [:top-left :relative?])))
      (is (nil? (get-in corners [:top-right :relative?]))))))

(deftest test-needs-smooth-path
  (testing "Zero smoothing and non-negative radii fit an RRect"
    (is (not (sc/needs-smooth-path? (sc/corners {:all 8 :smoothing 0}))))
    (is (not (sc/needs-smooth-path? (sc/corners {:all 0})))))

  (testing "Smoothing or concave corners require a path"
    (is (sc/needs-smooth-path? (sc/corners 8)))
    (is (sc/needs-smooth-path? (sc/corners {:all 8 :smoothing 0 :top-left -4}))))

  (testing "Relative radii always require a path, even without smoothing"
    (is (sc/needs-smooth-path? (sc/corners {:rel 0.3 :smoothing 0})))))

(deftest test-corner-params
  (testing "Zero smoothing degenerates to a plain arc"
    (let [{:keys [radius p l a b c d]} (sc/corner-params {:radius 10.0 :smoothing 0.0} 100.0 100.0)]
      (is (approx? 10.0 radius))
      (is (approx? 10.0 p))
      (is (approx? 10.0 l))
      (is (approx? 0.0 a))
      (is (approx? 0.0 b))
      (is (approx? 0.0 c))
      (is (approx? 0.0 d))))

  (testing "p extends along the edge by (1 + smoothing) and clamps to half size"
    (is (approx? 16.0 (:p (sc/corner-params {:radius 10.0 :smoothing 0.6} 100.0 100.0))))
    (is (approx? 25.0 (:p (sc/corner-params {:radius 24.0 :smoothing 1.0} 50.0 100.0))))))

(deftest test-fit-corners
  (testing "Radii within limits pass through unchanged"
    (let [fitted (sc/fit-corners (sc/corners {:top-left 80 :all 0}) 100.0 100.0)]
      (is (approx? 80.0 (get-in fitted [:top-left :radius])))))

  (testing "Overflow shrinks all radii by one common factor (RRect semantics)"
    (let [fitted (sc/fit-corners (sc/corners {:top-left 150 :top-right 50 :all 0}) 100.0 100.0)]
      (is (approx? 75.0 (get-in fitted [:top-left :radius])))
      (is (approx? 25.0 (get-in fitted [:top-right :radius])))))

  (testing "Concave radii participate in side sums via absolute value"
    (let [fitted (sc/fit-corners (sc/corners {:top-left {:radius -80 :smoothing 0}
                                              :top-right 80
                                              :all 0})
                                 100.0 100.0)]
      (is (approx? -50.0 (get-in fitted [:top-left :radius])))
      (is (approx? 50.0 (get-in fitted [:top-right :radius])))))

  (testing "Capsule: uniform oversized radius shrinks to half the short side"
    (let [fitted (sc/fit-corners (sc/corners 999) 100.0 40.0)]
      (doseq [[_ {:keys [radius ext]}] fitted]
        (is (approx? 20.0 radius))
        ;; at the capsule limit the smoothing extension vanishes
        (is (approx? 0.0 ext)))))

  (testing "Smoothing extensions shrink proportionally into the side slack"
    (let [fitted (sc/fit-corners {:top-left {:radius 10.0 :smoothing 1.0}
                                  :top-right {:radius 85.0 :smoothing 0.0}
                                  :bottom-right {:radius 0.0 :smoothing 0.0}
                                  :bottom-left {:radius 0.0 :smoothing 0.0}}
                                 100.0 100.0)]
      ;; desired extension 10, top-side slack 100 − 10 − 85 = 5
      (is (approx? 5.0 (get-in fitted [:top-left :ext])))
      (is (approx? 0.0 (get-in fitted [:top-right :ext]))))))

(deftest test-smooth-path
  (testing "Path spans the whole rect"
    (doseq [corners [(sc/corners 16)
                     (sc/corners {:all 16 :smoothing 1})
                     (sc/corners -16)
                     (sc/corners {:top-left 16 :bottom-right -16 :all 8})]]
      (let [rect (ui/Rect.fromLTWH 10 20 100 60)
            bounds (.getBounds (sc/smooth-path rect corners))]
        (is (approx? 10.0 (.-left bounds)))
        (is (approx? 20.0 (.-top bounds)))
        (is (approx? 110.0 (.-right bounds)))
        (is (approx? 80.0 (.-bottom bounds))))))

  (testing "Convex corner cuts the rect corner"
    (let [path (sc/smooth-path (ui/Rect.fromLTWH 0 0 100 100) (sc/corners 20))]
      (is (.contains path (ui/Offset 50 50)))
      (is (not (.contains path (ui/Offset 1 1))))))

  (testing "Concave corner carves a quarter disc into the shape"
    (let [path (sc/smooth-path (ui/Rect.fromLTWH 0 0 100 100)
                               (sc/corners {:top-right -20 :all 0}))]
      (is (.contains path (ui/Offset 50 50)))
      ;; inside the carved quarter disc around (100, 0)
      (is (not (.contains path (ui/Offset 95 5))))
      ;; the other corners stay sharp
      (is (.contains path (ui/Offset 1 1)))))

  (testing "A single radius may exceed half the side when its neighbors leave room"
    (let [path (sc/smooth-path (ui/Rect.fromLTWH 0 0 100 100)
                               (sc/corners {:top-left 80 :all 0}))]
      ;; (15, 15) lies outside the r=80 arc but inside the old r=50 clamp
      (is (not (.contains path (ui/Offset 15 15))))
      (is (.contains path (ui/Offset 50 50)))
      ;; the rest of the outline is intact
      (is (.contains path (ui/Offset 99 99)))
      (let [bounds (.getBounds path)]
        (is (approx? 0.0 (.-left bounds)))
        (is (approx? 100.0 (.-right bounds))))))

  (testing "Relative radius resolves against the shorter side"
    ;; {:rel 0.5} on 100×40 → r = 20 = h/2 → capsule
    (let [path (sc/smooth-path (ui/Rect.fromLTWH 0 0 100 40)
                               (sc/corners {:rel 0.5 :smoothing 0}))]
      (is (not (.contains path (ui/Offset 3 3))))
      (is (.contains path (ui/Offset 50 20))))
    ;; negative relative radius carves a concave corner
    (let [path (sc/smooth-path (ui/Rect.fromLTWH 0 0 100 100)
                               (sc/corners {:top-right {:rel -0.2} :all 0}))]
      (is (not (.contains path (ui/Offset 95 5))))
      (is (.contains path (ui/Offset 50 50)))))

  (testing "Oversized uniform radius degrades into a capsule"
    (let [path (sc/smooth-path (ui/Rect.fromLTWH 0 0 100 40) (sc/corners 999))
          bounds (.getBounds path)]
      (is (approx? 0.0 (.-left bounds)))
      (is (approx? 100.0 (.-right bounds)))
      (is (approx? 40.0 (.-bottom bounds)))
      ;; capsule end cap: the point just inside the rect corner is cut away
      (is (not (.contains path (ui/Offset 3 3))))
      (is (.contains path (ui/Offset 50 20))))))

(deftest test-smooth-rectangle-border
  (testing "Lerp between smooth borders interpolates radii"
    (let [a (sc/smooth-rectangle-border 8)
          b (sc/smooth-rectangle-border 16)
          mid ^sc/SmoothRectangleBorder (.lerpFrom b a 0.5)]
      (is (approx? 12.0 (get-in (.-corners mid) [:top-left :radius])))))

  (testing "Value equality"
    (is (= (sc/smooth-rectangle-border 8) (sc/smooth-rectangle-border 8)))
    (is (not= (sc/smooth-rectangle-border 8) (sc/smooth-rectangle-border 9))))

  (testing "Relative corners lerp numerically, mixed modes switch halfway"
    (let [rel-a (sc/smooth-rectangle-border {:rel 0.2})
          rel-b (sc/smooth-rectangle-border {:rel 0.4})
          mid ^sc/SmoothRectangleBorder (.lerpFrom rel-b rel-a 0.5)]
      (is (approx? 0.3 (get-in (.-corners mid) [:top-left :radius])))
      (is (true? (get-in (.-corners mid) [:top-left :relative?]))))
    (let [abs (sc/smooth-rectangle-border 8)
          rel (sc/smooth-rectangle-border {:rel 0.5})
          early ^sc/SmoothRectangleBorder (.lerpFrom rel abs 0.25)
          late ^sc/SmoothRectangleBorder (.lerpFrom rel abs 0.75)]
      (is (approx? 8.0 (get-in (.-corners early) [:top-left :radius])))
      (is (nil? (get-in (.-corners early) [:top-left :relative?])))
      (is (approx? 0.5 (get-in (.-corners late) [:top-left :radius])))
      (is (true? (get-in (.-corners late) [:top-left :relative?]))))))

(deftest test-decoration-dispatch
  (testing "Rounded rectangle is smooth by default"
    (is (instance? sc/SmoothDecoration (t/decoration {:color :red :border-radius 8}))))

  (testing "Zero smoothing takes the BoxDecoration fast path"
    (is (instance? m/BoxDecoration (t/decoration {:color :red :border-radius {:all 8 :smoothing 0}}))))

  (testing "Ready-made BorderRadius bypasses smoothing"
    (is (instance? m/BoxDecoration
                   (t/decoration {:color :red :border-radius (m/BorderRadius.circular 8)}))))

  (testing "Negative radius forces the smooth decoration even without smoothing"
    (is (instance? sc/SmoothDecoration
                   (t/decoration {:color :red :border-radius {:all 8 :smoothing 0 :top-left -8}}))))

  (testing "Background blend mode follows the smooth outline"
    (let [dec (t/decoration {:color :red :border-radius 8
                             :background-blend-mode m/BlendMode.multiply})]
      (is (instance? sc/SmoothDecoration dec))
      (is (= m/BlendMode.multiply (.-blend-mode ^sc/SmoothDecoration dec)))))

  (testing "Image follows the smooth outline, even with a relative radius"
    (let [img (m/DecorationImage .image (m/NetworkImage "http://example.com/x.png"))
          dec (t/decoration {:border-radius {:rel 0.5} :image img})]
      (is (instance? sc/SmoothDecoration dec))
      (is (= img (.-image ^sc/SmoothDecoration dec)))))

  (testing "Non-uniform border still falls back to BoxDecoration"
    (is (instance? m/BoxDecoration
                   (t/decoration {:color :red :border-radius 8
                                  :border (m/Border .bottom (m/BorderSide .width 2))}))))

  (testing "Uniform border becomes the decoration side"
    (let [dec (t/decoration {:color :red :border-radius 8
                             :border (m/Border.all .color m/Colors.black .width 2)})]
      (is (instance? sc/SmoothDecoration dec))
      (is (approx? 2.0 (.-width ^m/BorderSide (.-side ^sc/SmoothDecoration dec))))))

  (testing "Smooth decoration hit test respects the outline"
    (let [dec ^m/Decoration (t/decoration {:color :red :border-radius {:all 20 :smoothing 1}})]
      (is (.hitTest dec (ui/Size 100 100) (ui/Offset 50 50)))
      (is (not (.hitTest dec (ui/Size 100 100) (ui/Offset 1 1))))))

  (testing "Smooth decorations lerp between each other"
    (let [a ^m/Decoration (t/decoration {:color :red :border-radius 8})
          b ^m/Decoration (t/decoration {:color :blue :border-radius 16})
          mid ^sc/SmoothDecoration (.lerpTo a b 0.5)]
      (is (approx? 12.0 (get-in (.-corners mid) [:top-left :radius])))))

  (testing "Value equality for repaint short-circuiting"
    (is (= (t/decoration {:color :red :border-radius 8})
           (t/decoration {:color :red :border-radius 8}))))

  (testing "Relative radius goes through the smooth decoration even without smoothing"
    (is (instance? sc/SmoothDecoration
                   (t/decoration {:color :red :border-radius {:rel 0.5 :smoothing 0}}))))

  (testing "Relative radius outside a smooth context fails loudly"
    (is (thrown? Exception (t/radius {:rel 0.5})))
    (is (thrown? Exception (t/border-radius {:rel 0.5}))))

  (testing "Image and blend mode survive a lerp round-trip"
    (let [img (m/DecorationImage .image (m/NetworkImage "http://example.com/x.png"))
          a ^m/Decoration (t/decoration {:border-radius 8 :image img
                                         :background-blend-mode m/BlendMode.multiply})
          b ^m/Decoration (t/decoration {:border-radius 16 :color :blue})
          early ^sc/SmoothDecoration (.lerpTo a b 0.25)
          late ^sc/SmoothDecoration (.lerpTo a b 0.75)]
      (is (= img (.-image early)))
      (is (= m/BlendMode.multiply (.-blend-mode early)))
      (is (nil? (.-image late)))
      (is (nil? (.-blend-mode late))))))

(deftest test-inset-shadows
  (testing "box-shadow normalizes a map into {:box :inset?}"
    (let [drop (t/box-shadow {:color :black :blur 4})
          inset (t/box-shadow {:color :black :blur 4 :inset true})]
      (is (instance? m/BoxShadow (:box drop)))
      (is (false? (:inset? drop)))
      (is (true? (:inset? inset)))
      (is (approx? 4.0 (.-blurRadius ^m/BoxShadow (:box inset))))))

  (testing "box-shadow passes a BoxShadow instance through as a drop shadow"
    (let [bs (m/BoxShadow .color (m/Color 0xFF000000) .blurRadius 6)
          norm (t/box-shadow bs)]
      (is (identical? bs (:box norm)))
      (is (false? (:inset? norm)))))

  (testing "An inset shadow forces the smooth decoration even without smoothing"
    (is (instance? sc/SmoothDecoration
                   (t/decoration {:color :red :border-radius {:all 8 :smoothing 0}
                                  :box-shadow [{:inset true :blur 4}]}))))

  (testing "An inset shadow forces the smooth decoration even without a radius"
    (let [dec (t/decoration {:color :red :box-shadow [{:inset true :blur 4}]})]
      (is (instance? sc/SmoothDecoration dec))
      (is (true? (:inset? (first (.-shadows ^sc/SmoothDecoration dec)))))))

  (testing "A drop shadow keeps the BoxDecoration fast path"
    (let [dec (t/decoration {:color :red :border-radius {:all 8 :smoothing 0}
                             :box-shadow [{:blur 4}]})]
      (is (instance? m/BoxDecoration dec))
      (is (= 1 (count (.-boxShadow ^m/BoxDecoration dec))))))

  (testing "Inset and drop shadows coexist in one decoration"
    (let [dec ^sc/SmoothDecoration (t/decoration {:color :red :border-radius 12
                                                  :box-shadow [{:blur 8} {:inset true :blur 4}]})
          shadows (.-shadows dec)]
      (is (= 2 (count shadows)))
      (is (false? (:inset? (first shadows))))
      (is (true? (:inset? (second shadows))))))

  (testing "Inset shadows are rejected on a circle"
    (is (thrown? Exception
                 (t/decoration {:shape :circle :color :red
                                :box-shadow [{:inset true :blur 4}]}))))

  (testing "Inset shadows survive a lerp round-trip"
    (let [a ^m/Decoration (t/decoration {:color :red :border-radius 8
                                         :box-shadow [{:inset true :blur 4}]})
          b ^m/Decoration (t/decoration {:color :blue :border-radius 8
                                         :box-shadow [{:inset true :blur 8}]})
          mid ^sc/SmoothDecoration (.lerpTo a b 0.5)]
      (is (true? (:inset? (first (.-shadows mid))))))))

(deftest test-clip-corners-dispatch
  (testing "Smooth corners clip with a path"
    (is (instance? m/ClipPath (cc/clip-corners* 8 nil)))
    (is (instance? m/ClipPath (cc/clip-corners* {:all 8 :smoothing 0 :top-left -8} nil))))

  (testing "Plain corners keep the cheaper ClipRRect"
    (is (instance? m/ClipRRect (cc/clip-corners* {:all 8 :smoothing 0} nil)))
    (is (instance? m/ClipRRect (cc/clip-corners* (m/BorderRadius.circular 8) nil))))

  (testing "Global default smoothing switches the fast path"
    (sc/set-default-smoothing! 0)
    (try
      (is (instance? m/ClipRRect (cc/clip-corners* 8 nil)))
      (is (instance? m/BoxDecoration (t/decoration {:color :red :border-radius 8})))
      (finally
        (sc/set-default-smoothing! 0.6)))))
