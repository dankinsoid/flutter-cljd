(ns flutter-cljd.internal.grid.sliver-test
  (:require [clojure.test :refer [deftest is testing]]
            ["package:flutter/rendering.dart" :as r]
            [flutter-cljd.internal.grid.opts :as o]
            [flutter-cljd.internal.grid.sliver :as sl]))

(defn- close? [a b] (< (.abs (double (- a b))) 1e-6))

(defn- ^r/SliverConstraints constraints
  [{:keys [cross main preceding] :or {preceding 0}}]
  (r/SliverConstraints
   .axisDirection r/AxisDirection.down
   .growthDirection r/GrowthDirection.forward
   .userScrollDirection r/ScrollDirection.idle
   .scrollOffset 0.0
   .precedingScrollExtent (double preceding)
   .overlap 0.0
   .remainingPaintExtent (double main)
   .crossAxisExtent (double cross)
   .crossAxisDirection r/AxisDirection.right
   .viewportMainAxisExtent (double main)
   .remainingCacheExtent (double main)
   .cacheOrigin 0.0))

(defn- env-for
  "Prepared engine env for a grid layout over `public-opts`."
  [public-opts ^int n cnstr]
  (let [normalized (o/scroll-normalize (o/parse public-opts) (:anchor public-opts))
        layout (sl/flex-grid-layout normalized)
        env {:constraints (constraints cnstr) :item-count n}]
    [layout (assoc env :ctx ((:prepare layout) env))]))

(defn- geo [public-opts n cnstr ^int i]
  (let [[layout env] (env-for public-opts n cnstr)]
    ((:geometry layout) env i)))

;; 7 items in 3 fixed-100 columns; 50-high rows with a 10 gap → 3 rows, content 170.
(def ^:private base
  {:columns {:count 3 :size 100} :rows {:size 50 :gap 10}})

(deftest cross-tracks
  (testing "fixed columns"
    (is (close? 0 (:cross (geo base 7 {:cross 300 :main 500} 0))))
    (is (close? 100 (:cross (geo base 7 {:cross 300 :main 500} 1))))
    (is (close? 200 (:cross (geo base 7 {:cross 300 :main 500} 2))))
    (is (close? 100 (:cross-extent (geo base 7 {:cross 300 :main 500} 1)))))
  (testing "flex columns share the cross extent"
    (let [opts (assoc base :columns {:count 3 :size :flex})]
      (is (close? 120 (:cross-extent (geo opts 7 {:cross 360 :main 500} 0))))
      (is (close? 240 (:cross (geo opts 7 {:cross 360 :main 500} 2))))))
  (testing "adaptive count from a :min size"
    (let [opts (assoc base :columns {:size {:min 90 :flex 1} :gap 10})]
      ;; (300+10)/(90+10) → 3 tracks of (300-20)/3
      (is (close? (/ 280.0 3) (:cross-extent (geo opts 7 {:cross 300 :main 500} 0))))))
  (testing "[:left :down] mirrors the track order (RTL)"
    (let [opts (assoc base :flow [:left :down])]
      (is (close? 200 (:cross (geo opts 7 {:cross 300 :main 500} 0))))
      (is (close? 0 (:cross (geo opts 7 {:cross 300 :main 500} 2)))))))

(deftest main-axis-rows
  (is (close? 0 (:offset (geo base 7 {:cross 300 :main 500} 2))))
  (is (close? 60 (:offset (geo base 7 {:cross 300 :main 500} 3))))
  (is (close? 120 (:offset (geo base 7 {:cross 300 :main 500} 6))))
  (is (close? 50 (:main-extent (geo base 7 {:cross 300 :main 500} 0)))))

(deftest content-mode
  (let [[layout env] (env-for base 7 {:cross 300 :main 500})]
    (testing "sliver extent is exactly the content"
      (is (close? 170 ((:max-extent layout) env 7))))
    (testing "row align/flex are inert without free space"
      (let [[l2 e2] (env-for (assoc base :rows {:size 50 :gap 10 :align :bottom})
                             7 {:cross 300 :main 500})]
        (is (close? 170 ((:max-extent l2) e2 7)))
        (is (close? 0 (:offset ((:geometry l2) e2 0))))))))

(deftest fill-mode
  (let [opts (assoc base :rows {:size 50 :gap 10 :fit :fill})]
    (testing "sliver claims the viewport space left after preceding slivers"
      (let [[layout env] (env-for opts 7 {:cross 300 :main 500})]
        (is (close? 500 ((:max-extent layout) env 7))))
      (let [[layout env] (env-for opts 7 {:cross 300 :main 500 :preceding 200})]
        (is (close? 300 ((:max-extent layout) env 7)))))
    (testing ":align :bottom pins the rows to the far edge of the claim"
      (let [opts (assoc opts :rows {:size 50 :gap 10 :fit :fill :align :bottom})]
        (is (close? 330 (:offset (geo opts 7 {:cross 300 :main 500} 0))))))
    (testing "overflowing content degrades to plain scrolling"
      (let [[layout env] (env-for opts 30 {:cross 300 :main 500})]
        ;; 10 rows → 590 > 500
        (is (close? 590 ((:max-extent layout) env 30)))))
    (testing "an empty :fill grid claims nothing"
      (let [[layout env] (env-for opts 0 {:cross 300 :main 500})]
        (is (close? 0 ((:max-extent layout) env 0)))))))

(deftest window-index-range
  (let [[layout env] (env-for base 7 {:cross 300 :main 500})]
    (is (= 0 ((:first-index layout) env 0.0)))
    (is (= 2 ((:last-index layout) env 0.0)))
    (is (= 3 ((:first-index layout) env 70.0)))
    (is (= 6 ((:last-index layout) env 130.0)))))

(deftest anchor-end-shape
  ;; 7 items, 3 columns, pad 2 → line 0 holds 1 item; reversed data order
  ;; is the caller's job (grid), the layout only pads and mirrors.
  (let [opts (assoc base :anchor :end)]
    (testing "first line is partial, the last exactly full"
      (let [[layout env] (env-for opts 7 {:cross 300 :main 500})]
        (is (= 0 ((:first-index layout) env 0.0)))
        (is (= 0 ((:last-index layout) env 0.0)))
        (is (= 4 ((:first-index layout) env 130.0)))
        (is (= 6 ((:last-index layout) env 130.0)))))
    (testing "partial line sits at the visual flow origin (left, via mirror)"
      ;; k=1, line-align flow-:end + fill mirror → leftmost track
      (is (close? 0 (:cross (geo opts 7 {:cross 300 :main 500} 0)))))))

(deftest infinite-count-is-rejected
  (let [normalized (o/scroll-normalize (o/parse base) nil)
        layout (sl/flex-grid-layout normalized)]
    (is (thrown? Exception
                 ((:prepare layout) {:constraints (constraints {:cross 300 :main 500})
                                     :item-count nil})))))
