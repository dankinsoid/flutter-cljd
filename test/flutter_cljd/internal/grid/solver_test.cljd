(ns flutter-cljd.internal.grid.solver-test
  (:require [clojure.test :refer [deftest is testing]]
            [flutter-cljd.internal.grid.solver :as s]))

(def ^:private inf ##Inf)

(defn- close? [a b] (< (.abs (double (- a b))) 1e-6))

(defn- spec
  "Compile a line-spec from terse options (track/gap/margin default 0-ish)."
  [{:keys [track gap margin align n] :or {gap 0 margin 0 n 3}}]
  (s/line-spec {:track track :gap gap :margin margin :align align :n n}))

(defn- line
  "solve-line as [lead size gap extent] for terse assertions."
  [available n opts]
  (let [r (s/solve-line available n (spec (assoc opts :n n)))]
    [(:lead r) (:size r) (:gap r) (:extent r)]))

(defn- line=? [[l sz g e] exp-l exp-sz exp-g exp-e]
  (and (close? l exp-l) (close? sz exp-sz) (close? g exp-g) (close? e exp-e)))

(deftest sizer-normalization
  (is (= {:min 80.0 :max 80.0 :flex 0.0} (s/sizer 80)))
  (is (= {:min 0.0 :max inf :flex 1.0} (s/sizer :flex)))
  (is (= {:min 8.0 :max 24.0 :flex 1.0} (s/sizer {:min 8 :max 24 :flex 1})))
  (is (= {:min 50.0 :max 50.0 :flex 0.0} (s/sizer {:fixed 50})))
  (is (= {:min 0.0 :max inf :flex 0.0} (s/sizer {})))
  (testing "extra keys pass through"
    (is (= 2.0 (:aspect (s/sizer {:aspect 2.0 :min 10})))))
  (is (thrown? Exception (s/sizer "nope"))))

(deftest fixed-tracks
  (testing "exact fit"
    (is (line=? (line 100.0 2 {:track 50}) 0 50 0 100)))
  (testing "fixed gap consumes space"
    (is (line=? (line 120.0 2 {:track 40 :gap 20}) 0 40 20 120)))
  (testing "margin pads both edges"
    (is (line=? (line 100.0 2 {:track 40 :margin 10}) 10 40 0 100))))

(deftest align-compiles-to-gaps
  (testing "leftover distributed per align, matching flex semantics"
    (is (line=? (line 100.0 2 {:track 40 :align :start}) 0 40 0 100))
    (is (line=? (line 100.0 2 {:track 40 :align :end}) 20 40 0 100))
    (is (line=? (line 100.0 2 {:track 40 :align :center}) 10 40 0 100))
    (is (line=? (line 100.0 2 {:track 40 :align :space-between}) 0 40 20 100))
    (is (line=? (line 100.0 2 {:track 40 :align :space-around}) 5 40 10 100))
    (is (line=? (line 100.0 2 {:track 40 :align :space-evenly}) (/ 20.0 3) 40 (/ 20.0 3) 100)))
  (testing "single track degenerate cases"
    (is (line=? (line 100.0 1 {:track 50 :align :center}) 25 50 0 100))
    (is (line=? (line 100.0 1 {:track 50 :align :space-between}) 0 50 0 100)))
  (testing "align composes with a fixed margin (grows from it)"
    (is (line=? (line 100.0 2 {:track 40 :margin 4 :align :center}) 10 40 0 100)))
  (testing "align composes with a constrained gap"
    ;; gap min 4 + space-between: the gap takes min first, then all the slack
    (is (line=? (line 100.0 2 {:track 40 :gap 4 :align :space-between}) 0 40 20 100)))
  (testing "custom align fn returns raw gap sizers"
    (is (line=? (line 100.0 2 {:track 40 :align (fn [_] {:lead {:flex 1} :trail 0})})
                20 40 0 100)))
  (is (thrown? Exception (line 100.0 2 {:track 40 :align :left}))))

(deftest flex-distribution
  (testing "equal and proportional splits"
    (is (line=? (line 100.0 2 {:track :flex}) 0 50 0 100))
    (is (line=? (line 90.0 3 {:track {:flex 2}}) 0 30 0 90)))
  (testing "flex grows above its :min floor"
    (is (line=? (line 100.0 2 {:track {:min 30 :flex 1}}) 0 50 0 100)))
  (testing "flex gap grows"
    (is (line=? (line 120.0 2 {:track 40 :gap {:flex 1}}) 0 40 40 120))))

(deftest align-is-second-tier
  (testing "flex tracks defeat alignment"
    (is (line=? (line 100.0 2 {:track :flex :align :center}) 0 50 0 100)))
  (testing "capped flex tracks leave the residual to alignment"
    (is (line=? (line 100.0 2 {:track {:flex 1 :max 30} :align :center}) 20 30 0 100)))
  (testing "explicit margin flex competes with tracks at tier 0"
    ;; margin flex 1 ×2 + track flex 1 ×2 → each gets 25 of the free 100
    (is (line=? (line 100.0 2 {:track {:flex 1} :margin {:flex 1} :align :center})
                25 25 0 100))))

(deftest overflow-and-shrink-wrap
  (testing "content exceeds available: sizes pinned at :min, extent reports overflow"
    (is (line=? (line 100.0 2 {:track 60}) 0 60 0 120)))
  (testing "unbounded available: flex collapses to :min, extent = content"
    (is (line=? (line inf 2 {:track {:min 40 :flex 1} :gap {:min 8 :flex 1}}) 0 40 8 88))
    (is (line=? (line inf 2 {:track 40 :margin 10}) 10 40 0 100))))

(deftest degenerate
  (is (line=? (line 100.0 0 {:track 30}) 0 0 0 100))
  (is (line=? (line inf 0 {:track 30}) 0 0 0 0)))

(deftest generic-matches-uniform
  ;; solve-line is the O(1) closed form of solve-line* on uniform inputs —
  ;; the two must agree exactly across every feature combination
  (doseq [[available n opts :as case]
          [[100.0 2 {:track 50}]
           [100.0 2 {:track 40 :align :end}]
           [100.0 2 {:track 40 :align :center}]
           [100.0 2 {:track 40 :align :space-between}]
           [100.0 3 {:track 20 :align :space-around}]
           [100.0 3 {:track 20 :align :space-evenly}]
           [100.0 3 {:track :flex}]
           [90.0 3 {:track {:flex 2}}]
           [100.0 2 {:track 20 :gap {:flex 1}}]
           [100.0 3 {:track {:min 10 :flex 1} :gap {:min 5}}]
           [100.0 2 {:track {:flex 1 :max 30} :gap {:min 8 :flex 1 :max 24} :align :center}]
           [100.0 2 {:track {:flex 1 :max 20} :gap {:flex 1}}]
           [100.0 2 {:track 40 :margin {:min 5} :align :center}]
           [100.0 3 {:track 60 :gap 10}]                          ;; overflow
           [inf 3 {:track {:min 40 :flex 1} :gap {:min 8 :flex 1}}] ;; shrink-wrap
           [100.0 1 {:track 30 :gap 10 :align :center}]
           [100.0 0 {:track 30 :gap 10}]]]
    (let [sp (spec (assoc opts :n n))
          u (s/solve-line available n sp)
          gen (s/solve-line* available (vec (repeat n (:track sp))) sp)
          stride (+ (double (:size u)) (double (:gap u)))]
      (is (close? (:extent u) (:extent gen)) (str case))
      (doseq [[i tr] (map-indexed vector (:tracks gen))]
        (is (close? (+ (double (:lead u)) (* i stride)) (:offset tr)) (str case " track " i))
        (is (close? (:size u) (:size tr)) (str case " track " i))))))

(deftest justify-distribution
  (is (= [0.0 0.0] (s/justify :start 60.0 2)))
  (is (= [60.0 0.0] (s/justify :end 60.0 2)))
  (is (= [30.0 0.0] (s/justify :center 60.0 2)))
  (is (= [0.0 60.0] (s/justify :space-between 60.0 2)))
  (is (= [15.0 30.0] (s/justify :space-around 60.0 2)))
  (is (= [20.0 20.0] (s/justify :space-evenly 60.0 2)))
  (is (= [0.0 0.0] (s/justify :center 0.0 2)))
  (testing "custom fn"
    (is (= [7.0 3.0] (s/justify (fn [_r _k] [7.0 3.0]) 60.0 2)))))

(deftest count-derivation
  (let [sp (fn [opts] (spec (assoc opts :n 0)))]
    (testing "explicit count wins"
      (is (= 4 (s/derive-count 300.0 (sp {:track 100}) 4 100))))
    (testing "as many tracks as fit their :min"
      (is (= 3 (s/derive-count 300.0 (sp {:track {:min 90 :flex 1} :gap 10}) nil 100)))
      (is (= 2 (s/derive-count 250.0 (sp {:track {:min 100}}) nil 100))))
    (testing "as few tracks as cover the extent at a finite :max"
      (is (= 3 (s/derive-count 250.0 (sp {:track {:max 100 :flex 1}}) nil 100))))
    (testing "edge margins reduce the space tracks can use"
      (is (= 2 (s/derive-count 300.0 (sp {:track {:min 90} :margin 60}) nil 100))))
    (testing "range clamps a derived count"
      (is (= 2 (s/derive-count 1000.0 (sp {:track {:min 100}}) {:max 2} 100)))
      (is (= 4 (s/derive-count 100.0 (sp {:track {:min 100}}) {:min 4} 100))))
    (testing "derived count is capped by the item count"
      (is (= 2 (s/derive-count 1000.0 (sp {:track {:min 100}}) nil 2))))
    (testing "count fn receives the context"
      (is (= 5 (s/derive-count 300.0 (sp {:track 10}) (fn [_ctx] 5) 100))))
    (testing "at least one track even when nothing fits"
      (is (= 1 (s/derive-count 50.0 (sp {:track {:min 100}}) nil 100))))
    (testing "unbounded axis falls back to :max, then item count, else throws"
      (is (= 4 (s/derive-count inf (sp {:track {:min 100}}) {:max 4} 100)))
      (is (= 7 (s/derive-count inf (sp {:track {:min 100}}) nil 7)))
      (is (thrown? Exception (s/derive-count inf (sp {:track {:min 100}}) nil nil))))
    (testing "underivable without a usable size"
      (is (thrown? Exception (s/derive-count 300.0 (sp {:track :flex}) nil 100))))))
