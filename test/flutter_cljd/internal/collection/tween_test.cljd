;; @ai-generated(solo)
(ns flutter-cljd.internal.collection.tween-test
  (:require [clojure.test :refer [deftest is testing]]
            ["dart:ui" :as ui]
            ["package:flutter/rendering.dart" :as r]
            [flutter-cljd.internal.collection.layout :as lay]
            [flutter-cljd.internal.collection.tween :as tw]))

(defn- close? [a b] (< (.abs (double (- a b))) 1e-6))

(defn- frame= [a b]
  (and (close? (:offset a) (:offset b))
       (close? (:cross a) (:cross b))
       (close? (:main-extent a) (:main-extent b))
       (close? (:cross-extent a) (:cross-extent b))))

(def ^:private base-env {:axis :vertical :cross-extent 200.0 :item-count 10})

(defn- fr [off cross me ce]
  {:offset (double off) :cross (double cross)
   :main-extent (double me) :cross-extent (double ce)})

(defn- with-ctx
  "Prepares a tween layout's per-pass ctx into env, as a driver would."
  [layout env]
  (assoc env :ctx ((:prepare layout) env)))

(defn- tween-geo [from-src to-src ^double t ^int i]
  (let [tl (tw/tween-layout [:test t] from-src to-src (fn [] t))]
    ((:geometry tl) (with-ctx tl base-env) i)))

(defn- tween-window [from-src to-src ^double t ^double ws ^double we]
  (let [tl (tw/tween-layout [:test t] from-src to-src (fn [] t))
        env (with-ctx tl base-env)]
    [((:first-index tl) env ws) ((:last-index tl) env we)]))

;; --- lerp-frame ---

(deftest lerp-frame-endpoints-and-mid
  (let [a (fr 0 0 100 200) b (fr 40 200 60 100)]
    (testing "endpoints are exact"
      (is (frame= a (tw/lerp-frame a b 0.0)))
      (is (frame= b (tw/lerp-frame a b 1.0))))
    (testing "midpoint lerps every component"
      (is (frame= (fr 20 100 80 150) (tw/lerp-frame a b 0.5))))
    (testing "a nil endpoint yields the side that has an opinion"
      (is (frame= b (tw/lerp-frame nil b 0.3)))
      (is (frame= a (tw/lerp-frame a nil 0.7))))))

;; --- frozen-frame-source window queries ---

(deftest frozen-source-windowing
  (let [src (tw/frozen-frame-source
             {:base 0 :extent 400.0
              :frames [(fr 0 0 100 200) (fr 100 0 100 200)
                       (fr 200 0 100 200) (fr 300 0 100 200)]})
        first-idx (:first-index src)
        last-idx (:last-index src)]
    (testing "frame lookup is by absolute index, nil outside the window"
      (is (frame= (fr 100 0 100 200) ((:frame src) base-env nil 1)))
      (is (nil? ((:frame src) base-env nil 9))))
    (testing "first-index: first frame still reaching past the offset"
      (is (= 0 (first-idx base-env nil 0.0)))
      (is (= 1 (first-idx base-env nil 150.0))))
    (testing "last-index: last frame starting before the offset"
      (is (= 2 (last-idx base-env nil 250.0)))
      (is (= 3 (last-idx base-env nil 999.0))))
    (testing "an offset past the snapshot yields no opinion (nil)"
      (is (nil? (first-idx base-env nil 500.0))))
    (testing "extent is the endpoint total"
      (is (close? 400.0 ((:extent src) base-env nil 10))))))

;; --- combinator: geometry endpoints exact (two frozen sources) ---

(deftest tween-geometry-endpoints-exact
  (let [from (tw/frozen-frame-source
              {:base 0 :extent 300.0
               :frames [(fr 0 0 100 200) (fr 100 0 100 200) (fr 200 0 100 200)]})
        to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 100 60 100) (fr 120 0 60 100)]})]
    (testing "t=0 is exactly the from source"
      (is (frame= (fr 100 0 100 200) (tween-geo from to 0.0 1))))
    (testing "t=1 is exactly the to source"
      (is (frame= (fr 60 100 60 100) (tween-geo from to 1.0 1))))
    (testing "t=0.5 lerps position and size together"
      (is (frame= (fr 80 50 80 150) (tween-geo from to 0.5 1))))))

;; --- combinator: union windowing ---

(deftest tween-union-window
  (let [a (tw/frozen-frame-source
           {:base 0 :extent 400.0
            :frames [(fr 0 0 100 200) (fr 100 0 100 200)
                     (fr 200 0 100 200) (fr 300 0 100 200)]})
        b (tw/frozen-frame-source
           {:base 0 :extent 360.0
            :frames [(fr 0 0 60 200) (fr 60 0 60 200) (fr 120 0 60 200)
                     (fr 180 0 60 200) (fr 240 0 60 200) (fr 300 0 60 200)]})]
    (testing "first-index is the min, last-index the max across both layouts"
      ;; ws=150: a→1, b→2 ; we=250: a→2, b→4
      (is (= [1 4] (tween-window a b 0.5 150.0 250.0))))
    (testing "the union holds regardless of progress"
      (is (= [1 4] (tween-window a b 0.0 150.0 250.0)))
      (is (= [1 4] (tween-window a b 1.0 150.0 250.0))))))

;; --- combinator: scroll extent lerps ---

(deftest tween-extent-lerps
  (let [a (tw/frozen-frame-source {:base 0 :extent 400.0 :frames [(fr 0 0 100 200)]})
        b (tw/frozen-frame-source {:base 0 :extent 360.0 :frames [(fr 0 0 60 200)]})
        ext (fn [^double t]
              (let [tl (tw/tween-layout [:e t] a b (fn [] t))]
                ((:max-extent tl) (with-ctx tl base-env) 10)))]
    (is (close? 400.0 (ext 0.0)))
    (is (close? 360.0 (ext 1.0)))
    (is (close? 380.0 (ext 0.5)))))

;; --- retarget: freezing the interpolated frame is jump-free ---

(deftest retarget-freeze-is-continuous
  (let [a (tw/frozen-frame-source
           {:base 0 :extent 300.0 :frames [(fr 0 0 100 200) (fr 100 0 100 200)]})
        b (tw/frozen-frame-source
           {:base 0 :extent 180.0 :frames [(fr 0 0 60 100) (fr 60 100 60 100)]})
        ;; interrupt at t=0.5 → capture the interpolated frame of index 1
        mid (tween-geo a b 0.5 1)
        ;; re-aim: the captured frame becomes the frozen `from` of a new tween
        frozen (tw/frozen-frame-source {:base 0 :extent 240.0 :frames [(fr 0 0 0 0) mid]})
        c (tw/frozen-frame-source
           {:base 0 :extent 120.0 :frames [(fr 0 0 40 80) (fr 40 0 40 80)]})]
    (testing "the new tween starts exactly where the old one was interrupted"
      (is (frame= mid (tween-geo frozen c 0.0 1))))
    (testing "and still lands exactly on the new target"
      (is (frame= (fr 40 0 40 80) (tween-geo frozen c 1.0 1))))))

;; --- flow projection: run a flow layout over measured sizes ---

(deftest flow-frames-projection
  (let [venv {:axis :vertical :cross-extent 300.0 :item-count 10}
        l (lay/list-layout {:spacing 10})
        sized [[0 (ui/Size 300 50)] [1 (ui/Size 300 80)] [2 (ui/Size 300 20)]]
        seed (tw/flow-seed-state l venv 0 0.0)
        frames (tw/flow-frames l venv sized seed)]
    (testing "list stacks with spacing, sizes captured from the measured boxes"
      (is (frame= (fr 0 0 50 300) (nth frames 0)))
      (is (frame= (fr 60 0 80 300) (nth frames 1)))
      (is (frame= (fr 150 0 20 300) (nth frames 2)))))
  (testing "a windowed seed anchors the first index at its offset"
    (let [venv {:axis :vertical :cross-extent 300.0 :item-count 10}
          l (lay/list-layout {:spacing 10})
          seed (tw/flow-seed-state l venv 7 500.0)
          frames (tw/flow-frames l venv [[7 (ui/Size 300 40)]] seed)]
      (is (close? 500.0 (:offset (nth frames 0)))))))

;; --- indexed source wraps a live layout ---

(defn- ^r/SliverConstraints sliver-constraints [^double cross ^double main]
  (r/SliverConstraints
   .axisDirection r/AxisDirection.down
   .growthDirection r/GrowthDirection.forward
   .userScrollDirection r/ScrollDirection.idle
   .scrollOffset 0.0
   .precedingScrollExtent 0.0
   .overlap 0.0
   .remainingPaintExtent main
   .crossAxisExtent cross
   .crossAxisDirection r/AxisDirection.right
   .viewportMainAxisExtent main
   .remainingCacheExtent main
   .cacheOrigin 0.0))

(deftest indexed-source-matches-layout
  (let [g (lay/resolve-layout :grid {:columns 3 :rows {:size 50}})
        genv (lay/make-env (sliver-constraints 300.0 600.0) 10)
        src (tw/indexed-frame-source g)
        ctx ((:prepare src) genv)]
    (testing "frame equals the layout's own geometry"
      (is (frame= ((:geometry g) (assoc genv :ctx ((:prepare g) genv)) 4)
                  ((:frame src) genv ctx 4))))
    (testing "window + extent pass through"
      (is (= 3 ((:first-index src) genv ctx 50.0)))
      (is (close? 200.0 ((:extent src) genv ctx 10))))))

;; --- scroll correction on the indexed/animating path (the v2 gotcha) ---
;;
;; The indexed driver writes geometry directly and never emits
;; scrollOffsetCorrection. When content above the viewport collapses while the
;; rect animator runs, the anchored child must stay put — the engine has to
;; follow it. anchor-delta is the pure core the driver calls.

(deftest anchor-delta-follows-collapsing-content
  (testing "content above the anchor is removed → viewport follows the anchor up"
    ;; anchor sits at old-off 100; 50px above it vanished so it now sits at 50.
    (is (close? -50.0
                (tw/anchor-delta [{:key :a :old-off 100.0 :old-main 40.0 :new-off 50.0}]
                                 100.0))))
  (testing "no movement → no correction"
    (is (nil? (tw/anchor-delta [{:key :a :old-off 100.0 :old-main 40.0 :new-off 100.0}]
                               100.0))))
  (testing "the topmost cell still overlapping scroll-off is the anchor"
    ;; scroll-off 120: cell :a (100..140) overlaps and is topmost; :b (140..) is below.
    ;; only :a's delta drives the correction, even though :b moved further.
    (is (close? 20.0
                (tw/anchor-delta [{:key :a :old-off 100.0 :old-main 40.0 :new-off 120.0}
                                  {:key :b :old-off 140.0 :old-main 40.0 :new-off 999.0}]
                                 120.0))))
  (testing "a cell entirely above scroll-off is not the anchor"
    ;; :a (0..40) ends before scroll-off 100; :b (100..140) is the anchor.
    (is (close? -30.0
                (tw/anchor-delta [{:key :a :old-off 0.0 :old-main 40.0 :new-off -999.0}
                                  {:key :b :old-off 100.0 :old-main 40.0 :new-off 70.0}]
                                 100.0))))
  (testing "nothing overlapping scroll-off → no anchor"
    (is (nil? (tw/anchor-delta [{:key :a :old-off 0.0 :old-main 40.0 :new-off 10.0}]
                               100.0)))))

;; set-point-correction drives scrollOffset so the captured viewport-top INDEX
;; SLOT tracks its lerped OLD→NEW position (docs §9). Index-based ⇒ immune to
;; which keys shuffled where; absolute per pass ⇒ converges without drift; and
;; self-nullifying when the slot doesn't move (plain shuffle).
(deftest set-point-correction-tracks-anchor-slot
  (testing "grid rescale: slot moves 100→140, correction lerps then converges"
    (let [anchor {:from 100.0 :to 140.0 :screen 0.0}]
      ;; t=0: desired = lerp(100,140,0) − 0 = 100 == scrollOffset0 → no jump
      (is (nil? (tw/set-point-correction anchor 0.0 100.0)))
      ;; t=0.5: desired = 120; scrollOffset still 100 → +20
      (is (close? 20.0 (tw/set-point-correction anchor 0.5 100.0)))
      ;; t=1: desired = 140; scrollOffset caught up to 120 → +20
      (is (close? 20.0 (tw/set-point-correction anchor 1.0 120.0)))
      ;; converged: scrollOffset already at the set-point → ≈0 → nil
      (is (nil? (tw/set-point-correction anchor 1.0 140.0)))))
  (testing "plain shuffle: slot does not move (from==to) → no correction at any t"
    (let [anchor {:from 100.0 :to 100.0 :screen 20.0}]
      ;; desired = 100 − 20 = 80 for every t; scrollOffset sits at 80 → nil
      (is (nil? (tw/set-point-correction anchor 0.0 80.0)))
      (is (nil? (tw/set-point-correction anchor 0.5 80.0)))
      (is (nil? (tw/set-point-correction anchor 1.0 80.0)))))
  (testing "screen offset: slot below the viewport top keeps t=0 jump-free"
    ;; slot's from=200 sits 50 below the viewport top (screen=50) at segment
    ;; start ⇒ scrollOffset0 = from − screen = 150.
    (is (nil? (tw/set-point-correction {:from 200.0 :to 260.0 :screen 50.0} 0.0 150.0)))
    ;; t=1: desired = 260 − 50 = 210; from scrollOffset 150 → +60
    (is (close? 60.0 (tw/set-point-correction {:from 200.0 :to 260.0 :screen 50.0} 1.0 150.0)))))

;; --- keyed combinator (v2): the `from` side is key-addressed ---

(defn- keyed-geo [to-src committed ^double from-extent key-of ^double t ^int i]
  (let [tl (tw/keyed-tween-layout [:k t] to-src committed from-extent key-of (fn [] t))]
    ((:geometry tl) (with-ctx tl base-env) i)))

(deftest keyed-tween-geometry-endpoints-exact
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 100 60 100) (fr 120 0 60 100)]})
        committed {:x (fr 100 0 100 200)}
        key-of (fn [^int _i] :x)]
    (testing "t=0 is exactly the committed rect for the key"
      (is (frame= (fr 100 0 100 200) (keyed-geo to committed 300.0 key-of 0.0 1))))
    (testing "t=1 is exactly the to frame"
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 300.0 key-of 1.0 1))))
    (testing "t=0.5 lerps committed -> to together"
      (is (frame= (fr 80 50 80 150) (keyed-geo to committed 300.0 key-of 0.5 1))))))

(deftest keyed-tween-no-history-appears-at-target
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 100 60 100) (fr 120 0 60 100)]})
        committed {}                        ; key :y has no committed rect
        key-of (fn [^int _i] :y)]
    (testing "a key with no history sits at its target at every t (no glide)"
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 200.0 key-of 0.0 1)))
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 200.0 key-of 0.4 1)))
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 200.0 key-of 1.0 1))))))

(deftest keyed-tween-from-follows-key-not-index
  ;; the shuffle property: two indices carry keys whose committed rects differ;
  ;; each index must lerp from ITS OWN key's rect, not from a per-index `from`.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 0 60 100)]})
        committed {:a (fr 200 0 100 200) :b (fr 400 0 40 80)}
        key-of (fn [^int i] (if (zero? i) :a :b))]
    (testing "index 0 lerps from key :a's rect"
      (is (frame= (fr 200 0 100 200) (keyed-geo to committed 300.0 key-of 0.0 0)))
      (is (frame= (fr 100 0 80 150) (keyed-geo to committed 300.0 key-of 0.5 0))))
    (testing "index 1 lerps from key :b's rect (different `from`)"
      (is (frame= (fr 400 0 40 80) (keyed-geo to committed 300.0 key-of 0.0 1)))
      (is (frame= (fr 230 0 50 90) (keyed-geo to committed 300.0 key-of 0.5 1))))))

(deftest keyed-tween-reindex-on-remove-glides-survivor-up
  ;; §7a root-cause guard. Data [a b c d] (offsets 0/50/100/150) removes the
  ;; MIDDLE `b`; the INDEXED target is built over the PURE NEW DATA [a c d]
  ;; (offsets 0/50/100) — no dying reinsert. Survivor `c` was at old index 2
  ;; (committed offset 100) and now maps to new index 1, whose target sits HIGHER
  ;; (smaller offset), so the cell glides up instead of committed==target — the
  ;; bug the dying reinsert used to cause.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
        committed {:a (fr 0 0 50 200) :c (fr 100 0 50 200) :d (fr 150 0 50 200)}
        key-of (fn [^int i] (nth [:a :c :d] i))]  ; new index space, `b` gone
    (testing "reindexed survivor's target is above its committed position"
      (let [c-target (:offset (keyed-geo to committed 300.0 key-of 1.0 1))]
        (is (< c-target (:offset (get committed :c))))  ; 50 < 100 → real slide-up
        (is (close? 50.0 c-target))))
    (testing "mid-glide the survivor is strictly between committed and target"
      (is (frame= (fr 75 0 50 200) (keyed-geo to committed 300.0 key-of 0.5 1))))
    (testing "the cell above the removal (a, index 0) does not move"
      (is (frame= (fr 0 0 50 200) (keyed-geo to committed 300.0 key-of 0.5 0))))))

(deftest keyed-tween-extent-lerps
  (let [to (tw/frozen-frame-source {:base 0 :extent 180.0 :frames [(fr 0 0 60 200)]})
        ext (fn [^double t]
              (let [tl (tw/keyed-tween-layout [:e t] to {} 400.0 (fn [^int _i] :z) (fn [] t))]
                ((:max-extent tl) (with-ctx tl base-env) 10)))]
    (testing "max-extent lerps from-extent -> to-src extent"
      (is (close? 400.0 (ext 0.0)))
      (is (close? 180.0 (ext 1.0)))
      (is (close? 290.0 (ext 0.5))))))

(deftest keyed-tween-retarget-continuous
  ;; Interrupt a keyed glide mid-flight, freeze the interpolated rect as the new
  ;; committed `from`, and re-aim at a fresh target — as the engine does when a
  ;; second data/layout change lands mid-segment. Must be jump-free: the new
  ;; segment starts exactly where the old was interrupted and still lands on the
  ;; new target. Distinct from `retarget-freeze-is-continuous`, which exercises
  ;; the index-addressed `tween-layout`; this one is the KEYED `from` path.
  (let [to1 (tw/frozen-frame-source
             {:base 0 :extent 180.0 :frames [(fr 0 0 60 100) (fr 60 100 60 100)]})
        committed0 {:x (fr 200 0 100 200)}
        key-of (fn [^int _i] :x)
        ;; interrupt index 1 at t=0.5 → interpolated rect
        mid (keyed-geo to1 committed0 300.0 key-of 0.5 1)
        ;; re-aim: the interpolated rect becomes the new committed `from`
        committed1 {:x mid}
        to2 (tw/frozen-frame-source
             {:base 0 :extent 120.0 :frames [(fr 0 0 40 80) (fr 40 0 40 80)]})]
    (testing "the re-aimed segment starts exactly at the interrupted rect"
      (is (frame= mid (keyed-geo to2 committed1 240.0 key-of 0.0 1))))
    (testing "and still lands exactly on the new target"
      (is (frame= (fr 40 0 40 80) (keyed-geo to2 committed1 240.0 key-of 1.0 1))))))

(deftest keyed-tween-windowing-passes-through-to-src
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 400.0
             :frames [(fr 0 0 100 200) (fr 100 0 100 200)
                      (fr 200 0 100 200) (fr 300 0 100 200)]})
        ;; committed rects far from the window must NOT widen it — windowing is to-src only
        committed {:a (fr 0 0 100 200) :b (fr 900 0 100 200)}
        key-of (fn [^int i] (if (even? i) :a :b))
        tl (tw/keyed-tween-layout [:w 0.5] to committed 300.0 key-of (fn [] 0.5))
        env (with-ctx tl base-env)]
    (testing "first/last-index equal the to-src's own window"
      (is (= 1 ((:first-index tl) env 150.0)))
      (is (= 2 ((:last-index tl) env 250.0))))))

;; --- keyed combinator (v2): enter/exit wipe (main-extent collapse) ---

(defn- keyed-geo* [to-src committed ^double from-extent key-of opts ^double t ^int i]
  (let [tl (tw/keyed-tween-layout [:k t] to-src committed from-extent key-of (fn [] t) opts)]
    ((:geometry tl) (with-ctx tl base-env) i)))

(deftest keyed-tween-entering-key-wipes-open
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        key-of (fn [^int _i] :n)]
    (testing "t=0: main-extent 0 at the target offset/cross (no committed history)"
      (is (frame= (fr 40 20 0 100) (keyed-geo* to {} 180.0 key-of {:entering #{:n}} 0.0 0))))
    (testing "t=0.5: half-open at the target position"
      (is (frame= (fr 40 20 30 100) (keyed-geo* to {} 180.0 key-of {:entering #{:n}} 0.5 0))))
    (testing "t=1: full target frame"
      (is (frame= (fr 40 20 60 100) (keyed-geo* to {} 180.0 key-of {:entering #{:n}} 1.0 0))))))

(deftest keyed-tween-exiting-key-wipes-shut
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:d (fr 40 20 60 100)}
        key-of (fn [^int _i] :d)]
    (testing "t=0: natural committed rect"
      (is (frame= (fr 40 20 60 100) (keyed-geo* to committed 180.0 key-of {:exiting #{:d}} 0.0 0))))
    (testing "t=1: main-extent 0, offset/cross unchanged (collapses in place)"
      (is (frame= (fr 40 20 0 100) (keyed-geo* to committed 180.0 key-of {:exiting #{:d}} 1.0 0))))))

(deftest keyed-tween-normal-key-unaffected-by-enter-exit-opts
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 0 0 60 100) (fr 60 0 60 100)]})
        committed {:m (fr 200 0 100 200) :n (fr 400 0 40 80)}
        key-of (fn [^int i] (if (zero? i) :m :n))
        ;; :n is entering; index 0 carries the normal key :m and must lerp committed->to
        opts {:entering #{:n}}]
    (testing "the normal key still lerps its committed rect -> target"
      (is (frame= (fr 200 0 100 200) (keyed-geo* to committed 300.0 key-of opts 0.0 0)))
      (is (frame= (fr 100 0 80 150) (keyed-geo* to committed 300.0 key-of opts 0.5 0)))
      (is (frame= (fr 0 0 60 100) (keyed-geo* to committed 300.0 key-of opts 1.0 0))))))

;; --- §8a: lay-at (:full-main-extent) decoupled from visible (:main-extent) ---

(deftest full-main-extent-decouples-lay-at-from-visible
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:x (fr 40 20 60 100)}]
    (testing "entering: full == target, visible == target*progress"
      (let [g (keyed-geo* to {} 180.0 (fn [^int _i] :x) {:entering #{:x}} 0.25 0)]
        (is (close? 60.0 (:full-main-extent g)))
        (is (close? 15.0 (:main-extent g)))))
    (testing "exiting: full == committed, visible == committed*(1-progress)"
      (let [g (keyed-geo* to committed 180.0 (fn [^int _i] :x) {:exiting #{:x}} 0.25 0)]
        (is (close? 60.0 (:full-main-extent g)))
        (is (close? 45.0 (:main-extent g)))))
    (testing "stay: full == visible (a size-morphing stay reflows, no clip)"
      (let [g (keyed-geo* to {:x (fr 0 20 100 100)} 180.0 (fn [^int _i] :x) {} 0.5 0)]
        (is (close? 80.0 (:main-extent g)))          ; lerp(100, 60, 0.5)
        (is (close? (:main-extent g) (:full-main-extent g)))))))

;; --- §7c: from = committed ∪ old-layout math (viewport-entering cells glide) ---

(deftest augment-from-rects-glides-entering-cell
  ;; A cell below the old viewport lands inside the new one on a layout change and
  ;; has NO committed rect. augment-from-rects must give it its OLD-layout frame (a
  ;; real off-screen offset), NOT its target — so it glides in instead of popping.
  (let [prev (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 100}))
        committed {:a (fr 0 0 100 200)}          ; only index 0 was on-screen
        key-of (fn [^int i] (nth [:a :b :c :d :e] i))
        env (assoc base-env :item-count 5)
        result (tw/augment-from-rects committed prev env key-of 0 4)]
    (testing "the committed (on-screen) key keeps its committed rect"
      (is (frame= (fr 0 0 100 200) (get result :a))))
    (testing "an off-screen entering key gets its OLD-layout frame, not target"
      ;; index 4 sat at old offset 400 under the 100px list — a real off-screen from
      (is (close? 400.0 (:offset (get result :e))))
      (is (close? 100.0 (:main-extent (get result :e)))))
    (testing "every window index now has a from (glide, not pop)"
      (is (= #{:a :b :c :d :e} (set (keys result)))))))

;; --- §7a shared core: classify-cell / shadow-frame-source / slide-out-frame ---

(deftest classify-cell-matrix
  (testing "removed from data → exit-collapse regardless of window"
    (is (= :exit-collapse (tw/classify-cell true false true true)))
    (is (= :exit-collapse (tw/classify-cell true false false false))))
  (testing "joined the data → enter-collapse"
    (is (= :enter-collapse (tw/classify-cell false true true false)))
    (is (= :enter-collapse (tw/classify-cell false true true true))))
  (testing "in both, target visible, from visible → stay-glide"
    (is (= :stay-glide (tw/classify-cell true true true true))))
  (testing "in both, target visible, from off-screen → arrive-slide"
    (is (= :arrive-slide (tw/classify-cell true true true false))))
  (testing "in both, target off-screen, from visible → leave-slide"
    (is (= :leave-slide (tw/classify-cell true true false true)))))

(deftest shadow-frame-source-collapse-remap
  ;; Data [a b c d] (indexed list, extent 50 → old offsets 0/50/100/150) removes
  ;; the MIDDLE `b`. The shadow order keeps b in-tree as a dying slot; the pure
  ;; new data is [a c d]. Survivors must map to the compacted pure-new indices
  ;; (glide UP) and the dying slot must reserve zero extent at the gap.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
        entries [{:type :live :key :a}
                 {:type :dying :key :b :committed (fr 50 0 50 200)}
                 {:type :live :key :c}
                 {:type :live :key :d}]
        src (tw/shadow-frame-source to entries)
        env (assoc base-env :item-count 4)
        ctx ((:prepare src) env)
        frame (fn [^int i] ((:frame src) env ctx i))]
    (testing "live survivors map to pure-new-data indices (compacted, higher up)"
      (is (close? 0.0 (:offset (frame 0))))     ; a → d0 → 0
      (is (close? 50.0 (:offset (frame 2))))    ; c → d1 → 50 (was committed 100)
      (is (close? 100.0 (:offset (frame 3)))))  ; d → d2 → 100 (was committed 150)
    (testing "survivor frames sit HIGHER (smaller offset) than committed"
      (is (< (:offset (frame 2)) 100.0))        ; c new 50 < old 100
      (is (< (:offset (frame 3)) 150.0)))       ; d new 100 < old 150
    (testing "dying slot is a zero-extent gap at the next survivor's new offset"
      (let [g (frame 1)]
        (is (close? 50.0 (:offset g)))          ; == c's new offset (gap closes here)
        (is (close? 0.0 (:main-extent g)))      ; zero reserved extent to survivors
        (is (close? 0.0 (:cross g)))            ; from the dying cell's committed rect
        (is (close? 200.0 (:cross-extent g)))))
    (testing "extent is the pure-new (live) total, not the inflated shadow count"
      (is (close? 150.0 ((:extent src) env ctx 4))))   ; 3 live × 50
    (testing "first-index answers in shadow space, widening over the dying slot"
      (is (= 0 ((:first-index src) env ctx 40.0)))     ; window at a → shadow 0
      (is (= 1 ((:first-index src) env ctx 60.0)))))   ; window at c → include dying b (shadow 1)
  (testing "a dying cell trailing all survivors gaps to the pure-new total extent"
    (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
          entries [{:type :live :key :a}
                   {:type :live :key :b}
                   {:type :dying :key :c :committed (fr 100 0 50 200)}]
          src (tw/shadow-frame-source to entries)
          env (assoc base-env :item-count 3)
          ctx ((:prepare src) env)]
      (is (close? 100.0 (:offset ((:frame src) env ctx 2)))))))  ; live total = 2×50

(deftest slide-out-frame-clamps-to-edge
  (let [rect (fr 100 10 20 50)]
    (testing ":leading slides fully above ws, extent & cross unchanged"
      (is (frame= (fr -20 10 20 50) (tw/slide-out-frame rect 0.0 200.0 :leading))))
    (testing ":trailing slides fully below we, extent & cross unchanged"
      (is (frame= (fr 200 10 20 50) (tw/slide-out-frame rect 0.0 200.0 :trailing))))))

(deftest tween-between-two-grids-endpoints-exact
  (let [g2 (lay/resolve-layout :grid {:columns 2 :rows {:size 50}})
        g3 (lay/resolve-layout :grid {:columns 3 :rows {:size 50}})
        genv (lay/make-env (sliver-constraints 300.0 600.0) 10)
        from (tw/indexed-frame-source g2)
        to (tw/indexed-frame-source g3)
        geo-at (fn [^double t ^int i]
                 (let [tl (tw/tween-layout [:g t] from to (fn [] t))]
                   ((:geometry tl) (assoc genv :ctx ((:prepare tl) genv)) i)))
        g2-geo (fn [^int i] ((:geometry g2) (assoc genv :ctx ((:prepare g2) genv)) i))
        g3-geo (fn [^int i] ((:geometry g3) (assoc genv :ctx ((:prepare g3) genv)) i))]
    (testing "indexed×indexed morph is exact at both endpoints"
      (is (frame= (g2-geo 4) (geo-at 0.0 4)))
      (is (frame= (g3-geo 4) (geo-at 1.0 4))))))
