;; @ai-generated(solo)
(ns flutter-cljd.internal.collection.tween-test
  (:require [clojure.test :refer [deftest is testing]]
            ["dart:ui" :as ui]
            ["package:flutter/rendering.dart" :as r]
            [flutter-cljd.internal.collection.layout :as lay]
            [flutter-cljd.internal.collection.tween :as tw]))

(defn- close? [a b] (< (.abs (double (- a b))) 1e-6))

(defn- frame= [a b]
  (and (close? (:offset a) (:offset b))
       (close? (:cross a) (:cross b))
       (close? (:main-extent a) (:main-extent b))
       (close? (:cross-extent a) (:cross-extent b))))

(def ^:private base-env {:axis :vertical :cross-extent 200.0 :item-count 10})

(defn- fr [off cross me ce]
  {:offset (double off) :cross (double cross)
   :main-extent (double me) :cross-extent (double ce)})

(defn- with-ctx
  "Prepares a tween layout's per-pass ctx into env, as a driver would."
  [layout env]
  (assoc env :ctx ((:prepare layout) env)))

;; --- lerp-frame ---

(deftest lerp-frame-endpoints-and-mid
  (let [a (fr 0 0 100 200) b (fr 40 200 60 100)]
    (testing "endpoints are exact"
      (is (frame= a (tw/lerp-frame a b 0.0)))
      (is (frame= b (tw/lerp-frame a b 1.0))))
    (testing "midpoint lerps every component"
      (is (frame= (fr 20 100 80 150) (tw/lerp-frame a b 0.5))))
    (testing "a nil endpoint yields the side that has an opinion"
      (is (frame= b (tw/lerp-frame nil b 0.3)))
      (is (frame= a (tw/lerp-frame a nil 0.7))))))

;; --- frozen-frame-source window queries ---

(deftest frozen-source-windowing
  (let [src (tw/frozen-frame-source
             {:base 0 :extent 400.0
              :frames [(fr 0 0 100 200) (fr 100 0 100 200)
                       (fr 200 0 100 200) (fr 300 0 100 200)]})
        first-idx (:first-index src)
        last-idx (:last-index src)]
    (testing "frame lookup is by absolute index, nil outside the window"
      (is (frame= (fr 100 0 100 200) ((:frame src) base-env nil 1)))
      (is (nil? ((:frame src) base-env nil 9))))
    (testing "first-index: first frame still reaching past the offset"
      (is (= 0 (first-idx base-env nil 0.0)))
      (is (= 1 (first-idx base-env nil 150.0))))
    (testing "last-index: last frame starting before the offset"
      (is (= 2 (last-idx base-env nil 250.0)))
      (is (= 3 (last-idx base-env nil 999.0))))
    (testing "an offset past the snapshot yields no opinion (nil)"
      (is (nil? (first-idx base-env nil 500.0))))
    (testing "extent is the endpoint total"
      (is (close? 400.0 ((:extent src) base-env nil 10))))))

;; --- flow projection: run a flow layout over measured sizes ---

(deftest flow-frames-projection
  (let [venv {:axis :vertical :cross-extent 300.0 :item-count 10}
        l (lay/list-layout {:spacing 10})
        sized [[0 (ui/Size 300 50)] [1 (ui/Size 300 80)] [2 (ui/Size 300 20)]]
        seed (tw/flow-seed-state l venv 0 0.0)
        frames (tw/flow-frames l venv sized seed)]
    (testing "list stacks with spacing, sizes captured from the measured boxes"
      (is (frame= (fr 0 0 50 300) (nth frames 0)))
      (is (frame= (fr 60 0 80 300) (nth frames 1)))
      (is (frame= (fr 150 0 20 300) (nth frames 2)))))
  (testing "a windowed seed anchors the first index at its offset"
    (let [venv {:axis :vertical :cross-extent 300.0 :item-count 10}
          l (lay/list-layout {:spacing 10})
          seed (tw/flow-seed-state l venv 7 500.0)
          frames (tw/flow-frames l venv [[7 (ui/Size 300 40)]] seed)]
      (is (close? 500.0 (:offset (nth frames 0)))))))

;; --- indexed source wraps a live layout ---

(defn- ^r/SliverConstraints sliver-constraints [^double cross ^double main]
  (r/SliverConstraints
   .axisDirection r/AxisDirection.down
   .growthDirection r/GrowthDirection.forward
   .userScrollDirection r/ScrollDirection.idle
   .scrollOffset 0.0
   .precedingScrollExtent 0.0
   .overlap 0.0
   .remainingPaintExtent main
   .crossAxisExtent cross
   .crossAxisDirection r/AxisDirection.right
   .viewportMainAxisExtent main
   .remainingCacheExtent main
   .cacheOrigin 0.0))

(deftest indexed-source-matches-layout
  (let [g (lay/resolve-layout :grid {:columns 3 :rows {:size 50}})
        genv (lay/make-env (sliver-constraints 300.0 600.0) 10)
        src (tw/indexed-frame-source g)
        ctx ((:prepare src) genv)]
    (testing "frame equals the layout's own geometry"
      (is (frame= ((:geometry g) (assoc genv :ctx ((:prepare g) genv)) 4)
                  ((:frame src) genv ctx 4))))
    (testing "window + extent pass through"
      (is (= 3 ((:first-index src) genv ctx 50.0)))
      (is (close? 200.0 ((:extent src) genv ctx 10))))))

;; point-correction-delta drives scrollOffset so the captured viewport-top INDEX
;; SLOT tracks its lerped OLD→NEW position (docs §9). Index-based ⇒ immune to which
;; keys shuffled where; INCREMENTAL per pass (emits desired(t) − prev-desired) ⇒ the
;; animation delta composes with user drag instead of reverting it, and the emitted
;; deltas telescope to exactly to − from; self-nullifying when the slot doesn't move.
;;
;; `seed`: prev-desired starts at desired(0) = from − screen (== segment-start
;; scrollOffset). Each call returns [correction new-prev-desired]; the render sliver
;; feeds new-prev-desired back in next pass.
(deftest point-correction-delta-tracks-anchor-slot
  (let [seed (fn [{:keys [from screen]}] (- (double from) (double screen)))]
    (testing "grid rescale: slot moves 100→140, per-pass deltas telescope to to−from"
      (let [anchor {:from 100.0 :to 140.0 :screen 0.0}
            p0 (seed anchor)]                         ; desired(0) = 100
        ;; t=0: desired = 100 == prev → no jump, prev unchanged
        (let [[c p] (tw/point-correction-delta anchor 0.0 p0)]
          (is (nil? c)) (is (close? 100.0 p))
          ;; t=0.5: desired = 120 → +20, prev advances to 120
          (let [[c p] (tw/point-correction-delta anchor 0.5 p)]
            (is (close? 20.0 c)) (is (close? 120.0 p))
            ;; t=1: desired = 140 → +20, prev advances to 140
            (let [[c p] (tw/point-correction-delta anchor 1.0 p)]
              (is (close? 20.0 c)) (is (close? 140.0 p))
              ;; sum of emitted deltas == to − from == 40
              (is (close? 40.0 (- (double p) p0))))))))
    (testing "delta ignores the live offset ⇒ a user drag between passes survives"
      ;; prev-desired is the ONLY state; the live scrollOffset never enters the math,
      ;; so whatever the user dragged to is untouched — the pass adds only +20.
      (let [anchor {:from 100.0 :to 140.0 :screen 0.0}
            [c _] (tw/point-correction-delta anchor 0.5 100.0)]
        (is (close? 20.0 c))
        ;; identical result regardless of any drag the user applied to scrollOffset
        (is (= c (first (tw/point-correction-delta anchor 0.5 100.0))))))
    (testing "same-t re-layout (post-correction re-run) emits 0"
      ;; after emitting the t=0.5 delta prev==120; re-running at the SAME t must be 0
      ;; so the viewport layout converges within the frame.
      (let [anchor {:from 100.0 :to 140.0 :screen 0.0}
            [_ p] (tw/point-correction-delta anchor 0.5 (seed anchor))
            [c p2] (tw/point-correction-delta anchor 0.5 p)]
        (is (nil? c)) (is (close? 120.0 p2))))
    (testing "retrigger mid-segment: re-seed against the live offset ⇒ no jump"
      ;; a new segment-start! re-seeds prev = new-from − new-screen; the first pass at
      ;; the fresh t=0 must emit nil (no jump) then track the new endpoints.
      (let [anchor {:from 130.0 :to 90.0 :screen 10.0}   ; live scrollOffset now 120
            p0 (seed anchor)]                             ; desired(0) = 120
        (is (close? 120.0 p0))
        (let [[c p] (tw/point-correction-delta anchor 0.0 p0)]
          (is (nil? c)) (is (close? 120.0 p))
          (let [[c p] (tw/point-correction-delta anchor 1.0 p)]
            ;; desired(1) = 90 − 10 = 80 → −40, telescopes to to − from = −40
            (is (close? -40.0 c)) (is (close? 80.0 p))))))
    (testing "plain shuffle: slot does not move (from==to) → no correction at any t"
      (let [anchor {:from 100.0 :to 100.0 :screen 20.0}
            p (seed anchor)]                              ; desired = 80 for every t
        (is (nil? (first (tw/point-correction-delta anchor 0.0 p))))
        (is (nil? (first (tw/point-correction-delta anchor 0.5 p))))
        (is (nil? (first (tw/point-correction-delta anchor 1.0 p))))))
    (testing "sub-threshold deltas are retained, not dropped ⇒ no drift"
      ;; a tiny per-pass step (< 1e-3) emits nil and keeps prev, so it accumulates and
      ;; eventually crosses the threshold rather than being silently lost.
      (let [anchor {:from 0.0 :to 1.0 :screen 0.0}       ; to−from = 1 over the segment
            p0 (seed anchor)                              ; 0.0
            ;; a 0.0005 step (< 1e-3): nil, prev held at 0
            [c p] (tw/point-correction-delta anchor 0.0005 p0)]
        (is (nil? c)) (is (close? 0.0 p))
        ;; next pass reaches 0.002 total: delta from held prev = 0.002 > 1e-3 → emits
        (let [[c p] (tw/point-correction-delta anchor 0.002 p)]
          (is (close? 0.002 c)) (is (close? 0.002 p)))))))

;; --- keyed combinator (v2): the `from` side is key-addressed ---

(defn- keyed-geo [to-src committed ^double from-extent key-of ^double t ^int i]
  (let [tl (tw/keyed-tween-layout [:k t] to-src committed from-extent key-of (fn [] t))]
    ((:geometry tl) (with-ctx tl base-env) i)))

(deftest keyed-tween-geometry-endpoints-exact
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 100 60 100) (fr 120 0 60 100)]})
        committed {:x (fr 100 0 100 200)}
        key-of (fn [^int _i] :x)]
    (testing "t=0 is exactly the committed rect for the key"
      (is (frame= (fr 100 0 100 200) (keyed-geo to committed 300.0 key-of 0.0 1))))
    (testing "t=1 is exactly the to frame"
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 300.0 key-of 1.0 1))))
    (testing "t=0.5 lerps committed -> to together"
      (is (frame= (fr 80 50 80 150) (keyed-geo to committed 300.0 key-of 0.5 1))))))

(deftest keyed-tween-no-history-appears-at-target
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 100 60 100) (fr 120 0 60 100)]})
        committed {}                        ; key :y has no committed rect
        key-of (fn [^int _i] :y)]
    (testing "a key with no history sits at its target at every t (no glide)"
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 200.0 key-of 0.0 1)))
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 200.0 key-of 0.4 1)))
      (is (frame= (fr 60 100 60 100) (keyed-geo to committed 200.0 key-of 1.0 1))))))

(deftest keyed-tween-from-follows-key-not-index
  ;; the shuffle property: two indices carry keys whose committed rects differ;
  ;; each index must lerp from ITS OWN key's rect, not from a per-index `from`.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0
             :frames [(fr 0 0 60 100) (fr 60 0 60 100)]})
        committed {:a (fr 200 0 100 200) :b (fr 400 0 40 80)}
        key-of (fn [^int i] (if (zero? i) :a :b))]
    (testing "index 0 lerps from key :a's rect"
      (is (frame= (fr 200 0 100 200) (keyed-geo to committed 300.0 key-of 0.0 0)))
      (is (frame= (fr 100 0 80 150) (keyed-geo to committed 300.0 key-of 0.5 0))))
    (testing "index 1 lerps from key :b's rect (different `from`)"
      (is (frame= (fr 400 0 40 80) (keyed-geo to committed 300.0 key-of 0.0 1)))
      (is (frame= (fr 230 0 50 90) (keyed-geo to committed 300.0 key-of 0.5 1))))))

(deftest keyed-tween-reindex-on-remove-glides-survivor-up
  ;; §7a root-cause guard. Data [a b c d] (offsets 0/50/100/150) removes the
  ;; MIDDLE `b`; the INDEXED target is built over the PURE NEW DATA [a c d]
  ;; (offsets 0/50/100) — no dying reinsert. Survivor `c` was at old index 2
  ;; (committed offset 100) and now maps to new index 1, whose target sits HIGHER
  ;; (smaller offset), so the cell glides up instead of committed==target — the
  ;; bug the dying reinsert used to cause.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
        committed {:a (fr 0 0 50 200) :c (fr 100 0 50 200) :d (fr 150 0 50 200)}
        key-of (fn [^int i] (nth [:a :c :d] i))]  ; new index space, `b` gone
    (testing "reindexed survivor's target is above its committed position"
      (let [c-target (:offset (keyed-geo to committed 300.0 key-of 1.0 1))]
        (is (< c-target (:offset (get committed :c))))  ; 50 < 100 → real slide-up
        (is (close? 50.0 c-target))))
    (testing "mid-glide the survivor is strictly between committed and target"
      (is (frame= (fr 75 0 50 200) (keyed-geo to committed 300.0 key-of 0.5 1))))
    (testing "the cell above the removal (a, index 0) does not move"
      (is (frame= (fr 0 0 50 200) (keyed-geo to committed 300.0 key-of 0.5 0))))))

(deftest keyed-tween-extent-lerps
  (let [to (tw/frozen-frame-source {:base 0 :extent 180.0 :frames [(fr 0 0 60 200)]})
        ext (fn [^double t]
              (let [tl (tw/keyed-tween-layout [:e t] to {} 400.0 (fn [^int _i] :z) (fn [] t))]
                ((:max-extent tl) (with-ctx tl base-env) 10)))]
    (testing "max-extent lerps from-extent -> to-src extent"
      (is (close? 400.0 (ext 0.0)))
      (is (close? 180.0 (ext 1.0)))
      (is (close? 290.0 (ext 0.5))))))

(deftest keyed-tween-retarget-continuous
  ;; Interrupt a keyed glide mid-flight, freeze the interpolated rect as the new
  ;; committed `from`, and re-aim at a fresh target — as the engine does when a
  ;; second data/layout change lands mid-segment. Must be jump-free: the new
  ;; segment starts exactly where the old was interrupted and still lands on the
  ;; new target.
  (let [to1 (tw/frozen-frame-source
             {:base 0 :extent 180.0 :frames [(fr 0 0 60 100) (fr 60 100 60 100)]})
        committed0 {:x (fr 200 0 100 200)}
        key-of (fn [^int _i] :x)
        ;; interrupt index 1 at t=0.5 → interpolated rect
        mid (keyed-geo to1 committed0 300.0 key-of 0.5 1)
        ;; re-aim: the interpolated rect becomes the new committed `from`
        committed1 {:x mid}
        to2 (tw/frozen-frame-source
             {:base 0 :extent 120.0 :frames [(fr 0 0 40 80) (fr 40 0 40 80)]})]
    (testing "the re-aimed segment starts exactly at the interrupted rect"
      (is (frame= mid (keyed-geo to2 committed1 240.0 key-of 0.0 1))))
    (testing "and still lands exactly on the new target"
      (is (frame= (fr 40 0 40 80) (keyed-geo to2 committed1 240.0 key-of 1.0 1))))))

(deftest keyed-tween-windowing-passes-through-to-src
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 400.0
             :frames [(fr 0 0 100 200) (fr 100 0 100 200)
                      (fr 200 0 100 200) (fr 300 0 100 200)]})
        ;; committed rects far from the window must NOT widen it — windowing is to-src only
        committed {:a (fr 0 0 100 200) :b (fr 900 0 100 200)}
        key-of (fn [^int i] (if (even? i) :a :b))
        tl (tw/keyed-tween-layout [:w 0.5] to committed 300.0 key-of (fn [] 0.5))
        env (with-ctx tl base-env)]
    (testing "first/last-index equal the to-src's own window"
      (is (= 1 ((:first-index tl) env 150.0)))
      (is (= 2 ((:last-index tl) env 250.0))))))

;; --- keyed combinator (v2): enter/exit wipe (main-extent collapse) ---

(defn- keyed-geo* [to-src committed ^double from-extent key-of opts ^double t ^int i]
  (let [tl (tw/keyed-tween-layout [:k t] to-src committed from-extent key-of (fn [] t) opts)]
    ((:geometry tl) (with-ctx tl base-env) i)))

(deftest keyed-tween-entering-key-wipes-open
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        key-of (fn [^int _i] :n)]
    (testing "t=0: main-extent 0 at the target offset/cross (no committed history)"
      (is (frame= (fr 40 20 0 100) (keyed-geo* to {} 180.0 key-of {:entering #{:n}} 0.0 0))))
    (testing "t=0.5: half-open at the target position"
      (is (frame= (fr 40 20 30 100) (keyed-geo* to {} 180.0 key-of {:entering #{:n}} 0.5 0))))
    (testing "t=1: full target frame"
      (is (frame= (fr 40 20 60 100) (keyed-geo* to {} 180.0 key-of {:entering #{:n}} 1.0 0))))))

(deftest keyed-tween-exiting-key-wipes-shut
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:d (fr 40 20 60 100)}
        key-of (fn [^int _i] :d)]
    (testing "t=0: natural committed rect"
      (is (frame= (fr 40 20 60 100) (keyed-geo* to committed 180.0 key-of {:exiting #{:d}} 0.0 0))))
    (testing "t=1: main-extent 0, offset/cross unchanged (collapses in place)"
      (is (frame= (fr 40 20 0 100) (keyed-geo* to committed 180.0 key-of {:exiting #{:d}} 1.0 0))))))

(deftest keyed-tween-normal-key-unaffected-by-enter-exit-opts
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 0 0 60 100) (fr 60 0 60 100)]})
        committed {:m (fr 200 0 100 200) :n (fr 400 0 40 80)}
        key-of (fn [^int i] (if (zero? i) :m :n))
        ;; :n is entering; index 0 carries the normal key :m and must lerp committed->to
        opts {:entering #{:n}}]
    (testing "the normal key still lerps its committed rect -> target"
      (is (frame= (fr 200 0 100 200) (keyed-geo* to committed 300.0 key-of opts 0.0 0)))
      (is (frame= (fr 100 0 80 150) (keyed-geo* to committed 300.0 key-of opts 0.5 0)))
      (is (frame= (fr 0 0 60 100) (keyed-geo* to committed 300.0 key-of opts 1.0 0))))))

;; --- §8a: lay-at (:full-main-extent) decoupled from visible (:main-extent) ---

(deftest full-main-extent-decouples-lay-at-from-visible
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:x (fr 40 20 60 100)}]
    (testing "entering: full == target, visible == target*progress"
      (let [g (keyed-geo* to {} 180.0 (fn [^int _i] :x) {:entering #{:x}} 0.25 0)]
        (is (close? 60.0 (:full-main-extent g)))
        (is (close? 15.0 (:main-extent g)))))
    (testing "exiting: full == committed, visible == committed*(1-progress)"
      (let [g (keyed-geo* to committed 180.0 (fn [^int _i] :x) {:exiting #{:x}} 0.25 0)]
        (is (close? 60.0 (:full-main-extent g)))
        (is (close? 45.0 (:main-extent g)))))
    (testing "stay: full == visible (a size-morphing stay reflows, no clip)"
      (let [g (keyed-geo* to {:x (fr 0 20 100 100)} 180.0 (fn [^int _i] :x) {} 0.5 0)]
        (is (close? 80.0 (:main-extent g)))          ; lerp(100, 60, 0.5)
        (is (close? (:main-extent g) (:full-main-extent g)))))))

;; --- WS1.1: interruption continuity — a retrigger continues the wipe from the
;;     current visible window, instead of snapping back to 0 (enter) / full (exit).

(deftest keyed-tween-reentering-continues-from-captured-window
  ;; a cell caught 40% open (visible main 24 of a full 60) is re-entered by a new
  ;; segment: at t=0 the wipe MUST resume at 24, not restart from 0.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:x {:offset 40.0 :cross 20.0 :main-extent 24.0 :cross-extent 100.0
                       :full-main 60.0 :full-cross 100.0}}
        key-of (fn [^int _i] :x)
        opts {:entering #{:x}}]
    (testing "t=0 resumes at the captured visible window (24), not 0"
      (let [g (keyed-geo* to committed 180.0 key-of opts 0.0 0)]
        (is (close? 24.0 (:main-extent g)))
        (is (close? 60.0 (:full-main-extent g)))))   ; still laid at full
    (testing "t mid lerps captured-window -> full target"
      (is (close? 42.0 (:main-extent (keyed-geo* to committed 180.0 key-of opts 0.5 0)))))
    (testing "t=1 reaches the full target"
      (is (close? 60.0 (:main-extent (keyed-geo* to committed 180.0 key-of opts 1.0 0)))))))

(deftest keyed-tween-reexiting-continues-from-window-lays-at-full
  ;; a cell caught mid-collapse (visible main 30 of a full 60) is re-exited: the
  ;; wipe resumes at 30 (not the full 60), but the cell still LAYS OUT at its
  ;; captured full 60 — full comes from :full-main, not the partial :main-extent.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:x {:offset 40.0 :cross 20.0 :main-extent 30.0 :cross-extent 100.0
                       :full-main 60.0 :full-cross 100.0}}
        key-of (fn [^int _i] :x)
        opts {:exiting #{:x}}]
    (testing "t=0 resumes at the captured window (30), laid at the captured full (60)"
      (let [g (keyed-geo* to committed 180.0 key-of opts 0.0 0)]
        (is (close? 30.0 (:main-extent g)))
        (is (close? 60.0 (:full-main-extent g)))))
    (testing "t=1 collapses the window to 0, still laid at full"
      (let [g (keyed-geo* to committed 180.0 key-of opts 1.0 0)]
        (is (close? 0.0 (:main-extent g)))
        (is (close? 60.0 (:full-main-extent g)))))))

(deftest keyed-tween-reexiting-cross-collapse-uses-full-cross
  ;; cross-collapsing (grid/wrap) retrigger: the exit lay-at size comes from
  ;; :full-cross, not the partial cross window.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:x {:offset 40.0 :cross 20.0 :main-extent 60.0 :cross-extent 40.0
                       :full-main 60.0 :full-cross 100.0}}
        key-of (fn [^int _i] :x)
        opts {:collapse-axis :cross :exiting #{:x}}]
    (testing "t=0 resumes at the captured cross window (40), laid at full cross (100)"
      (let [g (keyed-geo* to committed 180.0 key-of opts 0.0 0)]
        (is (close? 40.0 (:cross-extent g)))
        (is (close? 100.0 (:full-cross-extent g)))
        (is (close? 60.0 (:main-extent g)))))       ; non-collapse axis held
    (testing "t=1 collapses the cross window to 0"
      (is (close? 0.0 (:cross-extent (keyed-geo* to committed 180.0 key-of opts 1.0 0)))))))

;; --- 3c: the collapse axis is DECLARED by the layout (main vs cross) ---

(deftest keyed-tween-cross-collapse-wipes-cross-not-main
  ;; a grid/wrap declares :collapse-axis :cross → a removed cell shrinks its CROSS
  ;; extent (width) toward 0 while KEEPING its main extent (height); an inserted
  ;; cell grows cross 0→full. Mirror of the default :main list collapse.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 40 20 60 100)]})
        committed {:x (fr 40 20 60 100)}
        cross {:collapse-axis :cross}]
    (testing "entering: cross-extent 0→full, main-extent held at target"
      (let [g0 (keyed-geo* to {} 180.0 (fn [^int _i] :x) (assoc cross :entering #{:x}) 0.0 0)
            g5 (keyed-geo* to {} 180.0 (fn [^int _i] :x) (assoc cross :entering #{:x}) 0.5 0)]
        (is (frame= (fr 40 20 60 0) g0))       ; cross wiped shut, main full
        (is (frame= (fr 40 20 60 50) g5))      ; half-open on cross
        ;; §8a: laid at full cross, painted clipped to the lerped visible cross
        (is (close? 100.0 (:full-cross-extent g5)))
        (is (close? 50.0 (:cross-extent g5)))
        (is (close? 60.0 (:full-main-extent g5)))))
    (testing "exiting: cross-extent full→0 in place, main-extent held"
      (let [g1 (keyed-geo* to committed 180.0 (fn [^int _i] :x) (assoc cross :exiting #{:x}) 1.0 0)]
        (is (frame= (fr 40 20 60 0) g1)))      ; width gone, height kept
      (let [g (keyed-geo* to committed 180.0 (fn [^int _i] :x) (assoc cross :exiting #{:x}) 0.25 0)]
        (is (close? 100.0 (:full-cross-extent g)))  ; stable full cross
        (is (close? 75.0 (:cross-extent g)))        ; visible = 100*(1-0.25)
        (is (close? 60.0 (:main-extent g)))))))     ; main untouched

(deftest shadow-frame-source-cross-collapse-keeps-main
  ;; a grid remove (:collapse-axis :cross): the dying slot's gap frame must reserve
  ;; zero CROSS extent (width) but keep its committed MAIN extent (height), so the
  ;; cell shrinks horizontally in place rather than collapsing to a point.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
        entries [{:type :live :key :a}
                 {:type :dying :key :b :committed (fr 50 30 50 90)}
                 {:type :live :key :c}]
        src (tw/shadow-frame-source to entries :cross)
        env (assoc base-env :item-count 3)
        ctx ((:prepare src) env)
        g ((:frame src) env ctx 1)]
    (testing "dying gap frame: cross-extent 0, main-extent kept from committed"
      (is (close? 0.0 (:cross-extent g)))     ; zero reserved width
      (is (close? 50.0 (:main-extent g)))     ; height kept (not collapsed to a point)
      (is (close? 30.0 (:cross g))))          ; positioned at its committed cross
    (testing "live survivors still map to pure-new indices (unchanged by axis)"
      (is (close? 0.0 (:offset ((:frame src) env ctx 0))))
      (is (close? 50.0 (:offset ((:frame src) env ctx 2)))))))

;; --- §7c: from = committed ∪ edge slide (viewport-entering cells glide) ---

(deftest augment-from-edges-glides-entering-cell
  ;; window indices 0..5; only 2,3 were on-screen (committed). With no old layout each
  ;; entering cell uses its TARGET frame, and edge-slide-block slides each edge-group
  ;; in as a BLOCK that keeps relative target spacing (not a single line at the edge).
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 100}))
        key-of (fn [^int i] (nth [:a :b :c :d :e :f] i))
        ;; :e carries a STALE committed rect but is NOT on-screen (it reindexed
        ;; off-screen last segment); it must get an edge frame, not keep the stale rect.
        committed {:c (fr 200 0 100 200) :d (fr 300 0 100 200) :e (fr 999 0 100 200)}
        on-screen #{:c :d}   ; the attached/visible keys — ground truth for `from`
        env (assoc base-env :item-count 6)
        ctx ((:prepare to) env)
        ws 200.0 we 400.0
        result (tw/augment-from-edges committed on-screen #{} to env ctx key-of 0 5 ws we nil)]
    (testing "committed (on-screen) keys keep their rects"
      (is (frame= (fr 200 0 100 200) (get result :c)))
      (is (frame= (fr 300 0 100 200) (get result :d))))
    (testing "stale committed key NOT on-screen is overridden with a block frame"
      (is (not (close? 999.0 (:offset (get result :e))))))
    (testing "trailing block (idx > cmax) abuts we, keeping target spacing"
      (is (close? 400.0 (:offset (get result :e))))     ; index 4: target 400, min → we
      (is (close? 500.0 (:offset (get result :f))))     ; index 5: 400 + 100 spacing
      (is (close? 100.0 (:main-extent (get result :f)))))
    (testing "leading block (idx < cmin) abuts ws from above, keeping target spacing"
      (is (close? 0.0 (:offset (get result :a))))       ; index 0: block far edge at ws
      (is (close? 100.0 (:offset (get result :b)))))    ; index 1
    (testing "every window index now has a from (glide, not pop)"
      (is (= #{:a :b :c :d :e :f} (set (keys result)))))))

(deftest augment-from-edges-drops-entering-cells
  ;; A freshly DATA-entering cell (∈ entering, ∉ old) must enter-collapse from 0,
  ;; not arrive-slide from the edge — the mirror of augment-to-edges skipping
  ;; exiting keys. It must get NO `from`, even reusing a key with a STALE committed
  ;; rect left by the cell just removed at that key.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 100}))
        key-of (fn [^int i] (nth [:a :b :c :d :e :f] i))
        committed {:c (fr 200 0 100 200) :d (fr 300 0 100 200) :e (fr 999 0 100 200)}
        on-screen #{:c :d}
        env (assoc base-env :item-count 6)
        ctx ((:prepare to) env)
        ws 200.0 we 400.0
        ;; :a fresh insert (no committed), :e fresh insert REUSING a stale-committed key
        entering #{:a :e}
        result (tw/augment-from-edges committed on-screen entering to env ctx key-of 0 5 ws we nil)]
    (testing "entering off-screen key gets no from → collapses from 0"
      (is (not (contains? result :a))))
    (testing "entering key reusing a stale committed rect is dropped, not slid"
      (is (not (contains? result :e))))
    (testing "on-screen and non-entering off-screen cells are unaffected"
      (is (frame= (fr 200 0 100 200) (get result :c)))
      (is (close? 400.0 (:offset (get result :f)))))))

(deftest augment-from-edges-grouped-old-size
  ;; §7c size morph: with an indexed old layout, cells arriving at one edge keep
  ;; their OLD size and are laid out relative to each other, then the block is
  ;; translated to the edge — instead of piling in a line at target size.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 100}))
        key-of (fn [^int i] (nth [:a :b :c :d :e :f] i))
        committed {:c (fr 200 0 100 200) :d (fr 300 0 100 200)}
        on-screen #{:c :d}                            ; cmin=2, cmax=3
        env (assoc base-env :item-count 6)
        ctx ((:prepare to) env)
        ws 200.0 we 400.0
        ;; old layout = taller cells: main 150 (target is 100)
        old-frame (fn [^int i] {:offset (* i 150.0) :cross 0.0 :main-extent 150.0 :cross-extent 200.0})
        result (tw/augment-from-edges committed on-screen #{} to env ctx key-of 0 5 ws we old-frame)]
    (testing "arriving cells carry the OLD size (150), not the target size (100)"
      (is (close? 150.0 (:main-extent (get result :f)))))
    (testing "trailing block keeps old spacing and abuts we"
      ;; :e(4),:f(5) old offsets 600,750; min=600 → shift = we-600 = -200
      (is (close? 400.0 (:offset (get result :e))))   ; 600 - 200
      (is (close? 550.0 (:offset (get result :f)))))  ; 750 - 200
    (testing "leading block abuts ws from above"
      ;; :a(0),:b(1) old offsets 0,150; max end = 300 → shift = ws-300 = -100
      (is (close? -100.0 (:offset (get result :a))))  ; 0 - 100
      (is (close? 50.0 (:offset (get result :b)))))   ; 150 - 100
    (testing "on-screen cells keep their real committed rects"
      (is (frame= (fr 200 0 100 200) (get result :c))))))

;; --- §7a shared core: shadow-entries / shadow-frame-source ---

(deftest shadow-entries-classifies-by-exiting-set
  (let [committed {:b (fr 50 0 50 200)}
        entries (tw/shadow-entries 3 (fn [^int i] (nth [:a :b :c] i)) #{:b} committed)]
    (testing "exiting keys become dying slots carrying their committed rect"
      (is (= {:type :dying :key :b :committed (fr 50 0 50 200)} (nth entries 1))))
    (testing "every other index is a live survivor, in shadow order"
      (is (= [{:type :live :key :a} {:type :live :key :c}]
             [(nth entries 0) (nth entries 2)])))))

(deftest shadow-frame-source-collapse-remap
  ;; Data [a b c d] (indexed list, extent 50 → old offsets 0/50/100/150) removes
  ;; the MIDDLE `b`. The shadow order keeps b in-tree as a dying slot; the pure
  ;; new data is [a c d]. Survivors must map to the compacted pure-new indices
  ;; (glide UP) and the dying slot must reserve zero extent at the gap.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
        entries [{:type :live :key :a}
                 {:type :dying :key :b :committed (fr 50 0 50 200)}
                 {:type :live :key :c}
                 {:type :live :key :d}]
        src (tw/shadow-frame-source to entries)
        env (assoc base-env :item-count 4)
        ctx ((:prepare src) env)
        frame (fn [^int i] ((:frame src) env ctx i))]
    (testing "live survivors map to pure-new-data indices (compacted, higher up)"
      (is (close? 0.0 (:offset (frame 0))))     ; a → d0 → 0
      (is (close? 50.0 (:offset (frame 2))))    ; c → d1 → 50 (was committed 100)
      (is (close? 100.0 (:offset (frame 3)))))  ; d → d2 → 100 (was committed 150)
    (testing "survivor frames sit HIGHER (smaller offset) than committed"
      (is (< (:offset (frame 2)) 100.0))        ; c new 50 < old 100
      (is (< (:offset (frame 3)) 150.0)))       ; d new 100 < old 150
    (testing "dying slot is a zero-extent gap at the next survivor's new offset"
      (let [g (frame 1)]
        (is (close? 50.0 (:offset g)))          ; == c's new offset (gap closes here)
        (is (close? 0.0 (:main-extent g)))      ; zero reserved extent to survivors
        (is (close? 0.0 (:cross g)))            ; from the dying cell's committed rect
        (is (close? 200.0 (:cross-extent g)))))
    (testing "extent is the pure-new (live) total, not the inflated shadow count"
      (is (close? 150.0 ((:extent src) env ctx 4))))   ; 3 live × 50
    (testing "first-index answers in shadow space, widening over the dying slot"
      (is (= 0 ((:first-index src) env ctx 40.0)))     ; window at a → shadow 0
      (is (= 1 ((:first-index src) env ctx 60.0)))))   ; window at c → include dying b (shadow 1)
  (testing "a dying cell trailing all survivors gaps to the pure-new total extent"
    (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
          entries [{:type :live :key :a}
                   {:type :live :key :b}
                   {:type :dying :key :c :committed (fr 100 0 50 200)}]
          src (tw/shadow-frame-source to entries)
          env (assoc base-env :item-count 3)
          ctx ((:prepare src) env)]
      (is (close? 100.0 (:offset ((:frame src) env ctx 2)))))))  ; live total = 2×50

(deftest flow-live-only-reflow-collapses-gap
  ;; Flow analogue of the indexed collapse remap (the `live-only-flow-window` core):
  ;; a flow list [a b c d] (natural 50 tall, spacing 10 → committed 0/60/120/180)
  ;; removes the MIDDLE `b`. The live-only source is the SURVIVOR sizes reindexed to
  ;; contiguous pure-live indices and RE-FLOWED via flow-frames (gap closes), frozen,
  ;; then wrapped by the SAME shadow-frame-source the indexed branch uses. Survivors
  ;; below the removal must glide UP; the dying slot must be a zero-extent gap.
  (let [l (lay/list-layout {:spacing 10})
        venv (assoc base-env :item-count 4)
        ;; survivors a,c,d reindexed to pure-live 0,1,2 and re-flowed
        sized [[0 (ui/Size 200 50)] [1 (ui/Size 200 50)] [2 (ui/Size 200 50)]]
        live-frames (tw/flow-frames l venv sized (tw/flow-seed-state l venv 0 0.0))
        to (tw/frozen-frame-source {:frames live-frames :base 0
                                    :extent (tw/frames-main-extent live-frames)})
        entries [{:type :live :key :a}
                 {:type :dying :key :b :committed (fr 60 0 50 200)}
                 {:type :live :key :c}
                 {:type :live :key :d}]
        src (tw/shadow-frame-source to entries)
        ctx ((:prepare src) venv)
        frame (fn [^int i] ((:frame src) venv ctx i))]
    (testing "survivors glide UP to their compacted pure-live offsets"
      (is (close? 0.0 (:offset (frame 0))))    ; a → d0 → 0
      (is (close? 60.0 (:offset (frame 2))))   ; c → d1 → 60 (was committed 120)
      (is (close? 120.0 (:offset (frame 3))))) ; d → d2 → 120 (was committed 180)
    (testing "dying slot is a zero-extent gap at the next survivor's new offset"
      (let [g (frame 1)]
        (is (close? 60.0 (:offset g)))
        (is (close? 0.0 (:main-extent g)))
        (is (close? 200.0 (:cross-extent g)))))
    (testing "extent is the pure-live total (dying cell excluded)"
      (is (close? 170.0 ((:extent src) venv ctx 4))))))

;; --- §7b: leave-slide (leaving key lerps committed -> edge frame) ---

(deftest keyed-tween-leaving-key-slides-to-edge
  ;; key :l reindexed outside the target window: the frozen to-src has NO frame
  ;; at its index, which used to freeze the cell at committed and pop it at GC.
  ;; With a :leaving `to` (committed slid past the trailing edge) it glides out.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 180.0 :frames [(fr 0 0 60 100)]})
        committed {:l (fr 100 0 100 200)}
        ;; committed slid fully past the trailing edge (we=400), size unchanged
        edge (fr 400 0 100 200)
        key-of (fn [^int _i] :l)
        opts {:leaving {:l edge}}]
    (testing "t=0 sits exactly at committed (no jump at segment start)"
      (is (frame= (fr 100 0 100 200) (keyed-geo* to committed 300.0 key-of opts 0.0 5))))
    (testing "t=1 sits fully past the trailing edge"
      (is (frame= (fr 400 0 100 200) (keyed-geo* to committed 300.0 key-of opts 1.0 5))))
    (testing "mid-glide is a pure translation: size constant, no paint clip"
      (let [g (keyed-geo* to committed 300.0 key-of opts 0.5 5)]
        (is (frame= (fr 250 0 100 200) g))
        (is (close? (:main-extent g) (:full-main-extent g)))))))

(deftest keyed-tween-leaving-overrides-far-target
  ;; an INDEXED to-src answers an exact frame at any index; a leaving key must
  ;; ignore that far frame and take the bounded edge slide instead (a shuffle
  ;; must not drag a cell across the whole list).
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 50}))
        committed {:l (fr 100 0 50 200)}
        ;; committed slid fully past the trailing edge (we=400), size unchanged
        edge (fr 400 0 50 200)
        key-of (fn [^int _i] :l)]
    (testing "t=1 lands at the edge, not at index 9's exact frame (450)"
      (is (frame= (fr 400 0 50 200)
                  (keyed-geo* to committed 500.0 key-of {:leaving {:l edge}} 1.0 9))))
    (testing "a key NOT in :leaving still aims at the exact indexed target"
      (is (frame= (fr 450 0 50 200)
                  (keyed-geo* to committed 500.0 key-of {:leaving {:other (fr 0 0 1 1)}} 1.0 9))))))

;; --- §7b: augment-to-edges (the leave-slide classifier + `to` builder) ---

(deftest augment-to-edges-classifies-leaving-cells
  ;; window span [lo..hi]=[2..4]; current window [200,400], end window [250,450].
  ;; Attached cells whose committed rect overlaps the CURRENT window but whose
  ;; index falls outside the span leave through the near END-window edge, morphing
  ;; to their TARGET size (list item-extent 80) — not their committed size (50).
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 80}))
        env (assoc base-env :item-count 10)
        ctx ((:prepare to) env)
        committed {:a (fr 210 0 50 200)   ; index 0 -> leaving :leading
                   :b (fr 260 0 50 200)   ; index 3 -> in span -> stays
                   :c (fr 310 0 50 200)   ; index 6 -> leaving :trailing
                   :d (fr 900 0 50 200)   ; index 5 -> committed off-window -> skip
                   :x (fr 360 0 50 200)}  ; index 4 -> in span -> stays
        cells [{:index 0 :key :a} {:index 3 :key :b} {:index 6 :key :c}
               {:index 5 :key :d} {:index 4 :key :x} {:index 1 :key :nohist}]
        out (tw/augment-to-edges committed cells #{} to env ctx 2 4 200.0 400.0 250.0 450.0 identity)]
    (testing "leaving :leading cell morphs to TARGET size, slid above the END edge"
      (is (close? 170.0 (:offset (get out :a))))       ; end-ws - target-main = 250-80
      (is (close? 80.0 (:main-extent (get out :a)))))  ; target size, not committed 50
    (testing "leaving :trailing cell morphs to TARGET size, slid below the END edge"
      (is (close? 450.0 (:offset (get out :c))))
      (is (close? 80.0 (:main-extent (get out :c)))))
    (testing "in-span, off-window-committed and history-less cells are not leaving"
      (is (= #{:a :c} (set (keys out)))))))

(deftest augment-to-edges-skips-exiting
  ;; a data-removed key exit-collapses in place (§7a) — never leave-slides,
  ;; even when reindexing pushed its shadow slot out of the window span.
  (let [to (tw/indexed-frame-source (lay/resolve-layout :list {:item-extent 80}))
        env (assoc base-env :item-count 10)
        ctx ((:prepare to) env)
        committed {:e (fr 210 0 50 200)}
        cells [{:index 9 :key :e}]]
    (is (= {} (tw/augment-to-edges committed cells #{:e} to env ctx 2 4 200.0 400.0 200.0 400.0 identity)))))

(deftest augment-to-edges-frame-lookup-uses-pure-live-index
  ;; A dying (exiting) cell PRECEDES a leaving cell in the SHADOW index space, so
  ;; the leaving cell's shadow index runs one ahead of its pure-live index. The
  ;; target frame (leave-src) is addressed by PURE-LIVE indices, so the lookup must
  ;; translate — otherwise the cell morphs toward the wrong slot's frame.
  (let [to (tw/frozen-frame-source
            {:base 0 :extent 1000.0
             :frames [(fr 0 0 30 200)       ; pure-live 0 → :a's CORRECT slot (main 30)
                      (fr 30 0 90 200)]})   ; pure-live 1 == :a's shadow index → WRONG (main 90)
        committed {:a (fr 210 0 50 200)}    ; overlaps current window, index outside span
        ;; shadow order [:dead(dying) :a(live)] → live-before = [0 0] ⇒ shadow 1 → pure-live 0
        shadow->live (fn [^int i] (nth [0 0] i))
        cells [{:index 0 :key :dead} {:index 1 :key :a}]
        out (tw/augment-to-edges committed cells #{:dead} to base-env nil
                                 3 5 200.0 400.0 250.0 450.0 shadow->live)]
    (testing "leaving cell morphs to its PURE-LIVE slot's size, not its shadow slot's"
      (is (close? 30.0 (:main-extent (get out :a))))   ; pure-live 0 (30), not shadow 1 (90)
      (is (close? 220.0 (:offset (get out :a)))))      ; :leading ⇒ end-ws(250) − main(30)
    (testing "the dying cell that precedes it is skipped"
      (is (= #{:a} (set (keys out)))))))

(deftest keyed-tween-between-two-grids-endpoints-exact
  ;; indexed×indexed morph via the KEYED combinator: `from` = the grid-2 frames
  ;; committed by key, `to` = the live grid-3 source. Exact at both endpoints.
  (let [g2 (lay/resolve-layout :grid {:columns 2 :rows {:size 50}})
        g3 (lay/resolve-layout :grid {:columns 3 :rows {:size 50}})
        genv (lay/make-env (sliver-constraints 300.0 600.0) 10)
        g2-geo (fn [^int i] ((:geometry g2) (assoc genv :ctx ((:prepare g2) genv)) i))
        g3-geo (fn [^int i] ((:geometry g3) (assoc genv :ctx ((:prepare g3) genv)) i))
        committed {4 (g2-geo 4)}
        to (tw/indexed-frame-source g3)
        geo-at (fn [^double t ^int i]
                 (let [tl (tw/keyed-tween-layout [:g t] to committed 250.0
                                                 (fn [^int i'] i') (fn [] t))]
                   ((:geometry tl) (assoc genv :ctx ((:prepare tl) genv)) i)))]
    (testing "keyed morph between two grids is exact at both endpoints"
      (is (frame= (g2-geo 4) (geo-at 0.0 4)))
      (is (frame= (g3-geo 4) (geo-at 1.0 4))))))
