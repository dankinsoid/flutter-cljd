;; @ai-generated(solo)
(ns flutter-cljd.internal.collection.render-test
  "Pure-fn coverage for the v2 keyed rect engine (render.cljd). The rect-commit
   and anchor-cell walks need a live render tree, so they are exercised only
   through their extracted pure kernels: prune-committed and widen-window-indices."
  (:require [clojure.test :refer [deftest is testing]]
            [flutter-cljd.internal.collection.render :as render]))

;; --- committed-rect (capture completeness for the wipe) ---

(deftest committed-rect-unclipped-visible-equals-full
  ;; a resting / non-collapsing child (clip nil) commits visible == full on both
  ;; axes, so nothing downstream that falls back to :main-extent changes.
  (let [rect {:offset 10.0 :cross 5.0 :main-extent 60.0 :cross-extent 100.0}
        c (render/committed-rect rect nil 42)]
    (is (= 60.0 (:main-extent c)))
    (is (= 100.0 (:cross-extent c)))
    (is (= 60.0 (:full-main c)))
    (is (= 100.0 (:full-cross c)))
    (is (= 42 (:seen c)))
    (is (= 10.0 (:offset c)))))

(deftest committed-rect-clipped-stores-visible-window-and-full
  ;; a cell laid at full 60x100 but painted clipped to a 24-tall main window:
  ;; committed keeps the VISIBLE extent (so a retrigger continues the wipe) AND
  ;; the FULL laid extent (so an exit re-lays at the stable size, not the window).
  (let [rect {:offset 10.0 :cross 5.0 :main-extent 60.0 :cross-extent 100.0}
        c (render/committed-rect rect [24.0 100.0] 7)]
    (is (= 24.0 (:main-extent c)))     ; visible window on the collapse axis
    (is (= 100.0 (:cross-extent c)))   ; non-collapse axis unchanged
    (is (= 60.0 (:full-main c)))       ; stable full laid extent preserved
    (is (= 100.0 (:full-cross c)))
    (is (= 7 (:seen c)))))

;; --- prune-committed ---

(deftest prune-committed-drops-only-stale
  (let [m {:a {:offset 0.0 :seen 100}
           :b {:offset 1.0 :seen 500}
           :c {:offset 2.0 :seen 700}}]
    (testing "entries older than max-age are dropped, fresher ones kept"
      ;; pass-tick 701, max-age 600 ⇒ :a age 601 pruned, :b/:c kept
      (let [p (render/prune-committed m 701 600)]
        (is (= #{:b :c} (set (keys p))))
        (is (nil? (:a p)))
        (is (= (:b m) (:b p)))))
    (testing "boundary is strict >: exactly max-age old survives"
      ;; :a seen 100, pass-tick 700 ⇒ age 600, not > 600 ⇒ kept
      (is (contains? (render/prune-committed m 700 600) :a))
      ;; pass-tick 701 ⇒ age 601 > 600 ⇒ pruned
      (is (not (contains? (render/prune-committed m 701 600) :a))))
    (testing "nothing stale ⇒ map unchanged"
      (is (= m (render/prune-committed m 700 10000))))))

;; --- widen-window-indices ---

(defn- cell [i off main] {:index i :offset (double off) :main-extent (double main)})

(deftest widen-window-keeps-overlapping-attached
  ;; window [ws=100, we=300]; target index window [2, 4]
  (let [ws 100.0 we 300.0
        ;; index 0 sits at [50,150] — overlaps below the target window
        ;; index 6 sits at [280,380] — overlaps above the target window
        ;; index 9 sits at [500,600] — fully outside, must NOT widen
        cells [(cell 0 50 100) (cell 2 150 100) (cell 4 250 100)
               (cell 6 280 100) (cell 9 500 100)]]
    (testing "first-index widens down to the lowest overlapping attached index"
      (is (= [0 6] (render/widen-window-indices 2 4 cells ws we))))
    (testing "a cell fully outside the window never widens"
      (is (= [2 4] (render/widen-window-indices
                    2 4 [(cell 9 500 100) (cell 11 700 100)] ws we))))
    (testing "no attached cells ⇒ window unchanged"
      (is (= [2 4] (render/widen-window-indices 2 4 [] ws we))))))

(deftest widen-window-nil-target-last-unbounded
  ;; target-last nil (infinite trailing): never widen the (already unbounded) tail,
  ;; but leading widening still applies.
  (let [cells [(cell 0 50 100) (cell 6 280 100)]]
    (is (= [0 nil] (render/widen-window-indices 3 nil cells 100.0 300.0)))))

(deftest widen-window-never-narrows
  ;; an overlapping cell already inside [first-index, target-last] leaves it be
  (let [cells [(cell 3 200 100)]]
    (is (= [2 5] (render/widen-window-indices 2 5 cells 100.0 300.0)))))

;; --- prevLayout lifecycle (docs §7c old-src) ---

(deftest prev-layout-lifecycle
  (let [list-lay {:id :list} grid-lay {:id :grid}]
    (testing "layout change with a pending segment freezes the outgoing layout"
      (is (= list-lay (render/next-prev-layout nil list-lay true true))))
    (testing "same-id rebuild before layout keeps the frozen layout (rebuild race)"
      ;; a second host rebuild arriving between the gen bump and performLayout
      ;; must not wipe the layout segment-start! is about to consume
      (is (= list-lay (render/next-prev-layout list-lay grid-lay false true))))
    (testing "retarget onto yet another layout re-freezes the CURRENT resting layout"
      (is (= grid-lay (render/next-prev-layout list-lay grid-lay true true))))
    (testing "resting pass drops any frozen layout"
      ;; a layout change whose morph settled (nothing attached to snapshot) or that
      ;; arrived with animations off has tween-anim nil — no segment-start! will
      ;; consume the frozen layout. Left around, a LATER data-only segment (empty
      ;; enter/exit, ids now differing) would build old-src over the dead layout
      ;; and hand viewport-arriving cells frames the user last saw N changes ago.
      (is (nil? (render/next-prev-layout list-lay grid-lay true false)))
      (is (nil? (render/next-prev-layout list-lay grid-lay false false))))
    (testing "resting steady state stays nil"
      (is (nil? (render/next-prev-layout nil list-lay false false))))))
