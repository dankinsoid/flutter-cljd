;; @ai-generated(solo)
(ns flutter-cljd.internal.collection.render-test
  "Pure-fn coverage for the v2 keyed rect engine (render.cljd). The rect-commit
   and anchor-cell walks need a live render tree, so they are exercised only
   through their extracted pure kernels: prune-committed and widen-window-indices."
  (:require [clojure.test :refer [deftest is testing]]
            ["dart:ui" :as ui]
            [flutter-cljd.internal.collection.layout :as lay]
            [flutter-cljd.internal.collection.tween :as tw]
            [flutter-cljd.internal.collection.render :as render]))

;; --- committed-rect (capture completeness for the wipe) ---

(deftest committed-rect-unclipped-visible-equals-full
  ;; a resting / non-collapsing child (clip nil) commits visible == full on both
  ;; axes, so nothing downstream that falls back to :main-extent changes.
  (let [rect {:offset 10.0 :cross 5.0 :main-extent 60.0 :cross-extent 100.0}
        c (render/committed-rect rect nil)]
    (is (= 60.0 (:main-extent c)))
    (is (= 100.0 (:cross-extent c)))
    (is (= 60.0 (:full-main c)))
    (is (= 100.0 (:full-cross c)))
    (is (= 10.0 (:offset c)))))

(deftest committed-rect-clipped-stores-visible-window-and-full
  ;; a cell laid at full 60x100 but painted clipped to a 24-tall main window:
  ;; committed keeps the VISIBLE extent (so a retrigger continues the wipe) AND
  ;; the FULL laid extent (so an exit re-lays at the stable size, not the window).
  (let [rect {:offset 10.0 :cross 5.0 :main-extent 60.0 :cross-extent 100.0}
        c (render/committed-rect rect [24.0 100.0])]
    (is (= 24.0 (:main-extent c)))     ; visible window on the collapse axis
    (is (= 100.0 (:cross-extent c)))   ; non-collapse axis unchanged
    (is (= 60.0 (:full-main c)))       ; stable full laid extent preserved
    (is (= 100.0 (:full-cross c)))))

;; --- prune-committed (geometric, WS2 phase D — replaced the 600-pass age prune) ---

(deftest prune-committed-geometric-band
  ;; band [ws=100, we=500): keep any entry whose span still overlaps it.
  (let [m {:above   {:offset 0.0 :main-extent 50.0}     ; ends at 50 < ws
           :seam-lo {:offset 60.0 :main-extent 50.0}    ; ends at 110 — overlaps
           :inside  {:offset 200.0 :main-extent 40.0}
           :seam-hi {:offset 480.0 :main-extent 40.0}   ; starts before we — overlaps
           :below   {:offset 500.0 :main-extent 40.0}}  ; starts at we — outside
        p (render/prune-committed m 100.0 500.0)]
    (testing "entries overlapping the band are kept, with their rects intact"
      (is (= #{:seam-lo :inside :seam-hi} (set (keys p))))
      (is (= (:inside m) (:inside p))))
    (testing "entries whose rect left the band are dropped on either side"
      (is (nil? (:above p)))
      (is (nil? (:below p))))
    (testing "a mid-wipe cell overlaps by its FULL span, not the visible window"
      ;; visible collapsed to 5px (ends at 65 < ws) but full-main still reaches in
      (let [m2 {:wiping {:offset 60.0 :main-extent 5.0 :full-main 50.0}}]
        (is (contains? (render/prune-committed m2 100.0 500.0) :wiping))))))

(deftest prune-committed-stale-enter-impossible
  ;; The §2.1 stale-`from` bug class: a key scrolled far away keeps no committed
  ;; entry, so re-inserting it later structurally CANNOT glide from a stale
  ;; offset — with no entry it falls back to the enter-wipe / edge-slide path.
  (let [m {:gone {:offset 12000.0 :main-extent 40.0 :full-main 40.0}
           :here {:offset 250.0 :main-extent 40.0 :full-main 40.0}}
        p (render/prune-committed m 100.0 500.0)]
    (is (nil? (get p :gone)))
    (is (some? (get p :here)))))

(deftest prune-committed-box-band-keeps-all
  ;; The box host's "band" is the whole (never-scrolled) box: [0, ∞) — the
  ;; geometric rule must degrade to keep-all there, never drop-all.
  (let [m {:a {:offset 0.0 :main-extent 40.0}
           :b {:offset 900.0 :main-extent 40.0}
           :z {:offset 1.0e9 :main-extent 40.0}}]
    (is (= m (render/prune-committed m 0.0 (/ 1.0 0.0))))))

(deftest commit-prune-only-between-segments
  (testing "a playing segment exempts everything — no prune mid-segment, so
            active participants and the `from` capture survive to segment end"
    (is (false? (render/commit-prune? true false)))
    (is (false? (render/commit-prune? true true))))
  (testing "a correction pass defers to its coherent corrected re-run"
    (is (false? (render/commit-prune? false true))))
  (testing "a resting, correction-free pass prunes"
    (is (true? (render/commit-prune? false false)))))

;; --- widen-window-indices ---

(defn- cell [i off main] {:index i :offset (double off) :main-extent (double main)})

(deftest widen-window-keeps-overlapping-attached
  ;; window [ws=100, we=300]; target index window [2, 4]
  (let [ws 100.0 we 300.0
        ;; index 0 sits at [50,150] — overlaps below the target window
        ;; index 6 sits at [280,380] — overlaps above the target window
        ;; index 9 sits at [500,600] — fully outside, must NOT widen
        cells [(cell 0 50 100) (cell 2 150 100) (cell 4 250 100)
               (cell 6 280 100) (cell 9 500 100)]]
    (testing "first-index widens down to the lowest overlapping attached index"
      (is (= [0 6] (render/widen-window-indices 2 4 cells ws we))))
    (testing "a cell fully outside the window never widens"
      (is (= [2 4] (render/widen-window-indices
                    2 4 [(cell 9 500 100) (cell 11 700 100)] ws we))))
    (testing "no attached cells ⇒ window unchanged"
      (is (= [2 4] (render/widen-window-indices 2 4 [] ws we))))))

(deftest widen-window-nil-target-last-unbounded
  ;; target-last nil (infinite trailing): never widen the (already unbounded) tail,
  ;; but leading widening still applies.
  (let [cells [(cell 0 50 100) (cell 6 280 100)]]
    (is (= [0 nil] (render/widen-window-indices 3 nil cells 100.0 300.0)))))

(deftest widen-window-never-narrows
  ;; an overlapping cell already inside [first-index, target-last] leaves it be
  (let [cells [(cell 3 200 100)]]
    (is (= [2 5] (render/widen-window-indices 2 5 cells 100.0 300.0)))))

;; --- checkpoint store (WS2 phase B) ---

(deftest cp-record-and-nearest
  (let [cps (-> {}
                (render/cp-record 0 0.0 :s0)
                (render/cp-record 5 300.0 :s5)
                (render/cp-record 12 800.0 :s12))]
    (testing "record stores {:offset :state} keyed by index"
      (is (= {:offset 300.0 :state :s5} (get cps 5))))
    (testing "nearest-at-or-below picks the greatest index <= target"
      (is (= 5 (:index (render/cp-nearest-at-or-below cps 9))))
      (is (= 12 (:index (render/cp-nearest-at-or-below cps 12))))
      (is (= 0 (:index (render/cp-nearest-at-or-below cps 0))))
      (is (= 800.0 (:offset (render/cp-nearest-at-or-below cps 20))))
      (testing "nil when nothing is at-or-below"
        (is (nil? (render/cp-nearest-at-or-below cps -1)))
        (is (nil? (render/cp-nearest-at-or-below {} 100)))))))

(deftest cp-drop-from-mutation-invalidation
  (let [cps (-> {} (render/cp-record 0 0.0 :a)
                (render/cp-record 5 300.0 :b) (render/cp-record 12 800.0 :c))]
    (testing "a mutation/resize at index j drops checkpoints with index >= j"
      (is (= #{0} (set (keys (render/cp-drop-from cps 5)))))
      (is (= #{0 5} (set (keys (render/cp-drop-from cps 12)))))
      (is (= #{0 5 12} (set (keys (render/cp-drop-from cps 13)))))
      (is (empty? (render/cp-drop-from cps 0))))))

(deftest cp-prune-offset-keeps-band-plus-one-seed
  ;; offsets: idx2=100 (above the band), idx5=300 & idx9=600 (in band),
  ;; idx14=900 (below the band). ws=250, we=700.
  (let [cps (-> {} (render/cp-record 2 100.0 :a) (render/cp-record 5 300.0 :b)
                (render/cp-record 9 600.0 :c) (render/cp-record 14 900.0 :d))
        p (render/cp-prune-offset cps 250.0 700.0)]
    (testing "keeps checkpoints whose offset is within [ws, we]"
      (is (contains? p 5))
      (is (contains? p 9)))
    (testing "drops checkpoints whose offset is below the band"
      (is (not (contains? p 14))))
    (testing "retains exactly one seed strictly above the band (nearest below ws)"
      (is (contains? p 2)))
    (testing "with two above the band, only the nearest (greatest index) survives"
      (let [cps2 (render/cp-record cps 3 150.0 :a2)   ; another above-band, higher idx
            p2 (render/cp-prune-offset cps2 250.0 700.0)]
        (is (contains? p2 3))
        (is (not (contains? p2 2)))))))

(deftest frontier-survives-front-trim
  ;; Row 3 frontier invariant: anchoredTo0 now means "retained offsets are exact",
  ;; NOT "index 0 is in the cache". Front-trim (trim-front) drops the from-0 prefix
  ;; while deep but keeps exact offsets + an exact re-seeded baseState, and the
  ;; checkpoint/committed prunes touch no offsets — so no geometric prune/trim can
  ;; degrade the claim. The reconciliation is identity; degradation is owned by the
  ;; offset ops (seed/re-anchor/mismatch/underflow) and mutation invalidation.
  (testing "an anchored pass survives front-trim + prune with no churn (was:
            the old rule cleared it the moment cacheFirst left 0 — now it must not)"
    (is (true? (render/frontier-after-prune true))))
  (testing "an un-anchored frontier never resurrects from a prune/trim pass"
    (is (false? (render/frontier-after-prune false))))
  (testing "an item mutation above the band degrades the claim via update-render!
            (count change) + cp-drop-from, not via this reconciliation — the flag
            arrives here already false and stays false"
    ;; cp-drop-from at the touched index drops the shifted checkpoints (>= j),
    ;; and update-render! clears anchoredTo0 on the same count change; the prune
    ;; reconciliation then preserves that cleared state.
    (let [cps (-> {} (render/cp-record 8 400.0 :s8) (render/cp-record 14 900.0 :s14))]
      (is (= #{8} (set (keys (render/cp-drop-from cps 14)))))   ; mutation at 14 above band
      (is (false? (render/frontier-after-prune false))))))

;; --- trim-front (Row 3 memory bound / Row 4 O(W) mismatch copy) ---

(defn- list-cache
  "A from-0 list cache: index i at offset i*pitch, extent, running :max-end."
  [^int n ^double pitch ^double ext]
  (mapv (fn [^int i]
          (let [^double off (* i pitch)]
            {:offset off :cross 0.0 :extent ext :end (+ off ext)
             :max-end (+ off ext) :state (+ off pitch) :canon true}))
        (range n)))

(deftest trim-front-keeps-band-and-seed-baseState
  ;; 100 entries, pitch 40 (offset i*40, end i*40+40). Band leading edge ws=2000:
  ;; entries [0,49] end <= 2000 (fully above), [50,99] reach in. Trim drops [0,50).
  (let [cache (list-cache 100 40.0 40.0)
        [trimmed ^int cf' base'] (render/trim-front cache 0 2000.0)]
    (testing "drops exactly the fully-above-band prefix, keeps the band suffix"
      (is (= 50 (count trimmed)))
      (is (= 50 cf'))
      (is (= 2000.0 (:offset (nth trimmed 0)))))
    (testing "baseState is the EXACT state stored on the last dropped entry
              (state before the new head) — the chain resumes with no re-walk"
      (is (= (:state (nth cache 49)) base')))
    (testing "no dropped entry could have reached the band (max-end <= ws)"
      (is (every? (fn [e] (<= (double (:max-end e)) 2000.0)) (subvec cache 0 50)))
      (is (every? (fn [e] (> (double (:max-end e)) 2000.0)) trimmed)))
    (testing "the retained head's max-end already equals its own end — no rebaseline
              needed, so a fresh running-max still starts correctly"
      (is (= (:end (nth trimmed 0)) (:max-end (nth trimmed 0)))))))

(deftest trim-front-noop-at-edges
  (let [cache (list-cache 10 40.0 40.0)]
    (testing "nothing above the band ⇒ nil (no trim, cache already band-sized)"
      (is (nil? (render/trim-front cache 0 0.0))))
    (testing "everything above the band ⇒ nil (keep the last entry as the head)"
      (is (nil? (render/trim-front cache 0 1.0e9))))
    (testing "an empty cache ⇒ nil"
      (is (nil? (render/trim-front [] 0 100.0))))))

(deftest trim-front-bounds-memory-and-mismatch-copy
  ;; Row 3 + Row 4: an anchored deep scroll builds a from-0 cache [0..we-index];
  ;; walk! stops the TAIL at we, and front-trim caps the HEAD at the band, so the
  ;; steady-state cache is band-sized, NOT O(N). walk!'s mismatch truncation
  ;; `(subvec cache 0 rel)` (rel <= count) is therefore an O(band) copy, not O(N).
  (let [pitch 40.0
        we-index 9031      ;; walk filled [0..9030] to the window bottom
        cache (list-cache we-index pitch 40.0)
        ws (* 9000 pitch)  ;; a ~31-item viewport deep at index 9000
        [trimmed ^int cf' _] (render/trim-front cache 0 ws)]
    (testing "front-trim drops the whole above-band prefix, leaving a band-sized cache"
      (is (= 9000 (- we-index (count trimmed))))   ; dropped exactly [0,9000)
      (is (= 9000 cf'))
      (is (= 31 (count trimmed)))                  ; band, not the 9000-entry prefix
      (is (< (count trimmed) 100)))
    (testing "the worst-case mismatch copy (whole trimmed cache) is band-bounded"
      (let [^int rel (count trimmed)]              ; rel <= count by construction
        (is (<= (count (subvec trimmed 0 rel)) (count trimmed)))))))

(deftest stitch-prefix-restores-global-running-max
  (let [prefix [{:offset 0.0 :end 40.0 :max-end 40.0}
                {:offset 40.0 :end 90.0 :max-end 90.0}]
        cache [{:offset 90.0 :end 130.0 :max-end 130.0}
               {:offset 130.0 :end 200.0 :max-end 200.0}]]
    (testing "prefix is prepended ahead of the cache"
      (let [out (render/stitch-prefix prefix cache)]
        (is (= 4 (count out)))
        (is (= 0.0 (:offset (nth out 0))))
        (is (= 90.0 (:offset (nth out 2))))))
    (testing "max-end stays a non-decreasing global running max (short prefix absorbed)"
      (let [out (render/stitch-prefix prefix cache)]
        (is (= [40.0 90.0 130.0 200.0] (mapv :max-end out)))))
    (testing "a tall mid-run prefix item carries its max-end forward past the seam"
      (let [tall [{:offset 0.0 :end 300.0 :max-end 300.0}]
            out (render/stitch-prefix tall cache)]
        (is (= [300.0 300.0 300.0] (mapv :max-end out)))
        (is (apply <= (mapv :max-end out)))))
    (testing "an empty prefix leaves the cache untouched"
      (is (= cache (render/stitch-prefix [] cache))))))

;; --- cold-start inverse-seed binary search ---

(deftest invert-approx-offset-lands-within-one-item
  (testing "on a linear monotone estimate, inversion lands within one item of truth"
    (let [pitch 50.0
          approx (fn [i] (* i pitch))]
      (doseq [true-i [0 1 7 100 523 999]]
        (let [target (+ (* true-i pitch) 10.0)     ; 10px into item true-i
              got (render/invert-approx-offset approx target 1000)]
          (is (<= (.abs (double (- got true-i))) 1))))))
  (testing "landing on an exact item boundary picks that item"
    (is (= 7 (render/invert-approx-offset (fn [i] (* i 50.0)) 350.0 1000))))
  (testing "a target below offset(0) clamps to index 0"
    (is (= 0 (render/invert-approx-offset (fn [i] (* i 50.0)) -5.0 100))))
  (testing "a non-linear but monotone estimate (per-run pitch) still lands within one"
    ;; wrap-like: 3 items per run, run pitch 120 ⇒ offset = floor(i/3)*120
    (let [approx (fn [i] (* (.floor (/ (double i) 3.0)) 120.0))]
      (doseq [target [0.0 130.0 245.0 600.0]]
        (let [got (render/invert-approx-offset approx target 300)]
          (is (>= (double (approx got)) 0.0))
          (is (<= (double (approx got)) target))
          ;; the next index overshoots the target (greatest index <= target)
          (is (> (double (approx (inc got))) target))))))
  (testing "unbounded (nil count) gallops to bracket the target"
    (is (<= (.abs (double (- (render/invert-approx-offset (fn [i] (* i 50.0)) 5000.0 nil) 100)))
            1))))

;; --- prevLayout lifecycle (docs §7c old-src) ---

(deftest prev-layout-lifecycle
  (let [list-lay {:id :list} grid-lay {:id :grid}]
    (testing "layout change with a pending segment freezes the outgoing layout"
      (is (= list-lay (render/next-prev-layout nil list-lay true true))))
    (testing "same-id rebuild before layout keeps the frozen layout (rebuild race)"
      ;; a second host rebuild arriving between the gen bump and performLayout
      ;; must not wipe the layout segment-start! is about to consume
      (is (= list-lay (render/next-prev-layout list-lay grid-lay false true))))
    (testing "retarget onto yet another layout re-freezes the CURRENT resting layout"
      (is (= grid-lay (render/next-prev-layout list-lay grid-lay true true))))
    (testing "resting pass drops any frozen layout"
      ;; a layout change whose morph settled (nothing attached to snapshot) or that
      ;; arrived with animations off has tween-anim nil — no segment-start! will
      ;; consume the frozen layout. Left around, a LATER data-only segment (empty
      ;; enter/exit, ids now differing) would build old-src over the dead layout
      ;; and hand viewport-arriving cells frames the user last saw N changes ago.
      (is (nil? (render/next-prev-layout list-lay grid-lay true false)))
      (is (nil? (render/next-prev-layout list-lay grid-lay false false))))
    (testing "resting steady state stays nil"
      (is (nil? (render/next-prev-layout nil list-lay false false))))))

;; --- progressive offset refinement (WS2 phase C) ---

;; suppression now reads the phase-E velocity sensor (scrollSign, |v|), not the
;; retired Phase C per-pass eps.
(deftest refine-suppression-gate
  (let [sup 120.0 vf 3200.0]
    (testing "idle (sign 0), slow, never suppresses"
      (is (false? (render/refine-suppressed? 0 500.0 sup vf))))
    (testing "active upward (sign -1) motion above the threshold suppresses"
      (is (true? (render/refine-suppressed? -1 400.0 sup vf))))
    (testing "upward motion below the threshold still refines"
      (is (false? (render/refine-suppressed? -1 90.0 sup vf))))
    (testing "forward/downward (sign +1) SLOW motion refines (below v-fast)"
      (is (false? (render/refine-suppressed? 1 2000.0 sup vf))))
    (testing "a FAST fling suppresses in EITHER direction (protect ballistic momentum)"
      ;; a correction during a fast ballistic tick fights the simulation → abrupt stop
      (is (true? (render/refine-suppressed? 1 4000.0 sup vf)))    ; fast downward
      (is (true? (render/refine-suppressed? 0 5000.0 sup vf))))))  ; fast, sign not yet resolved

(deftest refine-emission-exclusive-with-segment
  (testing "resting, still pass emits"
    (is (true? (render/refine-emit? false false))))
  (testing "a playing segment never emits refinement, even at rest —
            the WS1.3 segment correction owns the pass (mutual exclusivity)"
    (is (false? (render/refine-emit? true false))))
  (testing "suppressed resting pass defers"
    (is (false? (render/refine-emit? false true))))
  (testing "suppressed segment pass defers on both counts"
    (is (false? (render/refine-emit? true true)))))

;; --- origin corrections fire while flinging (#B: gap above item 0 during a fast up-fling) ---
(deftest origin-refine-emit-ignores-velocity
  ;; The exact-landing (index 0 at offset 0) and top-underflow (indices stranded at
  ;; the origin) corrections reconcile the SCROLL BOUNDARY the motion heads toward.
  ;; They are one-shot, convergent and pixel-stable, and Flutter resolves the
  ;; scrollOffsetCorrection within the same frame — so unlike above-anchor seam
  ;; refinement they must NOT be deferred by ballistic velocity, or a gap opens
  ;; above item 0 during a fast up-fling and only closes at deceleration (#B).
  (testing "origin corrections emit regardless of velocity / direction"
    (is (true? (render/origin-refine-emit? false))))    ; resting flow pass
  (testing "a playing segment still owns the pass — origin corrections defer (WS1.3)"
    (is (false? (render/origin-refine-emit? true))))
  (testing "the split is real: at a fast up-fling SEAM refinement is suppressed but
            the origin correction still fires"
    (let [seg? false
          suppressed? (render/refine-suppressed? -1 4000.0 120.0 3200.0)]  ; fast up
      (is (true? suppressed?))
      (is (false? (render/refine-emit? seg? suppressed?)))   ; seam refinement deferred
      (is (true? (render/origin-refine-emit? seg?))))))       ; origin clamp still fires

;; wrap fixture: cross-extent 200, items 90x40 ⇒ 2 per run, run pitch 40.
;; Truth: index i at offset 40*(i div 2), cross 90*(i mod 2).
(def ^:private wrap-env {:axis :vertical :cross-extent 200.0 :item-count 12})
(def ^:private wrapl (lay/wrap-layout {:spacing 0 :run-spacing 0}))

(defn- wrap-sized
  "[i size main-extent] triples for indices [from, to)."
  [^int from ^int to]
  (mapv (fn [^int i] [i (ui/Size 90 40) 40.0]) (range from to)))

(deftest refine-seam-delta-accounting
  ;; checkpoint at k=4 (run start, truth offset 80); re-flow [4,5]; head cf=6
  ;; truly belongs at 120 but the estimated cache placed it at 290 (error +170).
  (let [seed ((:anchor wrapl) wrap-env 4 80.0)
        entries (tw/flow-run-entries wrapl wrap-env (wrap-sized 4 6) seed)
        end-state (:state (peek entries))]
    (testing "the re-flowed prefix places the run correctly"
      (is (= 80.0 (:offset (nth entries 0))))
      (is (= 90.0 (:cross (nth entries 1)))))
    (testing "seam delta = true head offset − estimated head offset"
      (is (= -170.0 (render/refine-seam-delta wrapl wrap-env 6 (ui/Size 90 40)
                                              end-state 290.0))))
    (testing "emit-once: after the correction reconciles the head, delta is 0"
      ;; head shifted by the emitted −170 ⇒ old-head 120 ⇒ converged
      (is (= 0.0 (render/refine-seam-delta wrapl wrap-env 6 (ui/Size 90 40)
                                           end-state 120.0))))
    (testing "sub-pixel disagreement is treated as converged (no correction churn)"
      (is (= 0.0 (render/refine-seam-delta wrapl wrap-env 6 (ui/Size 90 40)
                                           end-state 120.0005))))))

(deftest refinement-telescopes-to-true-residual
  ;; A window estimated 170px below truth converges in two refinement steps:
  ;; the seam correction (−170) plus the exact-landing residual telescope to the
  ;; full estimate error, and index 0 lands exactly at offset 0.
  (let [;; step 1: seam at cf=6 (as above) emits −170; the window's coordinate
        ;; system is now checkpoint truth.
        d1 (render/refine-seam-delta wrapl wrap-env 6 (ui/Size 90 40)
                                     (:state (peek (tw/flow-run-entries
                                                    wrapl wrap-env (wrap-sized 4 6)
                                                    ((:anchor wrapl) wrap-env 4 80.0))))
                                     290.0)
        ;; step 2: backfill reaches index 0 via the from-0 checkpoint (truth):
        ;; the re-flow places index 0 at exactly 0 — no further residual.
        from0 (tw/flow-run-entries wrapl wrap-env (wrap-sized 0 4) ((:init wrapl) wrap-env))
        ^double z (:offset (nth from0 0))]
    (is (= -170.0 d1))
    (is (= 0.0 z))
    (testing "total emitted correction equals the window's initial estimate error"
      (is (= -170.0 (+ d1 (- z)))))
    (testing "the from-0 re-flow seam-matches the corrected window (no re-emission)"
      ;; head cf=4 after landing: truth 80 vs corrected cache 80 ⇒ 0
      (is (= 0.0 (render/refine-seam-delta wrapl wrap-env 4 (ui/Size 90 40)
                                           (:state (peek from0)) 80.0))))))

(deftest exact-landing-lands-index-0-at-offset-0
  ;; Synthetic estimate error: dead-reckoned backfill left index 0's run at 37.0.
  ;; The landing correction is −residual, and the corrected re-flow from :init
  ;; places index 0 exactly at 0 — scroll stops exactly on the first element.
  (let [estimated (tw/flow-run-entries wrapl wrap-env (wrap-sized 0 2)
                                       ((:anchor wrapl) wrap-env 0 37.0))
        ^double z (:offset (nth estimated 0))
        corr (- z)
        landed (tw/flow-run-entries wrapl wrap-env (wrap-sized 0 2)
                                    ((:init wrapl) wrap-env))]
    (is (= 37.0 z))
    (is (= 0.0 (+ z corr)))
    (testing "re-flow from :init is exact at the top"
      (is (= 0.0 (:offset (nth landed 0))))
      (is (= 0.0 (:cross (nth landed 0))))
      (is (= 90.0 (:cross (nth landed 1)))))))

(deftest trim-then-scroll-up-reproduces-exact-offsets-no-correction
  ;; Row 3 KEY property (requirement a): front-trim drops the from-0 prefix while
  ;; deep; scrolling back up through the trimmed region re-materialises it via a
  ;; checkpoint-seeded canonical walk that reproduces the EXACT offsets with NO
  ;; residual correction — because the offsets were exact (anchoredTo0) and the
  ;; retained checkpoint carries the exact state + offset from the same from-0 walk.
  (let [;; exact from-0 walk of the whole run (the anchored, pre-trim geometry):
        from0 (tw/flow-run-entries wrapl wrap-env (wrap-sized 0 12) ((:init wrapl) wrap-env))
        ;; renewal-point checkpoint at k=6 (run start, offset 120, cross 0): its
        ;; stored :state is the flow state BEFORE 6 == state AFTER 5.
        cp-state (:state (nth from0 5))
        ;; simulate: a deep scroll trimmed the cache to cacheFirst=8; scrolling up
        ;; re-flows [6,7] from the retained checkpoint at 6.
        reflow (tw/flow-run-entries wrapl wrap-env (wrap-sized 6 8) cp-state)]
    (testing "index 6 is a renewal point (run start) in the exact walk"
      (is (= 0.0 (:cross (nth from0 6))))
      (is (= 120.0 (:offset (nth from0 6)))))
    (testing "the checkpoint-seeded re-flow reproduces the exact from-0 offsets and
              real wrap cross (not the single-left-column estimate)"
      (is (= (:offset (nth from0 6)) (:offset (nth reflow 0))))   ; 120.0 == 120.0
      (is (= (:offset (nth from0 7)) (:offset (nth reflow 1))))
      (is (= 90.0 (:cross (nth reflow 1)))))
    (testing "the seam at the trimmed head (cf=8) matches exactly — NO correction"
      ;; the re-flowed prefix's end-state places index 8 at its true offset (160),
      ;; which the trimmed cache already held as its head ⇒ refine delta 0.
      (is (= 0.0 (render/refine-seam-delta wrapl wrap-env 8 (ui/Size 90 40)
                                           (:state (peek reflow))
                                           (:offset (nth from0 8))))))))

(deftest suppressed-seam-reanchor-stays-consistent
  ;; While suppressed / mid-segment the engine re-anchors the prefix AT THE SEAM
  ;; (:anchor at first-offset − d): structure identical, absolute position meets
  ;; the estimated head exactly, so the pass stays correction-free and the cache
  ;; coherent; the displacement is reconciled by a later resting pass.
  (let [sized (wrap-sized 4 6)
        truth (tw/flow-run-entries wrapl wrap-env sized ((:anchor wrapl) wrap-env 4 80.0))
        ^double d (render/refine-seam-delta wrapl wrap-env 6 (ui/Size 90 40)
                                            (:state (peek truth)) 290.0)
        seed' ((:anchor wrapl) wrap-env 4 (- ^double (:offset (nth truth 0)) d))
        anchored (tw/flow-run-entries wrapl wrap-env sized seed')]
    (testing "the re-anchored prefix meets the estimated head exactly (seam delta 0)"
      (is (= 0.0 (render/refine-seam-delta wrapl wrap-env 6 (ui/Size 90 40)
                                           (:state (peek anchored)) 290.0))))
    (testing "run structure survives — only the absolute offset moved"
      (dotimes [j (count truth)]
        (is (= (:cross (nth truth j)) (:cross (nth anchored j))))
        (is (= (- ^double (:offset (nth anchored j)) ^double (:offset (nth truth j)))
               (- d)))))))

(deftest landing-decision-one-shot
  (testing "built-in path: emit once, the corrected from-:init re-flow converges"
    (is (= :emit (render/landing-decision 40.0 true false)))
    (is (= :converged (render/landing-decision 0.0 true true))))
  (testing "suppressed / mid-segment landing defers (offset model frozen)"
    (is (= :defer (render/landing-decision 40.0 false false)))
    (is (= :defer (render/landing-decision 40.0 false true))))
  (testing "sub-pixel residual converges without emitting"
    (is (= :converged (render/landing-decision 0.0005 true false)))))

(deftest landing-violation-does-not-reemit
  ;; A contract-violating layout whose :init/:place puts index 0 at offset 40:
  ;; the first landing pass emits the correction once; the from-:init re-flow
  ;; reproduces z=40, and the second pass reports the violation (debug asserts,
  ;; release accepts the constant inset) instead of re-emitting the same
  ;; residual every pass forever.
  (let [padded {:init (fn [_env] 40.0)   ; violates ":init places index 0 at 0"
                :place (fn [env _i size ^double off]
                         [{:offset off :cross 0.0}
                          (+ off ^double (lay/size-main env size))])}
        sized (wrap-sized 0 2)
        walk1 (tw/flow-run-entries padded wrap-env sized ((:init padded) wrap-env))
        ^double z1 (:offset (nth walk1 0))
        ;; the emitted correction drops the cache; the re-run re-flows from :init
        walk2 (tw/flow-run-entries padded wrap-env sized ((:init padded) wrap-env))
        ^double z2 (:offset (nth walk2 0))]
    (is (= 40.0 z1))
    (is (= :emit (render/landing-decision z1 true false)))
    (is (= 40.0 z2))
    (testing "second pass does not emit again — the contract fails loudly instead"
      (is (= :violated (render/landing-decision z2 true true))))))

;; --- cross-layout re-anchor (wrap↔list morph while scrolled deep) ---

(deftest reanchor-offset-cross-layout-uses-new-estimate
  ;; Repro: press Wrap, Jump ~50vp, then List. The survivor top rests at index
  ;; ~1700. Wrap packs 3 items per run, so its offset is COMPRESSED (~1/3); list
  ;; stacks 1 per row, so index 1700 truly sits ~3× lower. If the post-morph
  ;; re-anchor keeps the stale WRAP offset, only ~1/3 of the px needed to fit 1700
  ;; list rows exists above the survivor → backfill exhausts its budget and pins a
  ;; deep index at offset 0: "top element is #1700, nothing above it, clamps at 0".
  (let [item-h 100.0
        per-run 3
        idx 1700
        wrap-off (* (double (quot idx per-run)) item-h)   ; ~56600  (stale, compressed)
        list-off (* (double idx) item-h)]                 ; 170000  (new-layout estimate)
    (testing "the fixture reproduces the compression that strands the leading region"
      (is (< wrap-off (* (double idx) item-h))))   ; not enough budget to reach index 0
    (testing "a cross-layout re-anchor adopts the NEW layout's estimate, not the stale offset"
      (is (= list-off (render/reanchor-offset true idx wrap-off list-off))))
    (testing "the re-anchored leading extent fits every index down to 0 (reachable)"
      ;; backfill walks up ~item-h per index; reaching 0 needs idx*item-h of budget
      (is (>= (render/reanchor-offset true idx wrap-off list-off) (* (double idx) item-h))))
    (testing "a same-layout cache loss (keyed reconcile) keeps the stale offset — no jump"
      (is (= wrap-off (render/reanchor-offset false idx wrap-off list-off))))
    (testing "a survivor at the very top ignores the estimate (already exact at 0)"
      (is (= 0.0 (render/reanchor-offset true 0 0.0 500.0))))
    (testing "a degenerate (non-positive) estimate falls back to the stale offset"
      (is (= wrap-off (render/reanchor-offset true idx wrap-off 0.0)))
      (is (= wrap-off (render/reanchor-offset true idx wrap-off nil))))
    (testing "the reverse morph (list→wrap) re-anchors LOWER — leading extent shrinks too"
      ;; list-off is the stale here; wrap-off the shorter new estimate
      (is (= wrap-off (render/reanchor-offset true idx list-off wrap-off))))))

;; --- top-underflow correction (re-anchor estimate runs short by k items) ---

(deftest underflow-decision-fires-only-at-origin
  ;; The re-anchor made the leading estimate almost right, but a residual undershoot
  ;; strands a few indices below the origin. The correction must fire ONLY there —
  ;; the origin test (head at/below 0), not the deficit magnitude, is the gate, so a
  ;; normal mid-scroll stall (frontier at a large window start) can never false-fire.
  (let [head 0.0
        honest 700.0]   ; index 7 belongs 7*100px below the origin
    (testing "a positive frontier stranded at the origin manufactures the deficit"
      (is (= :emit (render/underflow-decision 7 head honest true))))
    (testing "suppressed / mid-segment defers — the offset model stays frozen"
      (is (= :defer (render/underflow-decision 7 head honest false))))
    (testing "an index-0 frontier is not underflow — the landing check owns it"
      (is (= :ok (render/underflow-decision 0 head honest true))))
    (testing "a mid-scroll stall never fires even with a large local deficit —
              the origin gate, not the magnitude, protects it"
      (is (= :ok (render/underflow-decision 1590 158900.0 159600.0 true))))
    (testing "an already-honest frontier at the origin (deficit within eps) is quiet"
      (is (= :ok (render/underflow-decision 7 0.0 0.3 true))))
    (testing "a frontier fully at the scroll top (negative head) still fires"
      (is (= :emit (render/underflow-decision 7 -250.0 450.0 true))))))

(deftest underflow-restores-honest-range-after-short-reanchor
  ;; Repro shape: Wrap → Jump ~50vp → List re-anchors the survivor at the new-layout
  ;; estimate, but that estimate undershoots the true leading extent by k items, so
  ;; backfill exhausts its offset budget and stalls with index k at offset ≈0 —
  ;; items 0..k-1 fall below the origin and clamp ("top element is #k, nothing above
  ;; it"). At the scroll top the frontier (cf=k, head≈0) undershoots honest(k) =
  ;; approx-offset(k); the engine manufactures the deficit to restore the range.
  (let [item-h 100.0
        k 7
        env {:avg-main item-h}
        approx (:approx-offset (lay/list-layout {}))
        head 0.0                                 ; frontier stranded at the origin
        honest (double (approx env k))]          ; 700 — where index k honestly sits
    (testing "the honest estimate places index k exactly k items below the origin"
      (is (= 700.0 honest)))
    (testing "the stranded frontier manufactures exactly the missing k-item extent"
      (is (= :emit (render/underflow-decision k head honest true)))
      (is (= 700.0 (- honest head))))            ; the window shifts up by 7 items
    (testing "after the shift the frontier sits at its honest offset — deficit
              consumed, so the corrected re-run does not re-emit (single-shot)"
      (let [head' (+ head (- honest head))]
        (is (= :ok (render/underflow-decision k head' honest true)))))))

(deftest underflow-converges-with-landing-bounded
  ;; Oscillation guard: one correction makes the whole coordinate honest, so the
  ;; frontier hands off cleanly index by index down to 0 where the LANDING correction
  ;; (a different branch, cf==0) pins offset 0 — the two never ping-pong. Even under
  ;; the pathological assumption that every index re-strands at the origin, the sum
  ;; of manufactured corrections stays bounded and the frontier strictly decreases.
  (let [item-h 100.0
        env {:avg-main item-h}
        approx (:approx-offset (lay/list-layout {}))
        honest (fn [^int cf] (double (approx env cf)))]
    (testing "single-shot: the first correction makes the frontier honest, so the
              same frontier no longer underflows next pass"
      (is (= :emit (render/underflow-decision 7 0.0 (honest 7) true)))
      (is (= :ok (render/underflow-decision 7 (honest 7) (honest 7) true))))
    (testing "as the user scrolls up every lower index rests at its honest offset
              (deficit 0) — clean hand-off, no correction churn"
      (doseq [cf [6 5 4 3 2 1]]
        (is (= :ok (render/underflow-decision cf (honest cf) (honest cf) true)))))
    (testing "index 0 hands off to the landing correction — the sequence terminates"
      (is (= :ok (render/underflow-decision 0 0.0 0.0 true)))
      (is (= :emit (render/landing-decision 40.0 true false))))   ; landing owns cf==0
    (testing "pathological re-strand-every-item worst case still converges: strictly
              decreasing frontier, corrections bounded by the deepest estimate"
      (let [{:keys [^double total ^int final-cf seen]}
            (loop [^int cf 7 ^double total 0.0 seen []]
              (if (pos? cf)
                (let [^double h (honest cf)
                      ^double d (case (render/underflow-decision cf 0.0 h true)
                                  :emit h
                                  0.0)]
                  (recur (dec cf) (+ total d) (conj seen d)))
                {:total total :final-cf cf :seen seen}))]
        (is (= 0 final-cf))                       ; reaches index 0 (terminates)
        (is (every? pos? seen))                   ; every stall makes progress
        (is (<= total (* 7.0 (honest 7))))))))    ; Σ approx(cf) ≤ 7·approx(7)

;; --- canonical leading dead-reckon (wrap→jump→list no-spacing bug) ---

(deftest leading-step-canonical-list-keeps-spacing
  ;; Repro: Wrap → Jump ~50vp → List. The re-anchored deep survivor has NO
  ;; checkpoint above it (a layout :id change drops them), so backfill falls to the
  ;; single-child leading step. The old step packed `head - ext` — dropping the
  ;; layout's :spacing — and walk!'s extent-only reuse leaked that no-spacing offset
  ;; into the visible window (list pressed tight, fixed only after scrolling). The
  ;; canonical step must place the child through :place so the gap is the layout's.
  (let [spacing 8.0
        env {:axis :vertical :cross-extent 300.0 :item-count 2200}
        list (lay/list-layout {:spacing spacing})
        head 1000.0
        ext 60.0
        size (ui/Size 300.0 ext)
        e (render/leading-step-entry list env 41 head size ext 1200.0)]
    (testing "offset carries the inter-item gap: head - ext - spacing (not head - ext)"
      (is (= (- head ext spacing) (:offset e))))            ; 1000 - 60 - 8 = 932
    (testing "the laid child ends exactly `spacing` below the head — a real gap"
      (is (= (- head spacing) (:end e))))                   ; 932 + 60 = 992
    (testing "provenance is canonical — geometry came from :place"
      (is (true? (:canon e))))
    (testing "cross is the run-start value the layout assigns (0 for a list)"
      (is (= 0.0 (:cross e))))))

(deftest leading-step-canonical-matches-forward-walk
  ;; The invariant: the leading step's entry equals what a canonical forward :place
  ;; walk from its base-state produces — index i where the step laid it, and the
  ;; head (cf) back at `head`, so the run is contiguous and re-walk is a no-op.
  (let [spacing 8.0
        env {:axis :vertical :cross-extent 300.0 :item-count 2200}
        list (lay/list-layout {:spacing spacing})
        head 1000.0
        ext 60.0
        size (ui/Size 300.0 ext)
        i 41
        e (render/leading-step-entry list env i head size ext 1200.0)
        walk (tw/flow-run-entries list env
                                  [[i size ext] [(inc i) size ext]]
                                  (:base-state e))]
    (testing "forward walk places index i exactly where the leading step did"
      (is (= (:offset e) (:offset (nth walk 0)))))
    (testing "and lands the head (cf) back at `head` — the run is contiguous"
      (is (= head (:offset (nth walk 1)))))))

(deftest leading-step-wrap-preserves-run-height-pack
  ;; wrap's leading margin is accepted-approximate: a lone off-screen child can't
  ;; know its run, so it packs one run height (ext) above the head with cross 0 —
  ;; unchanged from before. The fix only ADDS the layout's main gap, which wrap
  ;; advances cross-wise (0 on main within a run), so the wrap pack is untouched.
  (let [env {:axis :vertical :cross-extent 300.0 :item-count 2200}
        wrap (lay/wrap-layout {:spacing 0 :run-spacing 0})
        head 1000.0
        ext 50.0
        size (ui/Size 100.0 ext)
        e (render/leading-step-entry wrap env 41 head size ext 1200.0)]
    (is (= (- head ext) (:offset e)))                       ; head - run height
    (is (= 0.0 (:cross e)))
    (is (true? (:canon e)))))

;; --- above-window backfill snaps to a renewal point (#A: single-left-column) ---

(deftest synth-renewal-checkpoint-lands-on-run-start
  ;; #A repro: after a deep jump / layout switch there is NO stored checkpoint
  ;; above the cache, so the backfill fell to the single-child estimate — which
  ;; places each leading wrap cell as its OWN fresh run at cross 0 (the reported
  ;; single left column). The fix synthesizes a checkpoint at the nearest renewal
  ;; point (run start) from the layout's run structure so the backfill re-flows
  ;; WHOLE runs. env: cross 200, avg-cross 90 ⇒ 2 items/run; run starts 0,2,4,…
  (let [env (assoc wrap-env :avg-main 40.0 :avg-cross 90.0)]
    (testing "a mid-run leading index snaps DOWN to its run start"
      (let [cp (render/synth-renewal-checkpoint wrapl env 5)]
        (is (= 4 (:index cp)))                              ; run start of 5
        (is (= ((:approx-offset wrapl) env 4) (:offset cp)))  ; O(1) estimate
        (is (= ((:anchor wrapl) env 4 (:offset cp)) (:state cp)))))  ; exact renewal anchor
    (testing "an index that is itself a run start needs no snap — nil (stays on the
              cheap single-child estimate path)"
      (is (nil? (render/synth-renewal-checkpoint wrapl env 4))))
    (testing "a layout without run structure (masonry) synthesizes nothing"
      (is (nil? (render/synth-renewal-checkpoint
                 (lay/masonry-layout {:cross-axis-count 3})
                 (assoc env :cross-extent 320.0) 5))))))

(deftest synth-renewal-reflow-produces-whole-runs-not-column
  ;; Reflowing from the synthesized checkpoint yields real multi-column wrap runs —
  ;; the anti-regression for the single-left-column bug. Contrast: the single-child
  ;; leading estimate places index 5 at cross 0 (its own run); the run-start-seeded
  ;; re-flow packs it into a real run at a nonzero cross.
  (let [env (assoc wrap-env :avg-main 40.0 :avg-cross 90.0)
        cp (render/synth-renewal-checkpoint wrapl env 5)
        ;; re-flow [4,5] forward from the run-start seed (real :place, real sizes)
        entries (tw/flow-run-entries wrapl env (wrap-sized 4 6) (:state cp))]
    (testing "index 4 opens the run (cross 0); index 5 packs beside it (cross 90)"
      (is (= 0.0 (:cross (nth entries 0))))
      (is (= 90.0 (:cross (nth entries 1)))))                ; multi-column, NOT 0
    (testing "the single-child estimate would instead put index 5 at cross 0 (column)"
      (let [col (render/leading-step-entry wrapl env 5 (:offset cp)
                                           (ui/Size 90 40) 40.0 1200.0)]
        (is (= 0.0 (:cross col)))))))

;; --- structural-invariant guard (estimate-shaped entry in the visible window) ---

(deftest window-canonical-violations-flags-estimate-in-window
  ;; The debug tripwire: an estimate-shaped entry (no :canon) overlapping the visible
  ;; window is a leak; a fully canonical cache — or an estimate confined OUTSIDE the
  ;; window — is clean. Root class behind #5, the Phase-E resting frames, and this bug.
  (let [canon (fn [off ext] {:offset off :end (+ off ext) :canon true})
        estim (fn [off ext] {:offset off :end (+ off ext)})   ; no :canon
        cache-first 40]
    (testing "an estimate entry inside [vs, ve) is reported with its absolute index"
      (let [cache [(canon 900.0 60.0) (estim 960.0 60.0) (canon 1020.0 60.0)]
            v (render/window-canonical-violations cache cache-first 950.0 1400.0)]
        (is (= 1 (count v)))
        (is (= 41 (first (first v))))))                      ; 40 + rel 1
    (testing "an all-canonical window has no violations"
      (let [cache [(canon 900.0 60.0) (canon 960.0 60.0)]]
        (is (empty? (render/window-canonical-violations cache cache-first 950.0 1400.0)))))
    (testing "an estimate confined OUTSIDE the visible window is allowed"
      (let [cache [(estim 100.0 60.0) (canon 1000.0 60.0)]]   ; estimate ends 160 < vs
        (is (empty? (render/window-canonical-violations cache cache-first 950.0 1400.0)))))))

(deftest ema-agg-seeds-then-blends
  (testing "nil prev seeds directly from the first live-window sample"
    (is (= {:avg-main 40.0 :avg-cross 90.0} (render/ema-agg nil 40.0 90.0))))
  (testing "subsequent samples blend by the EMA weight"
    (let [a (render/ema-agg {:avg-main 40.0 :avg-cross 90.0} 80.0 90.0)]
      (is (= 50.0 (:avg-main a)))     ; 0.75*40 + 0.25*80
      (is (= 90.0 (:avg-cross a))))))

;; ============================================================
;; WS2 phase E — velocity sensor + directional overscan + regime gate
;; ============================================================

(def ^:private nan (/ 0.0 0.0))

(deftest vel-ema-seeds-then-blends
  (testing "NaN prev (no prior sample) seeds directly from the instantaneous v"
    (is (= 1200.0 (render/vel-ema nan 1200.0 0.35))))
  (testing "subsequent samples blend by the EMA weight"
    ;; 0.65*1000 + 0.35*2000 = 1350
    (is (= 1350.0 (render/vel-ema 1000.0 2000.0 0.35))))
  (testing "a decelerating sample pulls the EMA down"
    (is (< (render/vel-ema 2000.0 0.0 0.35) 2000.0))))

(deftest vel-sign-hysteresis
  (let [eps 90.0]
    (testing "clear forward velocity is +1, clear backward -1"
      (is (= 1 (render/vel-sign 0 500.0 eps)))
      (is (= -1 (render/vel-sign 0 -500.0 eps))))
    (testing "within the ±eps band the previous sign is held (anti-thrash)"
      (is (= 1 (render/vel-sign 1 40.0 eps)))     ; small +v keeps +1
      (is (= 1 (render/vel-sign 1 -40.0 eps)))    ; brief zero-crossing keeps +1
      (is (= -1 (render/vel-sign -1 40.0 eps))))
    (testing "a reversed velocity must CLEAR eps before the sign flips"
      (is (= 1 (render/vel-sign 1 -85.0 eps)))    ; not yet cleared → still +1
      (is (= -1 (render/vel-sign 1 -95.0 eps))))))  ; cleared → flips

(deftest fidelity-regime-transitions
  ;; new arity: (fidelity-regime prev absv decel? fast-run v-slow v-fast min-fast-run)
  (let [vs 220.0 vf 3200.0 mfr 3]
    (testing "steady slow drag stays resting (Phase D behavior, wider band)"
      (is (= :resting (render/fidelity-regime :resting 100.0 false 0 vs vf mfr)))
      (is (= :resting (render/fidelity-regime :resting 100.0 true 0 vs vf mfr))))
    (testing "a medium drag that never reaches v-fast stays resting (real path)"
      (is (= :resting (render/fidelity-regime :resting 1500.0 false 0 vs vf mfr))))
    (testing "crossing v-fast for a SUSTAINED run (>= min-fast-run) enters flying"
      (is (= :flying (render/fidelity-regime :resting 4000.0 false 3 vs vf mfr))))
    (testing "hysteresis: once flying, stay flying through the band down to v-slow"
      (is (= :flying (render/fidelity-regime :flying 1500.0 true 0 vs vf mfr)))
      (is (= :flying (render/fidelity-regime :flying 250.0 true 0 vs vf mfr))))
    (testing "flying dropping below v-slow while decelerating engages landing"
      (is (= :landing (render/fidelity-regime :flying 180.0 true 0 vs vf mfr))))
    (testing "landing keeps landing while still coasting down"
      (is (= :landing (render/fidelity-regime :landing 120.0 true 0 vs vf mfr))))
    (testing "landing relaxes to resting once motion effectively dies"
      (is (= :resting (render/fidelity-regime :landing 0.5 true 0 vs vf mfr))))
    (testing "landing that re-accelerates past v-fast (sustained) flies again"
      (is (= :flying (render/fidelity-regime :landing 5000.0 false 3 vs vf mfr))))))

;; --- symptom 2 root cause: a SINGLE fast frame must NOT engage flying ---
;; (a desktop wheel/trackpad notch, a jumpTo, a correction glitch, or the first
;; post-idle sample can each read as one fast frame; only a sustained fling flies.)

(deftest single-fast-frame-does-not-fly
  (let [vs 220.0 vf 3200.0 mfr 3]
    (testing "one fast frame from rest stays resting despite absv >> v-fast"
      (is (= :resting (render/fidelity-regime :resting 12000.0 false 1 vs vf mfr)))
      (is (= :resting (render/fidelity-regime :resting 12000.0 false 2 vs vf mfr))))
    (testing "flying engages only once the run reaches min-fast-run"
      (is (= :flying (render/fidelity-regime :resting 12000.0 false 3 vs vf mfr))))))

;; --- symptom 2 root cause: velocity magnitude is correct, but desktop per-frame
;; scroll jumps read as huge velocities — proving flying must gate on a SUSTAINED
;; run rather than a single sample (units themselves are px/s, not inflated). ---

(deftest frame-velocity-realistic-numbers
  (let [frame-us 16667.0]   ; one 60fps frame in microseconds
    (testing "a 300px/s touch drag = ~5px over a frame → ~300px/s (NOT inflated ×1000)"
      ;; 5px over 16.667ms = 299.99…px/s
      (is (< 299.0 (render/frame-velocity 100.0 105.0 frame-us) 301.0)))
    (testing "a same-frame re-run (dt <= 0) reads as zero motion"
      (is (= 0.0 (render/frame-velocity 100.0 105.0 0.0)))
      (is (= 0.0 (render/frame-velocity 100.0 105.0 -1000.0))))
    (testing "a discrete desktop scroll notch (200px in ONE frame) reads as ~12000px/s"
      ;; this is why a single fast sample must not fly — it is a normal desktop nudge
      (is (< 11000.0 (render/frame-velocity 0.0 200.0 frame-us) 13000.0)))))

;; --- symptom 2 pipeline: a 300px/s touch drag, fed frame-by-frame through the real
;; sensor kernels (frame-velocity → vel-ema → flyingRun → fidelity-regime), never
;; engages flying (stays :resting every frame). ---

(deftest slow-drag-pipeline-stays-resting
  (let [vs 220.0 vf 3200.0 mfr 3 alpha 0.35 frame-us 16667.0
        ;; 20 frames of a steady 300px/s drag: +5px each 16.667ms frame.
        result (loop [i 0 off 0.0 ema (/ 0.0 0.0) run 0 regime :resting regimes []]
                 (if (= i 20)
                   regimes
                   (let [off' (+ off 5.0)
                         inst (render/frame-velocity off off' frame-us)
                         ema' (render/vel-ema ema inst alpha)
                         run' (if (>= (.abs ^double ema') vf) (inc run) 0)
                         regime' (render/fidelity-regime regime (.abs ^double ema') false run' vs vf mfr)]
                     (recur (inc i) off' ema' run' regime' (conj regimes regime')))))]
    (testing "every frame of a 300px/s drag stays resting (real, pixel-perfect path)"
      (is (every? #(= :resting %) result)))))

;; --- overscan config parsing (all forms) ---

(deftest resolve-overscan-forms
  (testing "nil (no config) → zero-config dynamic default"
    (is (= {:mode :dynamic} (render/resolve-overscan nil))))
  (testing "false / 0 / :none → disabled"
    (is (:disabled (render/resolve-overscan false)))
    (is (:disabled (render/resolve-overscan 0)))
    (is (:disabled (render/resolve-overscan :none))))
  (testing "a number → fixed symmetric px"
    (is (= {:mode :fixed :px 300.0} (render/resolve-overscan 300))))
  (testing "{:viewport f} → viewport fraction"
    (is (= {:mode :viewport :frac 0.5} (render/resolve-overscan {:viewport 0.5}))))
  (testing "the full dynamic map picks up each provided knob"
    (is (= {:mode :dynamic :base-ahead 400.0 :base-behind 100.0 :max 800.0 :lookahead-ms 120.0}
           (render/resolve-overscan {:ahead 400 :behind 100 :max 800 :lookahead-ms 120}))))
  (testing "a partial dynamic map leaves the rest to defaults"
    (is (= {:mode :dynamic :base-ahead 400.0} (render/resolve-overscan {:ahead 400}))))
  (testing "flying (approximate placement) is OFF unless explicitly opted in"
    ;; zero-config and every non-opted form must not carry :fly? — real placement,
    ;; pixel-perfect on every input device (symptom 2 regression fix)
    (is (not (:fly? (render/resolve-overscan nil))))
    (is (not (:fly? (render/resolve-overscan 300))))
    (is (not (:fly? (render/resolve-overscan {:ahead 400}))))
    (is (not (:fly? (render/resolve-overscan {:viewport 0.5})))))
  (testing "{:flying true} opts the dynamic form into the flying regime"
    (is (:fly? (render/resolve-overscan {:flying true})))
    (is (= {:mode :dynamic :base-ahead 400.0 :fly? true}
           (render/resolve-overscan {:ahead 400 :flying true}))))
  (testing "a fn is retained as an escape hatch"
    (let [f (fn [_] 100)]
      (is (= {:mode :fn :fn f} (render/resolve-overscan f))))))

;; --- overscan sizing law (clamp / base / cap / directional asymmetry) ---

(def ^:private vp 800.0)
(def ^:private lm 120.0)   ; lookahead-ms
(def ^:private amf 1.0)    ; ahead-max-frac
(def ^:private bf 0.25)    ; base-frac

(defn- ow [spec absv sign avg-main]
  (render/overscan-window spec absv sign vp avg-main lm amf bf))

(deftest overscan-window-disabled-and-fixed
  (testing "disabled / nil ⇒ [0 0]"
    (is (= [0.0 0.0] (ow {:disabled true} 3000.0 1 60.0)))
    (is (= [0.0 0.0] (ow nil 3000.0 1 60.0))))
  (testing "fixed px is symmetric and velocity-independent"
    (is (= [300.0 300.0] (ow {:mode :fixed :px 300.0} 0.0 0 60.0)))
    (is (= [300.0 300.0] (ow {:mode :fixed :px 300.0} 5000.0 1 60.0))))
  (testing "viewport fraction resolves against the viewport main extent"
    (is (= [400.0 400.0] (ow {:mode :viewport :frac 0.5} 4000.0 -1 60.0)))))

(deftest overscan-window-dynamic-law
  (let [dyn {:mode :dynamic}]
    (testing "at rest the band is the small symmetric base (one item = avg-main)"
      (is (= [60.0 60.0] (ow dyn 0.0 0 60.0))))
    (testing "no measured avg yet → base falls back to base-frac·viewport"
      (is (= [200.0 200.0] (ow dyn 0.0 0 0.0))))    ; 0.25*800
    (testing "forward motion grows AHEAD by |v|·lookahead, behind stays at base"
      ;; |v|=1000, lookahead 0.12s ⇒ lead 120; base 60 ⇒ ahead 120, behind 60
      (is (= [60.0 120.0] (ow dyn 1000.0 1 60.0))))
    (testing "backward motion mirrors the asymmetry onto BEHIND"
      (is (= [120.0 60.0] (ow dyn 1000.0 -1 60.0))))
    (testing "lead never drops below the base (clamp lower bound)"
      (is (= [60.0 60.0] (ow dyn 100.0 1 60.0))))   ; |v|·lookahead=12 < base 60
    (testing "lead is capped at ahead-max (1 viewport) on a fast fling"
      ;; |v|=20000 ⇒ raw lead 2400, capped to 800
      (is (= [60.0 800.0] (ow dyn 20000.0 1 60.0))))
    (testing "an explicit :max caps below the viewport"
      (is (= [100.0 500.0]
             (ow {:mode :dynamic :base-behind 100.0 :max 500.0} 20000.0 1 60.0))))))
