;; @ai-generated(guided)
(ns flutter-cljd.border-test
  (:require [clojure.test :refer [deftest is testing]]
            [flutter-cljd.types :as t]
            [flutter-cljd.smooth-corner :as sc]
            ["package:flutter/material.dart" :as m]))

(def ^:private grad {:type :linear :colors [:red :blue]})

(defn- approx? [^double a ^double b]
  (< (abs (- a b)) 0.001))

(deftest test-border-style
  (is (= m/BorderStyle.solid (t/border-style :solid)))
  (is (= m/BorderStyle.none (t/border-style :none)))
  (is (= m/BorderStyle.solid (t/border-style m/BorderStyle.solid)))
  (is (thrown? Exception (t/border-style :bogus))))

(deftest test-border-side
  (testing "number is the stroke width, black solid"
    (let [^m/BorderSide s (t/border-side 3)]
      (is (approx? 3.0 (.-width s)))
      (is (= m/Colors.black (.-color s)))
      (is (= m/BorderStyle.solid (.-style s)))))

  (testing ":none is BorderSide.none"
    (is (= m/BorderSide.none (t/border-side :none))))

  (testing "a bare color keyword sets the color, width 1"
    (let [^m/BorderSide s (t/border-side :red)]
      (is (= m/Colors.red (.-color s)))
      (is (approx? 1.0 (.-width s)))))

  (testing "map spec with width/color/style/align"
    (let [^m/BorderSide s (t/border-side {:width 2 :color :red :style :solid :align :outside})]
      (is (approx? 2.0 (.-width s)))
      (is (= m/Colors.red (.-color s)))
      (is (approx? m/BorderSide.strokeAlignOutside (.-strokeAlign s)))))

  (testing "map defaults: width 1, black, solid, inside"
    (let [^m/BorderSide s (t/border-side {:color :blue})]
      (is (approx? 1.0 (.-width s)))
      (is (= m/Colors.blue (.-color s)))
      (is (approx? m/BorderSide.strokeAlignInside (.-strokeAlign s)))))

  (testing "a BorderSide passes through"
    (let [side (m/BorderSide .width 5.0)]
      (is (= side (t/border-side side))))))

(deftest test-border
  (testing "number is a uniform width"
    (let [^m/Border b (t/border 2)]
      (is (.-isUniform b))
      (is (approx? 2.0 (.-width (.-top b))))))

  (testing "bare color is a uniform colored border"
    (let [^m/Border b (t/border :red)]
      (is (.-isUniform b))
      (is (= m/Colors.red (.-color (.-top b))))))

  (testing "a single-side map is applied to every edge"
    (let [^m/Border b (t/border {:width 2 :color :black})]
      (is (.-isUniform b))
      (is (approx? 2.0 (.-width (.-top b))))
      (is (approx? 2.0 (.-width (.-bottom b))))))

  (testing "per-edge map only sets named edges"
    (let [^m/Border b (t/border {:bottom 3})]
      (is (approx? 3.0 (.-width (.-bottom b))))
      (is (= m/BorderStyle.none (.-style (.-top b))))))

  (testing ":all is the fallback for unset edges"
    (let [^m/Border b (t/border {:all 1 :bottom 3})]
      (is (approx? 1.0 (.-width (.-top b))))
      (is (approx? 1.0 (.-width (.-left b))))
      (is (approx? 3.0 (.-width (.-bottom b))))))

  (testing ":horizontal is left & right (DSL convention, not Border.symmetric)"
    (let [^m/Border b (t/border {:horizontal 2})]
      (is (approx? 2.0 (.-width (.-left b))))
      (is (approx? 2.0 (.-width (.-right b))))
      (is (= m/BorderStyle.none (.-style (.-top b))))))

  (testing ":vertical is top & bottom"
    (let [^m/Border b (t/border {:vertical 2})]
      (is (approx? 2.0 (.-width (.-top b))))
      (is (approx? 2.0 (.-width (.-bottom b))))
      (is (= m/BorderStyle.none (.-style (.-left b))))))

  (testing "start/end produce a BorderDirectional"
    (let [b (t/border {:start {:color :red} :end 2})]
      (is (instance? m/BorderDirectional b))))

  (testing "a BoxBorder passes through"
    (let [b (m/Border.all .width 4.0)]
      (is (= b (t/border b))))))

(deftest test-decoration-border-and-blend-mode
  (testing "decoration accepts a border map"
    (let [^m/BoxDecoration d (t/decoration {:color :white :border {:width 2 :color :black}})]
      (is (instance? m/Border (.-border d)))
      (is (approx? 2.0 (.-width (.-top ^m/Border (.-border d)))))))

  (testing "decoration accepts a keyword background blend mode"
    (let [^m/BoxDecoration d (t/decoration {:color :white :background-blend-mode :multiply})]
      (is (= m/BlendMode.multiply (.-backgroundBlendMode d))))))

(deftest test-gradient-border
  (testing "a uniform border with :gradient routes to the smooth painter"
    (let [d (t/decoration {:color :white :border {:width 3 :gradient grad}})]
      (is (instance? sc/SmoothDecoration d))
      ;; the stroked side keeps its width; the gradient rides alongside it
      (is (approx? 3.0 (.-width (.-side ^sc/SmoothDecoration d))))
      (is (some? (.-border-gradient ^sc/SmoothDecoration d)))
      (is (not (.-assert-square? ^sc/SmoothDecoration d)))))

  (testing "gradient border works with any corners (incl. sharp, radius 0)"
    (is (instance? sc/SmoothDecoration
                   (t/decoration {:border {:width 2 :gradient grad}})))
    (is (instance? sc/SmoothDecoration
                   (t/decoration {:border-radius 12 :border {:width 2 :gradient grad}}))))

  (testing "gradient border on a circle → rel-0.5 outline, asserts squareness"
    (let [d (t/decoration {:shape :circle :border {:width 4 :gradient grad}})]
      (is (instance? sc/SmoothDecoration d))
      (is (.-assert-square? ^sc/SmoothDecoration d))))

  (testing "per-side gradient borders are rejected"
    (is (thrown? Exception (t/decoration {:border {:top {:width 2 :gradient grad}}}))))

  (testing "a gradient border without an explicit width defaults to 1px"
    (let [d (t/decoration {:border {:gradient grad}})]
      (is (instance? sc/SmoothDecoration d))
      (is (approx? 1.0 (.-width (.-side ^sc/SmoothDecoration d))))))

  (testing "a ready BorderRadius instance can't carry a gradient border"
    (is (thrown? Exception
                 (t/decoration {:border-radius (m/BorderRadius.circular 8)
                                :border {:width 2 :gradient grad}})))))

(deftest test-gradient-color-coercion
  (testing "t/gradient coerces a color into a solid gradient (same at both ends)"
    (let [g (t/gradient :red)
          colors (.-colors g)]
      (is (instance? m/Gradient g))
      ;; solid: every stop is the same color, whatever resampling happened
      (is (apply = colors))))

  (testing "a Color instance and a hex string coerce too"
    (is (instance? m/Gradient (t/gradient m/Colors.blue)))
    (is (instance? m/Gradient (t/gradient "#ff0000"))))

  (testing "an existing gradient and a typed map still pass through"
    (is (instance? m/Gradient (t/gradient grad)))
    (is (instance? m/Gradient (t/gradient (t/linear-gradient {:colors [:red :blue]})))))

  (testing "a color works as a (solid) gradient border"
    (is (instance? sc/SmoothDecoration
                   (t/decoration {:border {:width 2 :gradient :red}})))))
